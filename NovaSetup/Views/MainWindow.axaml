<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        d:DesignWidth="1500"
        d:DesignHeight="980"
        x:Class="NovaSetup.Views.MainWindow"
        x:CompileBindings="False"
        Title="NovaSetup"
        Icon="avares://NovaSetup/Assets/nova_logo.ico"
        RequestedThemeVariant="Default"
        Background="#050915"
        Foreground="#E6EBFF"
        MinWidth="1120"
        MinHeight="720">
    <Window.Resources>
        <SolidColorBrush x:Key="ShellBorderBrush" Color="#1A2742" />
        <SolidColorBrush x:Key="TopBarBrush" Color="#0C1121" />
        <SolidColorBrush x:Key="SidebarBrush" Color="#111827" />
        <SolidColorBrush x:Key="PanelBrush" Color="#101A2E" />
        <SolidColorBrush x:Key="CardBrush" Color="#141F36" />
        <SolidColorBrush x:Key="CardBorderBrush" Color="#253757" />
        <SolidColorBrush x:Key="InputBrush" Color="#1A243A" />
        <SolidColorBrush x:Key="InputBorderBrush" Color="#2D3E62" />
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#EEF3FF" />
        <SolidColorBrush x:Key="TextMutedBrush" Color="#A3B2D3" />
        <SolidColorBrush x:Key="AccentBrush" Color="#3E7BFF" />
        <SolidColorBrush x:Key="AccentSoftBrush" Color="#233C7A" />
        <SolidColorBrush x:Key="SuccessBrush" Color="#1DBF8B" />
        <SolidColorBrush x:Key="WarningBrush" Color="#F59E0B" />
        <SolidColorBrush x:Key="DangerBrush" Color="#F87171" />
    </Window.Resources>

    <Window.Styles>
        <Style Selector="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="FontFamily" Value="Segoe UI Variable Text, Segoe UI, Inter, Arial" />
        </Style>

        <Style Selector="Border.shellPanel">
            <Setter Property="BorderBrush" Value="{StaticResource ShellBorderBrush}" />
            <Setter Property="BorderThickness" Value="1.2" />
            <Setter Property="CornerRadius" Value="26" />
        </Style>

        <Style Selector="Border.card">
            <Setter Property="Background" Value="{StaticResource CardBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Padding" Value="10" />
        </Style>

        <Style Selector="Border.rowCard">
            <Setter Property="Background" Value="#10192E" />
            <Setter Property="BorderBrush" Value="#263A5C" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="7" />
            <Setter Property="Margin" Value="0,0,0,4" />
        </Style>

        <Style Selector="TextBox">
            <Setter Property="Background" Value="{StaticResource InputBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource InputBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="CornerRadius" Value="11" />
            <Setter Property="Padding" Value="10,7" />
        </Style>

        <Style Selector="ComboBox">
            <Setter Property="Background" Value="{StaticResource InputBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource InputBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="Padding" Value="8,6" />
        </Style>

        <Style Selector="ComboBoxItem">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="Background" Value="{StaticResource InputBrush}" />
        </Style>

        <Style Selector="Button">
            <Setter Property="Background" Value="#1B2740" />
            <Setter Property="BorderBrush" Value="#314468" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="10,6" />
        </Style>

        <Style Selector="Button.primary">
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderBrush" Value="#72A0FF" />
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="18,9" />
            <Setter Property="FontSize" Value="15" />
        </Style>

        <Style Selector="Button.ghost">
            <Setter Property="Background" Value="#1C253A" />
            <Setter Property="BorderBrush" Value="#2C3C5F" />
        </Style>

        <Style Selector="Button.icon">
            <Setter Property="Width" Value="38" />
            <Setter Property="Height" Value="38" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="FontSize" Value="15" />
        </Style>

        <Style Selector="Button.link">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Foreground" Value="#95BEFF" />
            <Setter Property="HorizontalAlignment" Value="Left" />
        </Style>

        <Style Selector="Button.nav">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="11,7" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="FontSize" Value="15" />
        </Style>

        <Style Selector="Button.navActive">
            <Setter Property="Background" Value="{StaticResource AccentSoftBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderThickness" Value="1.2" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style Selector="RadioButton.pill">
            <Setter Property="Background" Value="#1A243A" />
            <Setter Property="BorderBrush" Value="#2F4063" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
            <Setter Property="CornerRadius" Value="999" />
            <Setter Property="Padding" Value="10,5" />
            <Setter Property="FontSize" Value="13" />
        </Style>

        <Style Selector="RadioButton.pill:checked">
            <Setter Property="Background" Value="#204C93" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
            <Setter Property="Foreground" Value="#EAF1FF" />
        </Style>

        <Style Selector="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="FontSize" Value="14" />
        </Style>

        <Style Selector="CheckBox.appCheck">
            <Setter Property="Width" Value="22" />
            <Setter Property="Height" Value="22" />
            <Setter Property="Background" Value="#0E162A" />
            <Setter Property="BorderBrush" Value="#36507D" />
            <Setter Property="BorderThickness" Value="1.4" />
        </Style>
    </Window.Styles>

    <Border Margin="10"
            Classes="shellPanel"
            Padding="10">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#0A1020" Offset="0" />
                <GradientStop Color="#070D1A" Offset="1" />
            </LinearGradientBrush>
        </Border.Background>

        <Grid RowDefinitions="Auto,*" RowSpacing="10">
            <Border Grid.Row="0"
                    Classes="shellPanel"
                    CornerRadius="20"
                    Padding="10"
                    Background="{StaticResource TopBarBrush}">
                <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto" ColumnSpacing="10">
                    <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                        <Border Width="36"
                                Height="36"
                                CornerRadius="10"
                                Background="#10203F"
                                ClipToBounds="True">
                            <Image Source="avares://NovaSetup/Assets/nova_logo_512.png"
                                   Stretch="UniformToFill" />
                        </Border>
                        <StackPanel Spacing="0" VerticalAlignment="Center">
                            <TextBlock Text="Nova"
                                       FontSize="22"
                                       FontWeight="Bold" />
                            <TextBlock Text="Setup everything fast"
                                       FontSize="13"
                                       Foreground="{StaticResource TextMutedBrush}" />
                        </StackPanel>
                    </StackPanel>

                    <Border Grid.Column="2"
                            Background="#131F35"
                            BorderBrush="#294067"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="10,5"
                            VerticalAlignment="Center">
                        <TextBlock Text="{Binding CurrentPlatform, StringFormat='OS: {0}'}"
                                   Foreground="{StaticResource TextMutedBrush}" />
                    </Border>

                    <Button Grid.Column="3"
                            Classes="icon ghost"
                            Command="{Binding ToggleSettingsPanelCommand}">
                        <Viewbox Width="16" Height="16">
                            <Path Fill="{StaticResource TextPrimaryBrush}"
                                  Data="M19.14,12.94A7.43,7.43 0 0,0 19.19,12A7.43,7.43 0 0,0 19.14,11.06L21.19,9.47C21.37,9.33 21.42,9.08 21.31,8.88L19.31,5.42C19.2,5.22 18.95,5.13 18.74,5.2L16.33,6.17C15.83,5.79 15.29,5.47 14.7,5.23L14.34,2.67C14.31,2.44 14.11,2.27 13.88,2.27H10.12C9.89,2.27 9.69,2.44 9.66,2.67L9.3,5.23C8.71,5.47 8.17,5.79 7.67,6.17L5.26,5.2C5.05,5.13 4.8,5.22 4.69,5.42L2.69,8.88C2.58,9.08 2.63,9.33 2.81,9.47L4.86,11.06A7.43,7.43 0 0,0 4.81,12A7.43,7.43 0 0,0 4.86,12.94L2.81,14.53C2.63,14.67 2.58,14.92 2.69,15.12L4.69,18.58C4.8,18.78 5.05,18.87 5.26,18.8L7.67,17.83C8.17,18.21 8.71,18.53 9.3,18.77L9.66,21.33C9.69,21.56 9.89,21.73 10.12,21.73H13.88C14.11,21.73 14.31,21.56 14.34,21.33L14.7,18.77C15.29,18.53 15.83,18.21 16.33,17.83L18.74,18.8C18.95,18.87 19.2,18.78 19.31,18.58L21.31,15.12C21.42,14.92 21.37,14.67 21.19,14.53L19.14,12.94M12,15.5A3.5,3.5 0 0,1 8.5,12A3.5,3.5 0 0,1 12,8.5A3.5,3.5 0 0,1 15.5,12A3.5,3.5 0 0,1 12,15.5Z" />
                        </Viewbox>
                    </Button>
                    <Button Grid.Column="4"
                            Classes="icon ghost"
                            Content="?"
                            FontSize="18" />
                </Grid>
            </Border>

            <Grid Grid.Row="1" ColumnDefinitions="186,*" ColumnSpacing="10">
                <Border Grid.Column="0"
                        Classes="shellPanel"
                        CornerRadius="18"
                        Background="{StaticResource SidebarBrush}"
                        Padding="6">
                    <Grid RowDefinitions="*,Auto">
                        <StackPanel Spacing="4">
                            <Button Classes="nav navActive"
                                    IsVisible="{Binding IsDashboardSelected}"
                                    Content="Dashboard"
                                    Command="{Binding NavigateDashboardCommand}" />
                            <Button Classes="nav"
                                    IsVisible="{Binding IsDashboardUnselected}"
                                    Content="Dashboard"
                                    Command="{Binding NavigateDashboardCommand}" />

                            <Button Classes="nav navActive"
                                    IsVisible="{Binding IsAppsSelected}"
                                    Content="Apps"
                                    Command="{Binding NavigateAppsCommand}" />
                            <Button Classes="nav"
                                    IsVisible="{Binding IsAppsUnselected}"
                                    Content="Apps"
                                    Command="{Binding NavigateAppsCommand}" />

                            <Button Classes="nav navActive"
                                    IsVisible="{Binding IsDriversSelected}"
                                    Content="Drivers"
                                    Command="{Binding NavigateDriversCommand}" />
                            <Button Classes="nav"
                                    IsVisible="{Binding IsDriversUnselected}"
                                    Content="Drivers"
                                    Command="{Binding NavigateDriversCommand}" />

                            <Button Classes="nav navActive"
                                    IsVisible="{Binding IsMyListsSelected}"
                                    Content="My Lists"
                                    Command="{Binding NavigateMyListsCommand}" />
                            <Button Classes="nav"
                                    IsVisible="{Binding IsMyListsUnselected}"
                                    Content="My Lists"
                                    Command="{Binding NavigateMyListsCommand}" />

                            <Button Classes="nav navActive"
                                    IsVisible="{Binding IsHistorySelected}"
                                    Content="History"
                                    Command="{Binding NavigateHistoryCommand}" />
                            <Button Classes="nav"
                                    IsVisible="{Binding IsHistoryUnselected}"
                                    Content="History"
                                    Command="{Binding NavigateHistoryCommand}" />

                            <Button Classes="nav navActive"
                                    IsVisible="{Binding IsLogsSelected}"
                                    Content="Logs"
                                    Command="{Binding NavigateLogsCommand}" />
                            <Button Classes="nav"
                                    IsVisible="{Binding IsLogsUnselected}"
                                    Content="Logs"
                                    Command="{Binding NavigateLogsCommand}" />
                        </StackPanel>

                        <Border Grid.Row="1"
                                Classes="card"
                                Padding="10"
                                Background="#111A2C">
                            <StackPanel Spacing="6">
                                <TextBlock Text="Current profile"
                                           FontWeight="SemiBold" />
                                <TextBlock Text="{Binding CurrentProfileName}"
                                           Foreground="{StaticResource TextMutedBrush}" />
                                <TextBlock Text="{Binding SelectedCount, StringFormat='Selected: {0} app(s)'}"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           FontSize="12" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <Border Grid.Column="1"
                        Classes="shellPanel"
                        CornerRadius="18"
                        Background="{StaticResource PanelBrush}"
                        Padding="12">
                    <Grid>
                        <Grid IsVisible="{Binding IsHomeScreenVisible}"
                              RowDefinitions="Auto,*"
                              RowSpacing="8">
                            <StackPanel Grid.Row="0"
                                        Margin="4,2,4,0"
                                        Spacing="2">
                                <TextBlock Text="{Binding HomeTitle}"
                                           FontSize="24"
                                           FontWeight="Bold"
                                           TextWrapping="Wrap" />
                                <TextBlock Text="{Binding HomeSubtitle}"
                                           FontSize="14"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           TextWrapping="Wrap" />
                            </StackPanel>

                            <Border Grid.Row="1" Classes="card">
                                <Grid RowDefinitions="Auto,*,Auto" RowSpacing="8">
                                    <Grid Grid.Row="0" RowDefinitions="Auto,Auto" RowSpacing="6">
                                        <TextBox Width="260"
                                                 MinWidth="220"
                                                 MaxWidth="320"
                                                 Watermark="Search apps..."
                                                 Text="{Binding SearchText}" />

                                        <ScrollViewer Grid.Row="1"
                                                      HorizontalScrollBarVisibility="Auto"
                                                      VerticalScrollBarVisibility="Disabled">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <RadioButton GroupName="filter"
                                                             Classes="pill"
                                                             IsChecked="{Binding IsAllFilter}"
                                                             Content="All" />
                                                <RadioButton GroupName="filter"
                                                             Classes="pill"
                                                             IsChecked="{Binding IsGamesFilter}"
                                                             Content="Games" />
                                                <RadioButton GroupName="filter"
                                                             Classes="pill"
                                                             IsChecked="{Binding IsDevToolsFilter}"
                                                             Content="Dev Tools" />
                                                <RadioButton GroupName="filter"
                                                             Classes="pill"
                                                             IsChecked="{Binding IsUtilitiesFilter}"
                                                             Content="Utilities" />
                                            </StackPanel>
                                        </ScrollViewer>
                                    </Grid>

                                    <Grid Grid.Row="1" RowDefinitions="Auto,*" RowSpacing="6">
                                        <Grid ColumnDefinitions="36,*,70,88,56"
                                              Margin="2,0,8,0">
                                            <TextBlock Text="Sel" FontWeight="SemiBold" Foreground="{StaticResource TextMutedBrush}" />
                                            <TextBlock Grid.Column="1" Text="App" FontWeight="SemiBold" Foreground="{StaticResource TextMutedBrush}" />
                                            <TextBlock Grid.Column="2" Text="Size" FontWeight="SemiBold" Foreground="{StaticResource TextMutedBrush}" />
                                            <TextBlock Grid.Column="3" Text="Status" FontWeight="SemiBold" Foreground="{StaticResource TextMutedBrush}" />
                                            <TextBlock Grid.Column="4" Text="Details" FontWeight="SemiBold" Foreground="{StaticResource TextMutedBrush}" />
                                        </Grid>

                                        <ScrollViewer Grid.Row="1"
                                                      VerticalScrollBarVisibility="Auto"
                                                      HorizontalScrollBarVisibility="Disabled">
                                            <ItemsControl ItemsSource="{Binding VisibleApps}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Classes="rowCard" Opacity="{Binding RowOpacity}">
                                                            <Grid ColumnDefinitions="36,*,70,88,56" ColumnSpacing="8">
                                                                <CheckBox Classes="appCheck"
                                                                          IsChecked="{Binding IsSelected}"
                                                                          IsEnabled="{Binding IsSupportedOnCurrentPlatform}"
                                                                          VerticalAlignment="Center"
                                                                          HorizontalAlignment="Center" />

                                                                <Grid Grid.Column="1" ColumnDefinitions="36,*" ColumnSpacing="10">
                                                                    <Border Width="32"
                                                                            Height="32"
                                                                            CornerRadius="16"
                                                                            Background="#223765"
                                                                            VerticalAlignment="Center">
                                                                        <TextBlock Text="{Binding IconGlyph}"
                                                                                   HorizontalAlignment="Center"
                                                                                   VerticalAlignment="Center"
                                                                                   FontWeight="Bold" />
                                                                    </Border>

                                                                    <StackPanel Grid.Column="1" Spacing="1">
                                                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                                                            <TextBlock Text="{Binding Name}" FontSize="15" FontWeight="SemiBold" />
                                                                            <Border IsVisible="{Binding IsRecommended}"
                                                                                    Background="#214A92"
                                                                                    BorderBrush="{StaticResource AccentBrush}"
                                                                                    BorderThickness="1"
                                                                                    CornerRadius="7"
                                                                                    Padding="6,2">
                                                                                <TextBlock Text="Recommended" FontSize="10" />
                                                                            </Border>
                                                                        </StackPanel>

                                                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                                                            <TextBlock Text="{Binding Category}"
                                                                                       Foreground="{StaticResource TextMutedBrush}"
                                                                                       FontSize="12" />
                                                                            <Button Classes="link"
                                                                                    Content="{Binding PublisherName}"
                                                                                    Command="{Binding $parent[Window].DataContext.OpenPublisherCommand}"
                                                                                    CommandParameter="{Binding .}" />
                                                                        </StackPanel>
                                                                    </StackPanel>
                                                                </Grid>

                                                                <TextBlock Grid.Column="2"
                                                                           Text="~ 20 MB"
                                                                           VerticalAlignment="Center"
                                                                           Foreground="{StaticResource TextMutedBrush}" />

                                                                <Border Grid.Column="3"
                                                                        Background="#162643"
                                                                        BorderBrush="#2C456B"
                                                                        BorderThickness="1"
                                                                        CornerRadius="8"
                                                                        Padding="8,3"
                                                                        VerticalAlignment="Center"
                                                                        HorizontalAlignment="Left">
                                                                    <TextBlock Text="{Binding StatusBadge}"
                                                                               FontSize="12" />
                                                                </Border>

                                                                <Button Grid.Column="4"
                                                                        Classes="ghost"
                                                                        Content="..."
                                                                        Width="48"
                                                                        HorizontalAlignment="Left"
                                                                        Command="{Binding $parent[Window].DataContext.ShowAppDetailsCommand}"
                                                                        CommandParameter="{Binding .}" />
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </ScrollViewer>
                                    </Grid>

                                    <Border Grid.Row="2"
                                            Background="#0F172A"
                                            BorderBrush="#273A5F"
                                            BorderThickness="1"
                                            CornerRadius="12"
                                            Padding="10">
                                        <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                                      VerticalScrollBarVisibility="Disabled">
                                            <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10">
                                                <TextBlock Text="{Binding SelectedFooterText}"
                                                           Foreground="{StaticResource TextMutedBrush}"
                                                           VerticalAlignment="Center" />

                                                <Button Grid.Column="1"
                                                        Classes="ghost"
                                                        Content="Save List"
                                                        Command="{Binding SaveListCommand}"
                                                        Padding="22,9" />
                                                <Button Grid.Column="2"
                                                        Classes="primary"
                                                        Content="Install Selected"
                                                        Command="{Binding InstallCommand}" />
                                            </Grid>
                                        </ScrollViewer>
                                    </Border>
                                </Grid>
                            </Border>
                        </Grid>

                        <ScrollViewer IsVisible="{Binding IsInstallScreenVisible}"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <StackPanel Spacing="12" Margin="0,0,6,0">
                            <Border Classes="card" Padding="18">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="Installing"
                                               FontSize="44"
                                               FontWeight="Bold" />
                                    <TextBlock Text="Using official sources, silent installers when available, and logging every step."
                                               FontSize="15"
                                               Foreground="{StaticResource TextMutedBrush}" />
                                </StackPanel>
                            </Border>

                            <Border Classes="card">
                                <StackPanel Spacing="10">
                                    <TextBlock Text="{Binding ProgressValue, StringFormat='Overall progress: {0:0}%'}"
                                               Foreground="{StaticResource TextMutedBrush}" />
                                    <ProgressBar Minimum="0"
                                                 Maximum="100"
                                                 Value="{Binding ProgressValue}"
                                                 Height="16"
                                                 Background="#1B2946"
                                                 Foreground="{StaticResource AccentBrush}" />
                                </StackPanel>
                            </Border>

                            <Grid ColumnDefinitions="2*,1*" ColumnSpacing="10">
                                <Border Grid.Column="0" Classes="card">
                                    <StackPanel Spacing="8">
                                        <TextBlock Text="Now installing" FontSize="18" FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding InstallStatusText}"
                                                   TextWrapping="Wrap"
                                                   Foreground="{StaticResource TextMutedBrush}" />
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="1" Classes="card">
                                    <StackPanel Spacing="8">
                                        <TextBlock Text="Actions" FontSize="18" FontWeight="SemiBold" />
                                        <Button Content="Pause"
                                                Command="{Binding PauseInstallCommand}" />
                                        <Button Content="Open Logs"
                                                Command="{Binding OpenLogFileCommand}" />
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <Border Classes="card">
                                <StackPanel Spacing="8">
                                    <TextBlock Text="Queue" FontSize="18" FontWeight="SemiBold" />
                                    <ItemsControl ItemsSource="{Binding InstallResults}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border BorderBrush="#294067"
                                                        BorderThickness="1"
                                                        CornerRadius="9"
                                                        Padding="10"
                                                        Margin="0,0,0,6">
                                                    <Grid ColumnDefinitions="2*,Auto,3*">
                                                        <TextBlock Text="{Binding AppName}" FontWeight="SemiBold" />
                                                        <TextBlock Grid.Column="1"
                                                                   Text="{Binding Skipped, StringFormat='Skipped: {0}'}"
                                                                   Foreground="{StaticResource TextMutedBrush}" />
                                                        <TextBlock Grid.Column="2"
                                                                   Text="{Binding Message}"
                                                                   Foreground="{StaticResource TextMutedBrush}"
                                                                   TextWrapping="Wrap" />
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>

                            <Grid ColumnDefinitions="Auto,Auto,*" ColumnSpacing="10">
                                <Button Grid.Column="0"
                                        Content="Open Log File"
                                        Command="{Binding OpenLogFileCommand}" />
                                <Button Grid.Column="1"
                                        Classes="ghost"
                                        Content="Finish and Summary (auto)"
                                        IsEnabled="False" />
                            </Grid>
                            </StackPanel>
                        </ScrollViewer>

                        <ScrollViewer IsVisible="{Binding IsSummaryScreenVisible}"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <StackPanel Spacing="12" Margin="0,0,6,0">
                            <Border Classes="card" Padding="18">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="Setup complete"
                                               FontSize="44"
                                               FontWeight="Bold" />
                                    <TextBlock Text="{Binding InstallSummaryText}"
                                               FontSize="16"
                                               Foreground="{StaticResource TextMutedBrush}" />
                                </StackPanel>
                            </Border>

                            <Grid ColumnDefinitions="1.6*,1*" ColumnSpacing="10">
                                <Border Grid.Column="0" Classes="card">
                                    <StackPanel Spacing="10">
                                        <TextBlock Text="Installed summary" FontSize="18" FontWeight="SemiBold" />
                                        <Grid ColumnDefinitions="1*,1*,1*,1*" ColumnSpacing="8">
                                            <Border Background="#0F2B24" CornerRadius="10" Padding="10">
                                                <TextBlock Text="{Binding InstalledResults.Count, StringFormat='Installed {0}'}"
                                                           Foreground="{StaticResource SuccessBrush}" />
                                            </Border>
                                            <Border Grid.Column="1" Background="#2B1B1B" CornerRadius="10" Padding="10">
                                                <TextBlock Text="{Binding FailedResults.Count, StringFormat='Failed {0}'}"
                                                           Foreground="{StaticResource DangerBrush}" />
                                            </Border>
                                            <Border Grid.Column="2" Background="#2B2416" CornerRadius="10" Padding="10">
                                                <TextBlock Text="{Binding SkippedResults.Count, StringFormat='Skipped {0}'}"
                                                           Foreground="{StaticResource WarningBrush}" />
                                            </Border>
                                            <Border Grid.Column="3" Background="#192742" CornerRadius="10" Padding="10">
                                                <TextBlock Text="{Binding RestartRequiredResults.Count, StringFormat='Restart {0}'}"
                                                           Foreground="{StaticResource AccentBrush}" />
                                            </Border>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="1" Classes="card">
                                    <StackPanel Spacing="8">
                                        <TextBlock Text="Next steps" FontSize="18" FontWeight="SemiBold" />
                                        <TextBlock Text="- Launch installed apps and sign in if needed."
                                                   Foreground="{StaticResource TextMutedBrush}" />
                                        <TextBlock Text="- Check drivers if hardware tools were installed."
                                                   Foreground="{StaticResource TextMutedBrush}" />
                                        <TextBlock Text="- Keep this profile as your default setup list."
                                                   Foreground="{StaticResource TextMutedBrush}" />
                                        <TextBlock Text="{Binding Settings.SelfDeleteAfterInstall, StringFormat='Self-delete setting: {0}'}"
                                                   Foreground="{StaticResource TextMutedBrush}" />
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <Border Classes="card"
                                    IsVisible="{Binding IsRestartSectionVisible}"
                                    Background="#2A1F13"
                                    BorderBrush="#684B1E">
                                <StackPanel Spacing="8">
                                    <TextBlock Text="Restart Recommended"
                                               FontSize="18"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource WarningBrush}" />
                                    <TextBlock Text="{Binding RestartStatusText}"
                                               Foreground="#FCD9A5"
                                               TextWrapping="Wrap" />

                                    <StackPanel Orientation="Horizontal"
                                                Spacing="8"
                                                IsVisible="{Binding ShowPrimaryRestartActions}">
                                        <Button Classes="primary"
                                                Content="Restart Now"
                                                Command="{Binding RequestRestartNowCommand}" />
                                        <Button Content="Skip / Restart Later"
                                                Command="{Binding RestartLaterCommand}" />
                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal"
                                                Spacing="8"
                                                IsVisible="{Binding IsRestartConfirmationVisible}">
                                        <Button Classes="primary"
                                                Content="Confirm Restart"
                                                Command="{Binding ConfirmRestartNowCommand}" />
                                        <Button Content="Cancel"
                                                Command="{Binding CancelRestartCommand}" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <Grid ColumnDefinitions="Auto,Auto,Auto,*" ColumnSpacing="10">
                                <Button Grid.Column="0"
                                        Content="Save Default List"
                                        Command="{Binding SaveListCommand}" />
                                <Button Grid.Column="1"
                                        Content="Export Report (PDF)"
                                        Command="{Binding ExportReportCommand}" />
                                <Button Grid.Column="2"
                                        Content="Open Log File"
                                        Command="{Binding OpenLogFileCommand}" />
                            </Grid>

                            <Border Classes="card" IsVisible="{Binding HasInstalledResults}">
                                <StackPanel Spacing="6">
                                    <TextBlock Text="{Binding InstalledResults.Count, StringFormat='Installed Apps ({0})'}"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource SuccessBrush}" />
                                    <ItemsControl ItemsSource="{Binding InstalledResults}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding AppName}" />
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>

                            <Border Classes="card" IsVisible="{Binding HasFailedResults}">
                                <StackPanel Spacing="6">
                                    <TextBlock Text="{Binding FailedResults.Count, StringFormat='Failed Apps ({0})'}"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource DangerBrush}" />
                                    <ItemsControl ItemsSource="{Binding FailedResults}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding AppName, StringFormat='- {0}'}" />
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>

                            <Border Classes="card" IsVisible="{Binding HasSkippedResults}">
                                <StackPanel Spacing="6">
                                    <TextBlock Text="{Binding SkippedResults.Count, StringFormat='Skipped Apps ({0})'}"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource WarningBrush}" />
                                    <ItemsControl ItemsSource="{Binding SkippedResults}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding AppName, StringFormat='- {0}'}" />
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>

                            <Border Classes="card" IsVisible="{Binding HasRestartRequiredResults}">
                                <StackPanel Spacing="6">
                                    <TextBlock Text="{Binding RestartRequiredResults.Count, StringFormat='Apps Requiring Restart ({0})'}"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource AccentBrush}" />
                                    <ItemsControl ItemsSource="{Binding RestartRequiredResults}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding AppName, StringFormat='- {0}'}" />
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                            </StackPanel>
                        </ScrollViewer>

                        <Border IsVisible="{Binding IsHistoryEmptyScreenVisible}"
                                Classes="card"
                                Padding="20">
                            <StackPanel Spacing="10">
                                <TextBlock Text="History"
                                           FontSize="34"
                                           FontWeight="Bold" />
                                <TextBlock Text="No install history yet. Run an install and the summary will appear here."
                                           Foreground="{StaticResource TextMutedBrush}"
                                           TextWrapping="Wrap" />
                                <Button Content="Back to Apps"
                                        Command="{Binding NavigateAppsCommand}"
                                        HorizontalAlignment="Left" />
                            </StackPanel>
                        </Border>

                        <ScrollViewer IsVisible="{Binding IsLogsScreenVisible}"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <StackPanel Spacing="12" Margin="0,0,6,0">
                                <Border Classes="card" Padding="18">
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="Logs"
                                                   FontSize="34"
                                                   FontWeight="Bold" />
                                        <TextBlock Text="Open the current runtime log file or inspect the latest status message below."
                                                   FontSize="15"
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>

                                <Border Classes="card">
                                    <StackPanel Spacing="8">
                                        <TextBlock Text="Current log file"
                                                   FontSize="18"
                                                   FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding LogFilePath}"
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   TextWrapping="Wrap" />
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <Button Content="Open Log File"
                                                    Command="{Binding OpenLogFileCommand}" />
                                            <Button Classes="ghost"
                                                    Content="Back to Apps"
                                                    Command="{Binding NavigateAppsCommand}" />
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <Border Classes="card"
                                        IsVisible="{Binding IsDeveloperModeEnabled}">
                                    <StackPanel Spacing="6">
                                        <TextBlock Text="Latest status"
                                                   FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding StatusText}"
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>

                        <Border IsVisible="{Binding IsSettingsPanelOpen}"
                                Classes="card"
                                Width="360"
                                MaxHeight="640"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top"
                                Margin="0,8,8,0"
                                Padding="14"
                                Background="#17233B"
                                BorderBrush="#355181">
                            <Grid RowDefinitions="Auto,*" RowSpacing="12">
                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                                    <StackPanel Spacing="2">
                                        <TextBlock Text="Settings"
                                                   FontSize="20"
                                                   FontWeight="SemiBold" />
                                        <TextBlock Text="Persistent app behavior, downloads, and advanced options."
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                    <Button Grid.Column="1"
                                            Classes="icon ghost"
                                            Width="34"
                                            Height="34"
                                            Content="X"
                                            Command="{Binding ToggleSettingsPanelCommand}" />
                                </Grid>

                                <ScrollViewer Grid.Row="1"
                                              VerticalScrollBarVisibility="Auto"
                                              HorizontalScrollBarVisibility="Disabled">
                                    <StackPanel Spacing="14">
                                        <StackPanel Spacing="8">
                                            <TextBlock Text="Installation"
                                                       FontSize="16"
                                                       FontWeight="SemiBold" />

                                            <StackPanel Spacing="2">
                                                <CheckBox IsChecked="{Binding Settings.SilentInstall}"
                                                          Content="Silent installation" />
                                                <TextBlock Text="Install apps without showing installer windows when possible."
                                                           FontSize="12"
                                                           Foreground="{StaticResource TextMutedBrush}"
                                                           TextWrapping="Wrap" />
                                            </StackPanel>

                                            <StackPanel Spacing="2">
                                                <CheckBox IsChecked="{Binding Settings.ParallelInstall}"
                                                          Content="Install apps simultaneously" />
                                                <TextBlock Text="Install multiple apps at the same time to speed up setup."
                                                           FontSize="12"
                                                           Foreground="{StaticResource TextMutedBrush}"
                                                           TextWrapping="Wrap" />
                                            </StackPanel>

                                            <StackPanel Spacing="2">
                                                <CheckBox IsChecked="{Binding Settings.SelfDeleteAfterInstall}"
                                                          Content="Self-delete after install" />
                                                <TextBlock Text="Remove NovaSetup after installation finishes."
                                                           FontSize="12"
                                                           Foreground="{StaticResource TextMutedBrush}"
                                                           TextWrapping="Wrap" />
                                            </StackPanel>

                                            <StackPanel Spacing="4">
                                                <TextBlock Text="Restart computer if required" />
                                                <ComboBox ItemsSource="{Binding RestartBehaviorOptions}"
                                                          SelectedItem="{Binding SelectedRestartBehaviorOption}">
                                                    <ComboBox.ItemTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding Label}" />
                                                        </DataTemplate>
                                                    </ComboBox.ItemTemplate>
                                                </ComboBox>
                                                <TextBlock Text="Choose what NovaSetup should do if installed apps require a restart."
                                                           FontSize="12"
                                                           Foreground="{StaticResource TextMutedBrush}"
                                                           TextWrapping="Wrap" />
                                            </StackPanel>
                                        </StackPanel>

                                        <StackPanel Spacing="8">
                                            <TextBlock Text="App List"
                                                       FontSize="16"
                                                       FontWeight="SemiBold" />

                                            <StackPanel Spacing="2">
                                                <CheckBox IsChecked="{Binding Settings.OsSupportedApps}"
                                                          Content="OS supported apps" />
                                                <TextBlock Text="When enabled, only apps supported on this operating system will be shown."
                                                           FontSize="12"
                                                           Foreground="{StaticResource TextMutedBrush}"
                                                           TextWrapping="Wrap" />
                                            </StackPanel>

                                            <StackPanel Spacing="2">
                                                <CheckBox IsChecked="{Binding Settings.ShowAlreadyInstalledApps}"
                                                          Content="Show already installed apps" />
                                                <TextBlock Text="Show apps already installed on this computer."
                                                           FontSize="12"
                                                           Foreground="{StaticResource TextMutedBrush}"
                                                           TextWrapping="Wrap" />
                                            </StackPanel>

                                            <StackPanel Spacing="2">
                                                <CheckBox IsChecked="{Binding Settings.AutoDetectInstalledAppsOnStartup}"
                                                          Content="Scan PC for installed apps on startup" />
                                                <TextBlock Text="Automatically detect installed apps when NovaSetup starts."
                                                           FontSize="12"
                                                           Foreground="{StaticResource TextMutedBrush}"
                                                           TextWrapping="Wrap" />
                                            </StackPanel>
                                        </StackPanel>

                                        <StackPanel Spacing="8">
                                            <TextBlock Text="Downloads"
                                                       FontSize="16"
                                                       FontWeight="SemiBold" />

                                            <StackPanel Spacing="4">
                                                <TextBlock Text="Download location" />
                                                <ComboBox ItemsSource="{Binding DownloadLocationOptions}"
                                                          SelectedItem="{Binding SelectedDownloadLocationOption}">
                                                    <ComboBox.ItemTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding Label}" />
                                                        </DataTemplate>
                                                    </ComboBox.ItemTemplate>
                                                </ComboBox>
                                                <TextBlock Text="Choose where installers are downloaded before installation."
                                                           FontSize="12"
                                                           Foreground="{StaticResource TextMutedBrush}"
                                                           TextWrapping="Wrap" />
                                            </StackPanel>

                                            <StackPanel Spacing="4"
                                                        IsVisible="{Binding IsCustomDownloadFolderVisible}">
                                                <TextBlock Text="Custom download folder" />
                                                <TextBox Watermark="Used only for Custom folder mode"
                                                         Text="{Binding Settings.CustomDownloadFolder}" />
                                                <TextBlock Text="Used only when Download location is set to Custom folder."
                                                           FontSize="12"
                                                           Foreground="{StaticResource TextMutedBrush}"
                                                           TextWrapping="Wrap" />
                                            </StackPanel>

                                            <StackPanel Spacing="2">
                                                <CheckBox IsChecked="{Binding Settings.KeepInstallersAfterInstall}"
                                                          Content="Keep installers after install" />
                                                <TextBlock Text="Keep downloaded installers after installation finishes."
                                                           FontSize="12"
                                                           Foreground="{StaticResource TextMutedBrush}"
                                                           TextWrapping="Wrap" />
                                            </StackPanel>
                                        </StackPanel>

                                        <StackPanel Spacing="8">
                                            <TextBlock Text="System"
                                                       FontSize="16"
                                                       FontWeight="SemiBold" />

                                            <StackPanel Spacing="2">
                                                <CheckBox IsChecked="{Binding Settings.LaunchNovaAtStartup}"
                                                          Content="Launch Nova at startup" />
                                                <TextBlock Text="Open NovaSetup automatically when the system starts."
                                                           FontSize="12"
                                                           Foreground="{StaticResource TextMutedBrush}"
                                                           TextWrapping="Wrap" />
                                            </StackPanel>

                                            <StackPanel Spacing="4">
                                                <TextBlock Text="Theme" />
                                                <ComboBox ItemsSource="{Binding ThemeOptions}"
                                                          SelectedItem="{Binding SelectedThemeOption}">
                                                    <ComboBox.ItemTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding Label}" />
                                                        </DataTemplate>
                                                    </ComboBox.ItemTemplate>
                                                </ComboBox>
                                                <TextBlock Text="Choose the appearance theme for NovaSetup."
                                                           FontSize="12"
                                                           Foreground="{StaticResource TextMutedBrush}"
                                                           TextWrapping="Wrap" />
                                            </StackPanel>

                                            <StackPanel Spacing="4">
                                                <TextBlock Text="Language" />
                                                <ComboBox ItemsSource="{Binding LanguageOptions}"
                                                          SelectedItem="{Binding SelectedLanguageOption}">
                                                    <ComboBox.ItemTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding Label}" />
                                                        </DataTemplate>
                                                    </ComboBox.ItemTemplate>
                                                </ComboBox>
                                                <TextBlock Text="Choose the display language for NovaSetup."
                                                           FontSize="12"
                                                           Foreground="{StaticResource TextMutedBrush}"
                                                           TextWrapping="Wrap" />
                                            </StackPanel>
                                        </StackPanel>

                                        <StackPanel Spacing="8">
                                            <TextBlock Text="Data"
                                                       FontSize="16"
                                                       FontWeight="SemiBold" />
                                            <StackPanel Spacing="2">
                                                <CheckBox IsChecked="{Binding Settings.SaveProfilesAutomatically}"
                                                          Content="Save profiles automatically" />
                                                <TextBlock Text="Automatically save changes to your NovaSetup lists and profiles."
                                                           FontSize="12"
                                                           Foreground="{StaticResource TextMutedBrush}"
                                                           TextWrapping="Wrap" />
                                            </StackPanel>
                                        </StackPanel>

                                        <StackPanel Spacing="8">
                                            <TextBlock Text="Advanced"
                                                       FontSize="16"
                                                       FontWeight="SemiBold" />
                                            <StackPanel Spacing="2">
                                                <CheckBox IsChecked="{Binding Settings.DeveloperMode}"
                                                          Content="Developer mode" />
                                                <TextBlock Text="Show install logs and extra debug information."
                                                           FontSize="12"
                                                           Foreground="{StaticResource TextMutedBrush}"
                                                           TextWrapping="Wrap" />
                                            </StackPanel>

                                            <StackPanel Spacing="4">
                                                <Button Content="Reset Nova settings"
                                                        Command="{Binding ResetSettingsCommand}" />
                                                <TextBlock Text="Restore all NovaSetup settings to their default values."
                                                           FontSize="12"
                                                           Foreground="{StaticResource TextMutedBrush}"
                                                           TextWrapping="Wrap" />
                                            </StackPanel>
                                        </StackPanel>
                                    </StackPanel>
                                </ScrollViewer>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>
