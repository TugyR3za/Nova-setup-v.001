<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        d:DesignWidth="1500"
        d:DesignHeight="980"
        x:Class="NovaSetup.Views.MainWindow"
        x:CompileBindings="False"
        Title="NovaSetup"
        Icon="avares://NovaSetup/Assets/nova_logo.ico"
        RequestedThemeVariant="Dark"
        Background="#050915"
        Foreground="#E6EBFF"
        MinWidth="1120"
        MinHeight="720">
    <Window.Resources>
        <SolidColorBrush x:Key="ShellBorderBrush" Color="#1A2742" />
        <SolidColorBrush x:Key="TopBarBrush" Color="#0C1121" />
        <SolidColorBrush x:Key="SidebarBrush" Color="#111827" />
        <SolidColorBrush x:Key="PanelBrush" Color="#101A2E" />
        <SolidColorBrush x:Key="CardBrush" Color="#141F36" />
        <SolidColorBrush x:Key="CardBorderBrush" Color="#253757" />
        <SolidColorBrush x:Key="InputBrush" Color="#1A243A" />
        <SolidColorBrush x:Key="InputBorderBrush" Color="#2D3E62" />
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#EEF3FF" />
        <SolidColorBrush x:Key="TextMutedBrush" Color="#A3B2D3" />
        <SolidColorBrush x:Key="AccentBrush" Color="#3E7BFF" />
        <SolidColorBrush x:Key="AccentSoftBrush" Color="#233C7A" />
        <SolidColorBrush x:Key="SuccessBrush" Color="#1DBF8B" />
        <SolidColorBrush x:Key="WarningBrush" Color="#F59E0B" />
        <SolidColorBrush x:Key="DangerBrush" Color="#F87171" />
    </Window.Resources>

    <Window.Styles>
        <Style Selector="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="FontFamily" Value="Segoe UI Variable Text, Segoe UI, Inter, Arial" />
        </Style>

        <Style Selector="Border.shellPanel">
            <Setter Property="BorderBrush" Value="{StaticResource ShellBorderBrush}" />
            <Setter Property="BorderThickness" Value="1.2" />
            <Setter Property="CornerRadius" Value="26" />
        </Style>

        <Style Selector="Border.card">
            <Setter Property="Background" Value="{StaticResource CardBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Padding" Value="12" />
        </Style>

        <Style Selector="Border.rowCard">
            <Setter Property="Background" Value="#10192E" />
            <Setter Property="BorderBrush" Value="#263A5C" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="8" />
            <Setter Property="Margin" Value="0,0,0,6" />
        </Style>

        <Style Selector="TextBox">
            <Setter Property="Background" Value="{StaticResource InputBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource InputBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="CornerRadius" Value="11" />
            <Setter Property="Padding" Value="10,8" />
        </Style>

        <Style Selector="Button">
            <Setter Property="Background" Value="#1B2740" />
            <Setter Property="BorderBrush" Value="#314468" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="10,7" />
        </Style>

        <Style Selector="Button.primary">
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderBrush" Value="#72A0FF" />
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="18,9" />
            <Setter Property="FontSize" Value="15" />
        </Style>

        <Style Selector="Button.ghost">
            <Setter Property="Background" Value="#1C253A" />
            <Setter Property="BorderBrush" Value="#2C3C5F" />
        </Style>

        <Style Selector="Button.icon">
            <Setter Property="Width" Value="40" />
            <Setter Property="Height" Value="40" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="FontSize" Value="15" />
        </Style>

        <Style Selector="Button.link">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Foreground" Value="#95BEFF" />
            <Setter Property="HorizontalAlignment" Value="Left" />
        </Style>

        <Style Selector="Button.nav">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="12,9" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="FontSize" Value="16" />
        </Style>

        <Style Selector="Button.navActive">
            <Setter Property="Background" Value="{StaticResource AccentSoftBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderThickness" Value="1.2" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style Selector="RadioButton.pill">
            <Setter Property="Background" Value="#1A243A" />
            <Setter Property="BorderBrush" Value="#2F4063" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
            <Setter Property="CornerRadius" Value="999" />
            <Setter Property="Padding" Value="14,6" />
            <Setter Property="FontSize" Value="14" />
        </Style>

        <Style Selector="RadioButton.pill:checked">
            <Setter Property="Background" Value="#204C93" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
            <Setter Property="Foreground" Value="#EAF1FF" />
        </Style>

        <Style Selector="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="FontSize" Value="14" />
        </Style>

        <Style Selector="CheckBox.appCheck">
            <Setter Property="Width" Value="22" />
            <Setter Property="Height" Value="22" />
            <Setter Property="Background" Value="#0E162A" />
            <Setter Property="BorderBrush" Value="#36507D" />
            <Setter Property="BorderThickness" Value="1.4" />
        </Style>
    </Window.Styles>

    <Border Margin="14"
            Classes="shellPanel"
            Padding="12">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#0A1020" Offset="0" />
                <GradientStop Color="#070D1A" Offset="1" />
            </LinearGradientBrush>
        </Border.Background>

        <Grid RowDefinitions="Auto,*" RowSpacing="14">
            <Border Grid.Row="0"
                    Classes="shellPanel"
                    CornerRadius="20"
                    Padding="12"
                    Background="{StaticResource TopBarBrush}">
                <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto" ColumnSpacing="14">
                    <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                        <Border Width="38" Height="38" CornerRadius="19" Background="#10203F">
                            <TextBlock Text="*"
                                       FontSize="24"
                                       Foreground="{StaticResource AccentBrush}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Border>
                        <TextBlock Text="Nova" FontSize="26" FontWeight="Bold" VerticalAlignment="Center" />
                        <TextBlock Text="Setup everything fast"
                                   FontSize="14"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   VerticalAlignment="Center" />
                    </StackPanel>

                    <Border Grid.Column="2"
                            Background="#131F35"
                            BorderBrush="#294067"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="10,6"
                            VerticalAlignment="Center">
                        <TextBlock Text="{Binding CurrentPlatform, StringFormat='OS: {0}'}"
                                   Foreground="{StaticResource TextMutedBrush}" />
                    </Border>

                    <Button Grid.Column="3"
                            Classes="icon ghost"
                            Content="S"
                            Command="{Binding ToggleSettingsPanelCommand}" />
                    <Button Grid.Column="4" Classes="icon ghost" Content="?"/>
                </Grid>
            </Border>

            <Grid Grid.Row="1" ColumnDefinitions="200,*" ColumnSpacing="12">
                <Border Grid.Column="0"
                        Classes="shellPanel"
                        CornerRadius="18"
                        Background="{StaticResource SidebarBrush}"
                        Padding="8">
                    <Grid RowDefinitions="*,Auto">
                        <StackPanel Spacing="8">
                            <Button Classes="nav" Content="Dashboard" />

                            <Button Classes="nav navActive"
                                    IsVisible="{Binding IsSelectionPhase}"
                                    Content="Apps" />
                            <Button Classes="nav"
                                    IsVisible="{Binding IsSummaryScreenVisible}"
                                    Content="Apps" />

                            <Button Classes="nav" Content="Drivers" />
                            <Button Classes="nav" Content="My Lists" />

                            <Button Classes="nav navActive"
                                    IsVisible="{Binding IsSummaryScreenVisible}"
                                    Content="History" />
                            <Button Classes="nav"
                                    IsVisible="{Binding IsSelectionPhase}"
                                    Content="History" />

                            <Button Classes="nav" Content="Logs" Command="{Binding OpenLogFileCommand}" />
                        </StackPanel>

                        <Border Grid.Row="1"
                                Classes="card"
                                Padding="12"
                                Background="#111A2C">
                            <StackPanel Spacing="8">
                                <TextBlock Text="Current profile"
                                           FontWeight="SemiBold" />
                                <TextBlock Text="{Binding Settings.ProfileName}"
                                           Foreground="{StaticResource TextMutedBrush}" />
                                <TextBlock Text="{Binding SelectedCount, StringFormat='Selected: {0} app(s)'}"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           FontSize="12" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <Border Grid.Column="1"
                        Classes="shellPanel"
                        CornerRadius="18"
                        Background="{StaticResource PanelBrush}"
                        Padding="12">
                    <Grid>
                        <Grid IsVisible="{Binding IsHomeScreenVisible}"
                              RowDefinitions="Auto,Auto,*"
                              RowSpacing="10">
                            <Border Grid.Row="0" Classes="card" Padding="14">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="Choose what to install"
                                               FontSize="30"
                                               FontWeight="Bold"
                                               TextWrapping="Wrap" />
                                    <TextBlock Text="Pick apps, drivers, and packs, then press Install"
                                               FontSize="15"
                                               Foreground="{StaticResource TextMutedBrush}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>

                            <Grid Grid.Row="1" ColumnDefinitions="1*,1*" ColumnSpacing="8">
                                <Border Grid.Column="0" Classes="card" Padding="12">
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="Quick Packs" FontSize="16" FontWeight="SemiBold" />
                                        <TextBlock Text="Starter preset includes browser, chat, and dev essentials."
                                                   Foreground="{StaticResource TextMutedBrush}" />
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="1" Classes="card" Padding="12">
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="System Check" FontSize="16" FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding CurrentPlatform, StringFormat='Detected platform: {0}'}"
                                                   Foreground="{StaticResource TextMutedBrush}" />
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <Border Grid.Row="2" Classes="card">
                                <Grid RowDefinitions="Auto,Auto,*,Auto" RowSpacing="10">
                                    <WrapPanel Orientation="Horizontal">
                                        <TextBox Width="260"
                                                 Margin="0,0,10,10"
                                                 Watermark="Quick pack..."
                                                 Text="{Binding SearchText}" />

                                        <RadioButton GroupName="filter"
                                                     Classes="pill"
                                                     Margin="0,0,10,10"
                                                     IsChecked="{Binding IsAllFilter}"
                                                     Content="All" />
                                        <RadioButton GroupName="filter"
                                                     Classes="pill"
                                                     Margin="0,0,10,10"
                                                     IsChecked="{Binding IsGamesFilter}"
                                                     Content="Games" />
                                        <RadioButton GroupName="filter"
                                                     Classes="pill"
                                                     Margin="0,0,10,10"
                                                     IsChecked="{Binding IsDevToolsFilter}"
                                                     Content="Dev Tools" />
                                        <RadioButton GroupName="filter"
                                                     Classes="pill"
                                                     Margin="0,0,10,10"
                                                     IsChecked="{Binding IsUtilitiesFilter}"
                                                     Content="Utilities" />
                                    </WrapPanel>

                                    <TextBlock Grid.Row="1"
                                               Text="{Binding VisibleAppCount, StringFormat='Visible apps: {0}'}"
                                               Foreground="{StaticResource TextMutedBrush}" />

                                    <Grid Grid.Row="2" RowDefinitions="Auto,*,Auto" RowSpacing="8">
                                        <Grid ColumnDefinitions="40,*,76,96,64" Margin="2,0,2,0">
                                            <TextBlock Text="Sel" FontWeight="SemiBold" Foreground="{StaticResource TextMutedBrush}" />
                                            <TextBlock Grid.Column="1" Text="App" FontWeight="SemiBold" Foreground="{StaticResource TextMutedBrush}" />
                                            <TextBlock Grid.Column="2" Text="Size" FontWeight="SemiBold" Foreground="{StaticResource TextMutedBrush}" />
                                            <TextBlock Grid.Column="3" Text="Status" FontWeight="SemiBold" Foreground="{StaticResource TextMutedBrush}" />
                                            <TextBlock Grid.Column="4" Text="Details" FontWeight="SemiBold" Foreground="{StaticResource TextMutedBrush}" />
                                        </Grid>

                                        <ScrollViewer Grid.Row="1"
                                                      VerticalScrollBarVisibility="Auto"
                                                      HorizontalScrollBarVisibility="Disabled">
                                                <ItemsControl ItemsSource="{Binding VisibleApps}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border Classes="rowCard" Opacity="{Binding RowOpacity}">
                                                            <Grid ColumnDefinitions="40,*,76,96,64" ColumnSpacing="8">
                                                                <CheckBox Classes="appCheck"
                                                                          IsChecked="{Binding IsSelected}"
                                                                          IsEnabled="{Binding IsSupportedOnCurrentPlatform}"
                                                                          VerticalAlignment="Center"
                                                                          HorizontalAlignment="Center" />

                                                                <Grid Grid.Column="1" ColumnDefinitions="40,*" ColumnSpacing="10">
                                                                    <Border Width="34"
                                                                            Height="34"
                                                                            CornerRadius="17"
                                                                            Background="#223765"
                                                                            VerticalAlignment="Center">
                                                                        <TextBlock Text="{Binding IconGlyph}"
                                                                                   HorizontalAlignment="Center"
                                                                                   VerticalAlignment="Center"
                                                                                   FontWeight="Bold" />
                                                                    </Border>

                                                                    <StackPanel Grid.Column="1" Spacing="2">
                                                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                                                            <TextBlock Text="{Binding Name}" FontSize="16" FontWeight="SemiBold" />
                                                                            <Border IsVisible="{Binding IsRecommended}"
                                                                                    Background="#214A92"
                                                                                    BorderBrush="{StaticResource AccentBrush}"
                                                                                    BorderThickness="1"
                                                                                    CornerRadius="7"
                                                                                    Padding="8,2">
                                                                                <TextBlock Text="Recommended" FontSize="10" />
                                                                            </Border>
                                                                        </StackPanel>

                                                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                                                            <TextBlock Text="{Binding Category}"
                                                                                       Foreground="{StaticResource TextMutedBrush}"
                                                                                       FontSize="13" />
                                                                            <Button Classes="link"
                                                                                    Content="{Binding PublisherName}"
                                                                                    Command="{Binding $parent[Window].DataContext.OpenPublisherCommand}"
                                                                                    CommandParameter="{Binding .}" />
                                                                        </StackPanel>
                                                                    </StackPanel>
                                                                </Grid>

                                                                <TextBlock Grid.Column="2"
                                                                           Text="~ 20 MB"
                                                                           VerticalAlignment="Center"
                                                                           Foreground="{StaticResource TextMutedBrush}" />

                                                                <Border Grid.Column="3"
                                                                        Background="#162643"
                                                                        BorderBrush="#2C456B"
                                                                        BorderThickness="1"
                                                                        CornerRadius="8"
                                                                        Padding="10,4"
                                                                        VerticalAlignment="Center"
                                                                        HorizontalAlignment="Left">
                                                                    <TextBlock Text="{Binding StatusBadge}" />
                                                                </Border>

                                                                <Button Grid.Column="4"
                                                                        Classes="ghost"
                                                                        Content="..."
                                                                        Width="52"
                                                                        HorizontalAlignment="Left"
                                                                        Command="{Binding $parent[Window].DataContext.ShowAppDetailsCommand}"
                                                                        CommandParameter="{Binding .}" />
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </ScrollViewer>

                                        <Border Grid.Row="2"
                                                Background="#0F172A"
                                                BorderBrush="#273A5F"
                                                BorderThickness="1"
                                                CornerRadius="12"
                                                Padding="12">
                                            <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                                          VerticalScrollBarVisibility="Disabled">
                                                <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10">
                                                    <TextBlock Text="{Binding SelectedFooterText}"
                                                               Foreground="{StaticResource TextMutedBrush}"
                                                               VerticalAlignment="Center" />

                                                    <Button Grid.Column="1"
                                                            Classes="ghost"
                                                            Content="Save List"
                                                            Command="{Binding SaveListCommand}"
                                                            Padding="26,10" />
                                                    <Button Grid.Column="2"
                                                            Classes="primary"
                                                            Content="Install Selected"
                                                            Command="{Binding InstallCommand}" />
                                                </Grid>
                                            </ScrollViewer>
                                        </Border>
                                    </Grid>
                                </Grid>
                            </Border>
                        </Grid>

                        <ScrollViewer IsVisible="{Binding IsInstallScreenVisible}"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <StackPanel Spacing="12" Margin="0,0,6,0">
                            <Border Classes="card" Padding="18">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="Installing"
                                               FontSize="44"
                                               FontWeight="Bold" />
                                    <TextBlock Text="Using official sources, silent installers when available, and logging every step."
                                               FontSize="15"
                                               Foreground="{StaticResource TextMutedBrush}" />
                                </StackPanel>
                            </Border>

                            <Border Classes="card">
                                <StackPanel Spacing="10">
                                    <TextBlock Text="{Binding ProgressValue, StringFormat='Overall progress: {0:0}%'}"
                                               Foreground="{StaticResource TextMutedBrush}" />
                                    <ProgressBar Minimum="0"
                                                 Maximum="100"
                                                 Value="{Binding ProgressValue}"
                                                 Height="16"
                                                 Background="#1B2946"
                                                 Foreground="{StaticResource AccentBrush}" />
                                </StackPanel>
                            </Border>

                            <Grid ColumnDefinitions="2*,1*" ColumnSpacing="10">
                                <Border Grid.Column="0" Classes="card">
                                    <StackPanel Spacing="8">
                                        <TextBlock Text="Now installing" FontSize="18" FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding InstallStatusText}"
                                                   TextWrapping="Wrap"
                                                   Foreground="{StaticResource TextMutedBrush}" />
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="1" Classes="card">
                                    <StackPanel Spacing="8">
                                        <TextBlock Text="Actions" FontSize="18" FontWeight="SemiBold" />
                                        <Button Content="Pause"
                                                Command="{Binding PauseInstallCommand}" />
                                        <Button Content="Open Logs"
                                                Command="{Binding OpenLogFileCommand}" />
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <Border Classes="card">
                                <StackPanel Spacing="8">
                                    <TextBlock Text="Queue" FontSize="18" FontWeight="SemiBold" />
                                    <ItemsControl ItemsSource="{Binding InstallResults}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border BorderBrush="#294067"
                                                        BorderThickness="1"
                                                        CornerRadius="9"
                                                        Padding="10"
                                                        Margin="0,0,0,6">
                                                    <Grid ColumnDefinitions="2*,Auto,3*">
                                                        <TextBlock Text="{Binding AppName}" FontWeight="SemiBold" />
                                                        <TextBlock Grid.Column="1"
                                                                   Text="{Binding Skipped, StringFormat='Skipped: {0}'}"
                                                                   Foreground="{StaticResource TextMutedBrush}" />
                                                        <TextBlock Grid.Column="2"
                                                                   Text="{Binding Message}"
                                                                   Foreground="{StaticResource TextMutedBrush}"
                                                                   TextWrapping="Wrap" />
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>

                            <Grid ColumnDefinitions="Auto,Auto,*" ColumnSpacing="10">
                                <Button Grid.Column="0"
                                        Content="Open Log File"
                                        Command="{Binding OpenLogFileCommand}" />
                                <Button Grid.Column="1"
                                        Classes="ghost"
                                        Content="Finish and Summary (auto)"
                                        IsEnabled="False" />
                            </Grid>
                            </StackPanel>
                        </ScrollViewer>

                        <ScrollViewer IsVisible="{Binding IsSummaryScreenVisible}"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <StackPanel Spacing="12" Margin="0,0,6,0">
                            <Border Classes="card" Padding="18">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="Setup complete"
                                               FontSize="44"
                                               FontWeight="Bold" />
                                    <TextBlock Text="{Binding InstallSummaryText}"
                                               FontSize="16"
                                               Foreground="{StaticResource TextMutedBrush}" />
                                </StackPanel>
                            </Border>

                            <Grid ColumnDefinitions="1.6*,1*" ColumnSpacing="10">
                                <Border Grid.Column="0" Classes="card">
                                    <StackPanel Spacing="10">
                                        <TextBlock Text="Installed summary" FontSize="18" FontWeight="SemiBold" />
                                        <Grid ColumnDefinitions="1*,1*,1*,1*" ColumnSpacing="8">
                                            <Border Background="#0F2B24" CornerRadius="10" Padding="10">
                                                <TextBlock Text="{Binding InstalledResults.Count, StringFormat='Installed {0}'}"
                                                           Foreground="{StaticResource SuccessBrush}" />
                                            </Border>
                                            <Border Grid.Column="1" Background="#2B1B1B" CornerRadius="10" Padding="10">
                                                <TextBlock Text="{Binding FailedResults.Count, StringFormat='Failed {0}'}"
                                                           Foreground="{StaticResource DangerBrush}" />
                                            </Border>
                                            <Border Grid.Column="2" Background="#2B2416" CornerRadius="10" Padding="10">
                                                <TextBlock Text="{Binding SkippedResults.Count, StringFormat='Skipped {0}'}"
                                                           Foreground="{StaticResource WarningBrush}" />
                                            </Border>
                                            <Border Grid.Column="3" Background="#192742" CornerRadius="10" Padding="10">
                                                <TextBlock Text="{Binding RestartRequiredResults.Count, StringFormat='Restart {0}'}"
                                                           Foreground="{StaticResource AccentBrush}" />
                                            </Border>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="1" Classes="card">
                                    <StackPanel Spacing="8">
                                        <TextBlock Text="Next steps" FontSize="18" FontWeight="SemiBold" />
                                        <TextBlock Text="- Launch installed apps and sign in if needed."
                                                   Foreground="{StaticResource TextMutedBrush}" />
                                        <TextBlock Text="- Check drivers if hardware tools were installed."
                                                   Foreground="{StaticResource TextMutedBrush}" />
                                        <TextBlock Text="- Keep this profile as your default setup list."
                                                   Foreground="{StaticResource TextMutedBrush}" />
                                        <TextBlock Text="{Binding Settings.SelfDeleteEnabled, StringFormat='Self-delete setting: {0}'}"
                                                   Foreground="{StaticResource TextMutedBrush}" />
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <Border Classes="card"
                                    IsVisible="{Binding IsRestartSectionVisible}"
                                    Background="#2A1F13"
                                    BorderBrush="#684B1E">
                                <StackPanel Spacing="8">
                                    <TextBlock Text="Restart Recommended"
                                               FontSize="18"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource WarningBrush}" />
                                    <TextBlock Text="{Binding RestartStatusText}"
                                               Foreground="#FCD9A5"
                                               TextWrapping="Wrap" />

                                    <StackPanel Orientation="Horizontal"
                                                Spacing="8"
                                                IsVisible="{Binding ShowPrimaryRestartActions}">
                                        <Button Classes="primary"
                                                Content="Restart Now"
                                                Command="{Binding RequestRestartNowCommand}" />
                                        <Button Content="Skip / Restart Later"
                                                Command="{Binding RestartLaterCommand}" />
                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal"
                                                Spacing="8"
                                                IsVisible="{Binding IsRestartConfirmationVisible}">
                                        <Button Classes="primary"
                                                Content="Confirm Restart"
                                                Command="{Binding ConfirmRestartNowCommand}" />
                                        <Button Content="Cancel"
                                                Command="{Binding CancelRestartCommand}" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <Grid ColumnDefinitions="Auto,Auto,Auto,*" ColumnSpacing="10">
                                <Button Grid.Column="0"
                                        Content="Save Default List"
                                        Command="{Binding SaveListCommand}" />
                                <Button Grid.Column="1"
                                        Content="Export Report (PDF)"
                                        Command="{Binding ExportReportCommand}" />
                                <Button Grid.Column="2"
                                        Content="Open Log File"
                                        Command="{Binding OpenLogFileCommand}" />
                            </Grid>

                            <Border Classes="card" IsVisible="{Binding HasInstalledResults}">
                                <StackPanel Spacing="6">
                                    <TextBlock Text="{Binding InstalledResults.Count, StringFormat='Installed Apps ({0})'}"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource SuccessBrush}" />
                                    <ItemsControl ItemsSource="{Binding InstalledResults}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding AppName}" />
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>

                            <Border Classes="card" IsVisible="{Binding HasFailedResults}">
                                <StackPanel Spacing="6">
                                    <TextBlock Text="{Binding FailedResults.Count, StringFormat='Failed Apps ({0})'}"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource DangerBrush}" />
                                    <ItemsControl ItemsSource="{Binding FailedResults}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding AppName, StringFormat='- {0}'}" />
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>

                            <Border Classes="card" IsVisible="{Binding HasSkippedResults}">
                                <StackPanel Spacing="6">
                                    <TextBlock Text="{Binding SkippedResults.Count, StringFormat='Skipped Apps ({0})'}"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource WarningBrush}" />
                                    <ItemsControl ItemsSource="{Binding SkippedResults}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding AppName, StringFormat='- {0}'}" />
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>

                            <Border Classes="card" IsVisible="{Binding HasRestartRequiredResults}">
                                <StackPanel Spacing="6">
                                    <TextBlock Text="{Binding RestartRequiredResults.Count, StringFormat='Apps Requiring Restart ({0})'}"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource AccentBrush}" />
                                    <ItemsControl ItemsSource="{Binding RestartRequiredResults}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding AppName, StringFormat='- {0}'}" />
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                            </StackPanel>
                        </ScrollViewer>

                        <Border IsVisible="{Binding IsSettingsPanelOpen}"
                                Classes="card"
                                Width="320"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top"
                                Margin="0,8,8,0"
                                Padding="16"
                                Background="#17233B"
                                BorderBrush="#355181">
                            <StackPanel Spacing="12">
                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                                    <StackPanel Spacing="2">
                                        <TextBlock Text="Settings"
                                                   FontSize="20"
                                                   FontWeight="SemiBold" />
                                        <TextBlock Text="Installation behavior and list visibility."
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                    <Button Grid.Column="1"
                                            Classes="icon ghost"
                                            Width="34"
                                            Height="34"
                                            Content="X"
                                            Command="{Binding ToggleSettingsPanelCommand}" />
                                </Grid>

                                <CheckBox IsChecked="{Binding Settings.SilentInstallEnabled}"
                                          Content="Silent install" />
                                <CheckBox IsChecked="{Binding Settings.ShowUnsupportedApps}"
                                          Content="Show unsupported apps" />
                                <CheckBox IsChecked="{Binding Settings.SelfDeleteEnabled}"
                                          Content="Self-delete after install" />

                                <StackPanel Spacing="6">
                                    <TextBlock Text="Default install location"
                                               Foreground="{StaticResource TextMutedBrush}" />
                                    <TextBox Watermark="System default"
                                             Text="{Binding Settings.DefaultInstallLocation}" />
                                </StackPanel>

                                <StackPanel Spacing="6">
                                    <TextBlock Text="Profile name"
                                               Foreground="{StaticResource TextMutedBrush}" />
                                    <TextBox Watermark="Website Starter"
                                             Text="{Binding Settings.ProfileName}" />
                                </StackPanel>

                                <Button Content="Save current list"
                                        Command="{Binding SaveListCommand}" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>
