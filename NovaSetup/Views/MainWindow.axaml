<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        d:DesignWidth="1100"
        d:DesignHeight="760"
        x:Class="NovaSetup.Views.MainWindow"
        x:CompileBindings="False"
        Title="NovaSetup"
        Background="#F4F7FB"
        MinWidth="940"
        MinHeight="640">
    <Window.Resources>
        <SolidColorBrush x:Key="PanelBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="BorderBrush" Color="#D7E1ED" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="#5D6F86" />
        <SolidColorBrush x:Key="SelectedBadgeBrush" Color="#DCFCE7" />
        <SolidColorBrush x:Key="WarningBadgeBrush" Color="#FEE2E2" />
        <SolidColorBrush x:Key="PlatformBadgeBrush" Color="#EEF3FB" />
        <SolidColorBrush x:Key="SuccessTextBrush" Color="#166534" />
        <SolidColorBrush x:Key="WarnTextBrush" Color="#9A3412" />
        <SolidColorBrush x:Key="ErrorTextBrush" Color="#991B1B" />
        <SolidColorBrush x:Key="InfoPanelBrush" Color="#F8FAFC" />
        <SolidColorBrush x:Key="RecommendedBadgeBrush" Color="#DBEAFE" />
        <SolidColorBrush x:Key="RecommendedTextBrush" Color="#1D4ED8" />
    </Window.Resources>

    <Window.Styles>
        <Style Selector="Border.rowCard">
            <Setter Property="Background" Value="{StaticResource PanelBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="10" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="Auto,*,Auto" Margin="14">
        <Border Grid.Row="0"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="10"
                Padding="14"
                Margin="0,0,0,10">
            <StackPanel Spacing="10">
                <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto" ColumnSpacing="12">
                    <TextBlock Text="NovaSetup"
                               FontSize="22"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center" />
                    <TextBlock Grid.Column="2"
                               Text="{Binding CurrentPlatform, StringFormat='Current OS: {0}'}"
                               Foreground="{StaticResource MutedTextBrush}"
                               VerticalAlignment="Center" />
                    <TextBlock Grid.Column="3"
                               Text="{Binding SelectedCount, StringFormat='Selected: {0}'}"
                               VerticalAlignment="Center"
                               FontWeight="SemiBold" />
                    <Button Grid.Column="4"
                            Command="{Binding InstallCommand}"
                            Content="Install Selected"
                            Padding="14,8" />
                </Grid>

                <Border Background="{StaticResource InfoPanelBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="10">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Settings"
                                   FontWeight="SemiBold" />
                        <Grid ColumnDefinitions="Auto,Auto,Auto,2*" ColumnSpacing="14">
                            <CheckBox Grid.Column="0"
                                      IsChecked="{Binding Settings.SilentInstallEnabled}"
                                      Content="Silent install" />
                            <CheckBox Grid.Column="1"
                                      IsChecked="{Binding Settings.SelfDeleteEnabled}"
                                      Content="Self-delete (placeholder)" />
                            <CheckBox Grid.Column="2"
                                      IsChecked="{Binding Settings.ShowUnsupportedApps}"
                                      Content="Show unsupported apps" />
                            <TextBox Grid.Column="3"
                                     Watermark="Default install location (optional)"
                                     Text="{Binding Settings.DefaultInstallLocation}" />
                        </Grid>
                        <Grid ColumnDefinitions="220,*" ColumnSpacing="10">
                            <TextBox Grid.Column="0"
                                     Watermark="Profile name (placeholder)"
                                     Text="{Binding Settings.ProfileName}" />
                            <TextBlock Grid.Column="1"
                                       Text="Silent install is ON by default when supported. Self-delete stays a safe placeholder and does not remove files yet."
                                       TextWrapping="Wrap"
                                       Foreground="{StaticResource MutedTextBrush}" />
                        </Grid>
                        <TextBlock Text="When 'Show unsupported apps' is OFF, selected unsupported apps still remain visible so you can review skipped items."
                                   TextWrapping="Wrap"
                                   FontSize="11"
                                   Foreground="{StaticResource MutedTextBrush}" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>
        
        <Border Grid.Row="1"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="10"
                Padding="12"
                Margin="0,0,0,10">
            <Grid RowDefinitions="Auto,*">
                <Grid Grid.Row="0" ColumnDefinitions="48,2*,1.3*,1.3*,1.3*" Margin="0,0,0,8">
                    <TextBlock Text="Sel" FontWeight="SemiBold" VerticalAlignment="Center" />
                    <TextBlock Grid.Column="1" Text="App" FontWeight="SemiBold" VerticalAlignment="Center" />
                    <TextBlock Grid.Column="2" Text="Publisher" FontWeight="SemiBold" VerticalAlignment="Center" />
                    <TextBlock Grid.Column="3" Text="Platforms" FontWeight="SemiBold" VerticalAlignment="Center" />
                    <TextBlock Grid.Column="4" Text="State" FontWeight="SemiBold" VerticalAlignment="Center" />
                </Grid>

                <ScrollViewer Grid.Row="1">
                    <ItemsControl ItemsSource="{Binding VisibleApps}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Classes="rowCard" Opacity="{Binding RowOpacity}">
                                    <Grid ColumnDefinitions="48,2*,1.3*,1.3*,1.3*" ColumnSpacing="8">
                                        <CheckBox IsChecked="{Binding IsSelected}"
                                                  IsEnabled="{Binding IsSupportedOnCurrentPlatform}"
                                                  VerticalAlignment="Center"
                                                  HorizontalAlignment="Center" />

                                        <StackPanel Grid.Column="1" Spacing="2">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                                                <Border IsVisible="{Binding IsRecommended}"
                                                        Background="{StaticResource RecommendedBadgeBrush}"
                                                        CornerRadius="8"
                                                        Padding="8,2"
                                                        VerticalAlignment="Center">
                                                    <TextBlock Text="Recommended"
                                                               FontSize="10"
                                                               FontWeight="SemiBold"
                                                               Foreground="{StaticResource RecommendedTextBrush}" />
                                                </Border>
                                            </StackPanel>
                                            <TextBlock Text="{Binding Description}"
                                                       FontSize="11"
                                                       Foreground="{StaticResource MutedTextBrush}" />
                                            <TextBlock Text="{Binding RecommendationReason}"
                                                       IsVisible="{Binding IsRecommended}"
                                                       TextWrapping="Wrap"
                                                       FontSize="11"
                                                       Foreground="{StaticResource RecommendedTextBrush}" />
                                        </StackPanel>

                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding PublisherName}"
                                                   VerticalAlignment="Center" />

                                        <StackPanel Grid.Column="3"
                                                    Orientation="Horizontal"
                                                    Spacing="6"
                                                    VerticalAlignment="Center">
                                            <Border IsVisible="{Binding SupportedPlatforms.Windows}"
                                                    Background="{StaticResource PlatformBadgeBrush}"
                                                    CornerRadius="8"
                                                    Padding="8,3">
                                                <TextBlock Text="Windows" FontSize="11" />
                                            </Border>
                                            <Border IsVisible="{Binding SupportedPlatforms.Linux}"
                                                    Background="{StaticResource PlatformBadgeBrush}"
                                                    CornerRadius="8"
                                                    Padding="8,3">
                                                <TextBlock Text="Linux" FontSize="11" />
                                            </Border>
                                        </StackPanel>

                                        <StackPanel Grid.Column="4"
                                                    Orientation="Horizontal"
                                                    Spacing="6"
                                                    VerticalAlignment="Center">
                                            <Border IsVisible="{Binding IsSelected}"
                                                    Background="{StaticResource SelectedBadgeBrush}"
                                                    CornerRadius="8"
                                                    Padding="8,3">
                                                <TextBlock Text="Selected" FontSize="11" />
                                            </Border>
                                            <Border Background="{StaticResource WarningBadgeBrush}"
                                                    CornerRadius="8"
                                                    Padding="8,3">
                                                <TextBlock Text="{Binding StatusBadge}" FontSize="11" />
                                            </Border>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="10"
                Padding="10">
            <StackPanel Spacing="8">
                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                    <TextBlock Text="Install Status:"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center" />
                    <TextBlock Grid.Column="1"
                               Text="{Binding InstallStatusText}"
                               VerticalAlignment="Center" />
                </Grid>

                <TextBlock Text="Installation is running..."
                           IsVisible="{Binding IsInstalling}"
                           Foreground="{StaticResource WarnTextBrush}"
                           FontWeight="SemiBold" />

                <ProgressBar Minimum="0"
                             Maximum="100"
                             Value="{Binding ProgressValue}"
                             Height="10" />

                <TextBlock Text="{Binding ProgressValue, StringFormat='Progress: {0:0}%'}"
                           Foreground="{StaticResource MutedTextBrush}" />

                <TextBlock Text="{Binding InstallSummaryText}"
                           FontWeight="SemiBold"
                           IsVisible="{Binding HasInstallResults}"
                           Foreground="{StaticResource SuccessTextBrush}" />

                <Border IsVisible="{Binding IsRestartSectionVisible}"
                        Background="#FFF7ED"
                        BorderBrush="#FED7AA"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="10">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Restart Recommended"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource WarnTextBrush}" />
                        <TextBlock Text="Some apps or drivers may not work correctly until the PC is restarted."
                                   TextWrapping="Wrap"
                                   Foreground="{StaticResource WarnTextBrush}" />
                        <TextBlock Text="{Binding RestartStatusText}"
                                   TextWrapping="Wrap" />

                        <StackPanel Orientation="Horizontal"
                                    Spacing="8"
                                    IsVisible="{Binding ShowPrimaryRestartActions}">
                            <Button Content="Restart Now"
                                    Command="{Binding RequestRestartNowCommand}" />
                            <Button Content="Skip / Restart Later"
                                    Command="{Binding RestartLaterCommand}" />
                        </StackPanel>

                        <StackPanel Orientation="Horizontal"
                                    Spacing="8"
                                    IsVisible="{Binding IsRestartConfirmationVisible}">
                            <Button Content="Confirm Restart"
                                    Command="{Binding ConfirmRestartNowCommand}" />
                            <Button Content="Cancel"
                                    Command="{Binding CancelRestartCommand}" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border IsVisible="{Binding HasInstalledResults}"
                        Background="{StaticResource InfoPanelBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="8">
                    <StackPanel Spacing="6">
                        <TextBlock Text="{Binding InstalledResults.Count, StringFormat='Installed Apps ({0})'}"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource SuccessTextBrush}" />
                        <ItemsControl ItemsSource="{Binding InstalledResults}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding AppName}" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <Border IsVisible="{Binding HasFailedResults}"
                        Background="{StaticResource InfoPanelBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="8">
                    <StackPanel Spacing="6">
                        <TextBlock Text="{Binding FailedResults.Count, StringFormat='Failed Apps ({0})'}"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource ErrorTextBrush}" />
                        <ItemsControl ItemsSource="{Binding FailedResults}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding AppName, StringFormat='• {0}: failed'}" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <Border IsVisible="{Binding HasSkippedResults}"
                        Background="{StaticResource InfoPanelBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="8">
                    <StackPanel Spacing="6">
                        <TextBlock Text="{Binding SkippedResults.Count, StringFormat='Skipped Apps ({0})'}"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource WarnTextBrush}" />
                        <ItemsControl ItemsSource="{Binding SkippedResults}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding AppName, StringFormat='• {0}'}" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <Border IsVisible="{Binding HasUnsupportedSkippedResults}"
                        Background="#FEF2F2"
                        BorderBrush="#FECACA"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="8">
                    <StackPanel Spacing="6">
                        <TextBlock Text="{Binding UnsupportedSkippedResults.Count, StringFormat='Unsupported Selected (Skipped) ({0})'}"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource ErrorTextBrush}" />
                        <ItemsControl ItemsSource="{Binding UnsupportedSkippedResults}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding AppName, StringFormat='• {0} (unsupported on this OS)'}" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <Border IsVisible="{Binding HasRestartRequiredResults}"
                        Background="{StaticResource InfoPanelBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="8">
                    <StackPanel Spacing="6">
                        <TextBlock Text="{Binding RestartRequiredResults.Count, StringFormat='Apps Requiring Restart ({0})'}"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource WarnTextBrush}" />
                        <ItemsControl ItemsSource="{Binding RestartRequiredResults}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding AppName, StringFormat='• {0}'}" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <ItemsControl ItemsSource="{Binding InstallResults}"
                              IsVisible="{Binding HasInstallResults}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="8"
                                    Margin="0,0,0,6">
                                <Grid ColumnDefinitions="2*,Auto,Auto,3*" ColumnSpacing="10">
                                    <TextBlock Text="{Binding AppName}" FontWeight="SemiBold" />
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding Success, StringFormat='Success: {0}'}"
                                               Foreground="{StaticResource MutedTextBrush}" />
                                    <TextBlock Grid.Column="2"
                                               Text="{Binding Skipped, StringFormat='Skipped: {0}'}"
                                               Foreground="{StaticResource MutedTextBrush}" />
                                    <TextBlock Grid.Column="3"
                                               Text="{Binding Message}"
                                               TextWrapping="Wrap"
                                               Foreground="{StaticResource MutedTextBrush}" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <TextBlock Text="{Binding StatusText}"
                           Foreground="{StaticResource MutedTextBrush}" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
