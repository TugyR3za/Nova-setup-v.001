<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:controls="clr-namespace:NovaSetup.Views.Controls"
        xmlns:converters="clr-namespace:NovaSetup.Views.Converters"
        xmlns:views="clr-namespace:NovaSetup.Views"
        xmlns:design="clr-namespace:NovaSetup.Design"
        mc:Ignorable="d"
        d:DesignWidth="1500"
        d:DesignHeight="980"
        x:Class="NovaSetup.Views.MainWindow"
        x:Name="RootWindow"
        x:CompileBindings="False"
        Title="NovaSetup"
        Icon="avares://NovaSetup/Assets/nova_logo.ico"
        RequestedThemeVariant="Default"
        Background="{DynamicResource ShellBackgroundBrush}"
        Foreground="{DynamicResource TextPrimaryBrush}"
        MinWidth="1120"
        MinHeight="720">
    <Design.DataContext>
        <design:MainWindowSampleData />
    </Design.DataContext>

    <Window.Resources>
        <converters:LogLevelToBrushConverter x:Key="LogLevelToBrushConverter" />
    </Window.Resources>

    <Grid RowDefinitions="Auto,*"
          RowSpacing="8">
        <Border Grid.Row="0"
                IsVisible="{Binding IsUpdateAvailable}"
                Background="{DynamicResource AccentSoftBrush}"
                BorderBrush="{DynamicResource AccentBrush}"
                BorderThickness="1"
                CornerRadius="16"
                Padding="14,8"
                Margin="10,10,10,0">
            <Grid ColumnDefinitions="*,Auto"
                  ColumnSpacing="12">
                <TextBlock Text="{Binding UpdateVersionText}"
                           VerticalAlignment="Center"
                           FontWeight="SemiBold" />

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            Spacing="8">
                    <Button Classes="ghost compact"
                            Content="Download"
                            Command="{Binding DownloadUpdateCommand}" />
                    <Button Classes="compact"
                            Content="Dismiss"
                            Command="{Binding DismissUpdateCommand}" />
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Margin="10"
                Classes="shellPanel"
                Padding="8"
                Background="{DynamicResource ShellBackgroundBrush}">
        <Grid ColumnDefinitions="220,*" ColumnSpacing="10">
            <controls:SidebarControl Grid.Column="0"
                                     CurrentProfileName="{Binding CurrentProfileName}"
                                     IsDashboardSelected="{Binding IsDashboardSelected}"
                                     IsDashboardUnselected="{Binding IsDashboardUnselected}"
                                     IsAppsSelected="{Binding IsAppsSelected}"
                                     IsAppsUnselected="{Binding IsAppsUnselected}"
                                     IsMyListsSelected="{Binding IsMyListsSelected}"
                                     IsMyListsUnselected="{Binding IsMyListsUnselected}"
                                     IsHistorySelected="{Binding IsHistorySelected}"
                                     IsHistoryUnselected="{Binding IsHistoryUnselected}"
                                     IsLogsSelected="{Binding IsLogsSelected}"
                                     IsLogsUnselected="{Binding IsLogsUnselected}"
                                     IsAboutSelected="{Binding IsAboutSelected}"
                                     IsAboutUnselected="{Binding IsAboutUnselected}"
                                     NavigateDashboardCommand="{Binding NavigateDashboardCommand}"
                                     NavigateAppsCommand="{Binding NavigateAppsCommand}"
                                     NavigateMyListsCommand="{Binding NavigateMyListsCommand}"
                                     NavigateHistoryCommand="{Binding NavigateHistoryCommand}"
                                     NavigateLogsCommand="{Binding NavigateLogsCommand}"
                                     NavigateAboutCommand="{Binding NavigateAboutCommand}"
                                     ToggleAccountMenuCommand="{Binding ToggleAccountMenuCommand}"
                                     OpenAccountProfileCommand="{Binding OpenAccountProfileCommand}"
                                     OpenAccountSettingsCommand="{Binding OpenAccountSettingsCommand}"
                                     IsAccountMenuOpen="{Binding IsAccountMenuOpen, Mode=TwoWay}" />

            <Border Grid.Column="1"
                    Classes="shellPanel"
                    Background="{DynamicResource PanelBrush}"
                    Padding="14">
                <Grid RowDefinitions="*,Auto,Auto">
                    <Grid IsVisible="{Binding IsHomeScreenVisible}"
                          RowDefinitions="Auto,Auto,Auto,*"
                          RowSpacing="10">
                        <controls:HeaderControl Grid.Row="0"
                                                Title="{Binding HomeTitle}"
                                                Subtitle="{Binding HomeSubtitle}"
                                                ProfileName="{Binding CurrentProfileName}"
                                                SelectedCount="{Binding SelectedCount}"
                                                RecommendedCount="{Binding RecommendedCount}"
                                                HasRecommendedApps="{Binding HasRecommendedApps}"
                                                ShowRecommendedFilterCommand="{Binding ShowRecommendedFilterCommand}"
                                                UpdateAvailableCount="{Binding UpdateAvailableCount}"
                                                HasUpdatesAvailable="{Binding HasUpdatesAvailable}"
                                                CurrentPlatform="{Binding CurrentPlatform}"
                                                RefreshCatalogCommand="{Binding RefreshCatalogCommand}"
                                                ShowUpdatesFilterCommand="{Binding ShowUpdatesFilterCommand}"
                                                HelpCommand="{Binding ShowHelpCommand}" />

                        <Border Grid.Row="1"
                                Classes="card"
                                Padding="12">
                            <StackPanel Spacing="10">
                                <Grid ColumnDefinitions="Auto,Auto,Auto,*,Auto"
                                      ColumnSpacing="8">
                                    <Button Grid.Column="0"
                                            Classes="ghost compact"
                                            Content="Save Profile"
                                            Command="{Binding SaveProfileCommand}" />
                                    <Button Grid.Column="1"
                                            Classes="ghost compact"
                                            Content="Load Profile"
                                            Command="{Binding LoadProfileCommand}" />
                                    <Button Grid.Column="2"
                                            Classes="ghost compact"
                                            Content="Export Profile"
                                            Command="{Binding ExportProfileCommand}" />

                                    <TextBlock Grid.Column="4"
                                               Text="{Binding CurrentProfileName, StringFormat='Active profile: {0}'}"
                                               VerticalAlignment="Center"
                                               Foreground="{DynamicResource TextMutedBrush}"
                                               TextWrapping="Wrap" />
                                </Grid>

                                <Grid IsVisible="{Binding IsSaveProfilePanelOpen}"
                                      ColumnDefinitions="1.2*,2*,Auto,Auto"
                                      ColumnSpacing="10">
                                    <StackPanel Grid.Column="0"
                                                Spacing="4">
                                        <TextBlock Text="Profile name" />
                                        <TextBox Watermark="My Setup"
                                                 Text="{Binding PendingProfileName, Mode=TwoWay}" />
                                    </StackPanel>

                                    <StackPanel Grid.Column="1"
                                                Spacing="4">
                                        <TextBlock Text="Description" />
                                        <TextBox Watermark="Optional description"
                                                 Text="{Binding PendingProfileDescription, Mode=TwoWay}" />
                                    </StackPanel>

                                    <Button Grid.Column="2"
                                            Classes="compact"
                                            Content="Save"
                                            Command="{Binding ConfirmSaveProfileCommand}"
                                            VerticalAlignment="Bottom" />

                                    <Button Grid.Column="3"
                                            Classes="ghost compact"
                                            Content="Cancel"
                                            Command="{Binding CancelSaveProfileCommand}"
                                            VerticalAlignment="Bottom" />
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="2"
                                Classes="card"
                                IsVisible="{Binding IsMyListsSelected}"
                                Padding="12">
                            <StackPanel Spacing="10">
                                <Grid ColumnDefinitions="*,Auto,Auto"
                                      ColumnSpacing="8">
                                    <StackPanel Spacing="2">
                                        <TextBlock Text="Saved profiles"
                                                   FontSize="18"
                                                   FontWeight="SemiBold" />
                                        <TextBlock Text="Profiles saved on this machine. Load one to reapply its app selection instantly."
                                                   Foreground="{DynamicResource TextMutedBrush}"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>

                                    <Button Grid.Column="1"
                                            Classes="ghost compact"
                                            Content="Load Selected"
                                            Command="{Binding LoadSavedProfileCommand}"
                                            VerticalAlignment="Center" />

                                    <Button Grid.Column="2"
                                            Classes="ghost compact"
                                            Content="Delete"
                                            Command="{Binding DeleteSavedProfileCommand}"
                                            VerticalAlignment="Center" />
                                </Grid>

                                <TextBlock Text="No saved local profiles yet."
                                           IsVisible="{Binding HasNoSavedProfiles}"
                                           Foreground="{DynamicResource TextMutedBrush}"
                                           TextWrapping="Wrap" />

                                <ListBox ItemsSource="{Binding SavedProfiles}"
                                         SelectedItem="{Binding SelectedSavedProfile, Mode=TwoWay}"
                                         IsVisible="{Binding HasSavedProfiles}"
                                         MaxHeight="220"
                                         Background="{DynamicResource InputBrush}"
                                         BorderBrush="{DynamicResource InputBorderBrush}"
                                         BorderThickness="1">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border Padding="10,8">
                                                <Grid ColumnDefinitions="*,Auto"
                                                      ColumnSpacing="12">
                                                    <StackPanel Spacing="3">
                                                        <TextBlock Text="{Binding ProfileName}"
                                                                   FontWeight="SemiBold"
                                                                   TextWrapping="Wrap" />
                                                        <TextBlock Text="{Binding Description}"
                                                                   IsVisible="{Binding HasDescription}"
                                                                   Foreground="{DynamicResource TextMutedBrush}"
                                                                   TextWrapping="Wrap" />
                                                        <TextBlock Text="{Binding DisplayCreatedOn, StringFormat='Saved: {0}'}"
                                                                   Foreground="{DynamicResource TextMutedBrush}"
                                                                   FontSize="12" />
                                                    </StackPanel>

                                                    <StackPanel Grid.Column="1"
                                                                Spacing="3"
                                                                HorizontalAlignment="Right">
                                                        <Border Classes="metaChip">
                                                            <TextBlock Text="{Binding DisplaySelectedAppsText}"
                                                                       Foreground="{DynamicResource TextMutedBrush}" />
                                                        </Border>
                                                        <TextBlock Text="{Binding Platform}"
                                                                   Foreground="{DynamicResource TextMutedBrush}"
                                                                   FontSize="12"
                                                                   HorizontalAlignment="Right" />
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </StackPanel>
                        </Border>

                        <ScrollViewer Grid.Row="3"
                                      IsVisible="{Binding IsDashboardSelected}"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <StackPanel Spacing="12" Margin="0,0,6,0">
                                <Grid ColumnDefinitions="1.35*,1*" ColumnSpacing="12">
                                    <Border Grid.Column="0" Classes="card">
                                        <StackPanel Spacing="10">
                                            <StackPanel Spacing="3">
                                                <TextBlock Text="Setup overview"
                                                           FontSize="18"
                                                           FontWeight="SemiBold" />
                                                <TextBlock Text="Everything important about the current install list in one place."
                                                           Foreground="{DynamicResource TextMutedBrush}"
                                                           TextWrapping="Wrap" />
                                            </StackPanel>

                                            <Border Classes="metaChip">
                                                <TextBlock Text="{Binding SelectedFooterText}"
                                                           Foreground="{DynamicResource TextMutedBrush}"
                                                           TextWrapping="Wrap" />
                                            </Border>

                                            <TextBlock Text="{Binding UnsupportedSelectedCount, StringFormat='Unsupported selected apps to review: {0}'}"
                                                       IsVisible="{Binding HasUnsupportedSelectedApps}"
                                                       Foreground="{DynamicResource WarningBrush}"
                                                       TextWrapping="Wrap" />

                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <Button Classes="ghost"
                                                        Content="Save List"
                                                        Command="{Binding SaveListCommand}" />
                                                <Button Classes="primary"
                                                        Content="Install Selected"
                                                        Command="{Binding InstallCommand}" />
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Column="1" Classes="card">
                                        <StackPanel Spacing="10">
                                            <StackPanel Spacing="3">
                                                <TextBlock Text="Recommendations"
                                                           FontSize="18"
                                                           FontWeight="SemiBold" />
                                                <TextBlock Text="Suggested apps already found in your catalog based on detected hardware and accessories."
                                                           Foreground="{DynamicResource TextMutedBrush}"
                                                           TextWrapping="Wrap" />
                                            </StackPanel>

                                            <Border Classes="metaChip">
                                                <TextBlock Text="{Binding RecommendedAppsSummary}"
                                                           Foreground="{DynamicResource TextMutedBrush}"
                                                           TextWrapping="Wrap" />
                                            </Border>

                                            <Button Classes="ghost compact"
                                                    Content="Review Drivers &amp; Accessories"
                                                    Command="{Binding NavigateDriversCommand}"
                                                    HorizontalAlignment="Left" />
                                        </StackPanel>
                                    </Border>
                                </Grid>

                                <Grid ColumnDefinitions="1*,1*" ColumnSpacing="12">
                                    <Border Grid.Column="0" Classes="card">
                                        <StackPanel Spacing="10">
                                            <TextBlock Text="Recent installs"
                                                       FontSize="18"
                                                       FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding InstallSummaryText}"
                                                       IsVisible="{Binding HasInstallResults}"
                                                       Foreground="{DynamicResource TextMutedBrush}"
                                                       TextWrapping="Wrap" />
                                            <TextBlock Text="No install history yet. Run an install and the summary screen will appear here."
                                                       IsVisible="{Binding IsHistoryEmptyScreenVisible}"
                                                       Foreground="{DynamicResource TextMutedBrush}"
                                                       TextWrapping="Wrap" />
                                            <Button Classes="ghost compact"
                                                    Content="Open History"
                                                    Command="{Binding NavigateHistoryCommand}"
                                                    HorizontalAlignment="Left" />
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Column="1" Classes="card">
                                        <StackPanel Spacing="10">
                                            <TextBlock Text="Quick actions"
                                                       FontSize="18"
                                                       FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding StatusText}"
                                                       Foreground="{DynamicResource TextMutedBrush}"
                                                       TextWrapping="Wrap" />
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <Button Classes="ghost compact"
                                                        Content="Open Apps"
                                                        Command="{Binding NavigateAppsCommand}" />
                                                <Button Classes="ghost compact"
                                                        Content="Open Logs"
                                                        Command="{Binding NavigateLogsCommand}" />
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </StackPanel>
                        </ScrollViewer>

                        <Border Grid.Row="3"
                                Classes="card"
                                IsVisible="{Binding IsDashboardUnselected}"
                                Padding="12">
                            <Grid RowDefinitions="Auto,*,Auto" RowSpacing="8">
                        <controls:FilterBarControl Grid.Row="0"
                                                   SearchText="{Binding SearchText, Mode=TwoWay}"
                                                   IsAllFilter="{Binding IsAllFilter, Mode=TwoWay}"
                                                   IsGamesFilter="{Binding IsGamesFilter, Mode=TwoWay}"
                                                   IsDriversFilter="{Binding IsDriversFilter, Mode=TwoWay}"
                                                   IsRecommendedFilter="{Binding IsRecommendedFilter, Mode=TwoWay}"
                                                   IsDevToolsFilter="{Binding IsDevToolsFilter, Mode=TwoWay}"
                                                   IsUtilitiesFilter="{Binding IsUtilitiesFilter, Mode=TwoWay}"
                                                   IsUpdatesFilter="{Binding IsUpdatesFilter, Mode=TwoWay}" />

                                <controls:AppListControl Grid.Row="1"
                                                         Items="{Binding VisibleApps}"
                                                         OpenPublisherCommand="{Binding OpenPublisherCommand}"
                                                         ShowAppDetailsCommand="{Binding ShowAppDetailsCommand}" />

                                <controls:BottomBarControl Grid.Row="2"
                                                           FooterText="{Binding SelectedFooterText}"
                                                           SaveListCommand="{Binding SaveListCommand}"
                                                           InstallSelectedCommand="{Binding InstallCommand}" />
                            </Grid>
                        </Border>
                    </Grid>
                    <ScrollViewer IsVisible="{Binding IsInstallScreenVisible}"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <StackPanel Spacing="12" Margin="0,0,6,0">
                            <Border Classes="card" Padding="18">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="Installing"
                                               FontSize="38"
                                               FontWeight="Bold" />
                                    <TextBlock Text="Using official sources, silent installers when available, and logging every step."
                                               FontSize="15"
                                               Foreground="{DynamicResource TextMutedBrush}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>

                            <Border Classes="card">
                                <StackPanel Spacing="10">
                                    <TextBlock Text="{Binding ProgressValue, StringFormat='Overall progress: {0:0}%'}"
                                               Foreground="{DynamicResource TextMutedBrush}" />
                                    <ProgressBar Minimum="0"
                                                 Maximum="100"
                                                 Value="{Binding ProgressValue}"
                                                 Height="16"
                                                 Background="{DynamicResource InputBrush}"
                                                 Foreground="{DynamicResource AccentBrush}" />
                                </StackPanel>
                            </Border>

                            <Grid ColumnDefinitions="2*,1*" ColumnSpacing="10">
                                <Border Grid.Column="0" Classes="card">
                                    <StackPanel Spacing="8">
                                        <TextBlock Text="Now installing" FontSize="18" FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding InstallStatusText}"
                                                   TextWrapping="Wrap"
                                                   Foreground="{DynamicResource TextMutedBrush}" />
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="1" Classes="card">
                                    <StackPanel Spacing="8">
                                        <TextBlock Text="Actions" FontSize="18" FontWeight="SemiBold" />
                                        <Button Content="Pause"
                                                Command="{Binding PauseInstallCommand}" />
                                        <Button Content="Open Logs"
                                                Command="{Binding OpenLogFileCommand}" />
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <Border Classes="card">
                                <StackPanel Spacing="8">
                                    <TextBlock Text="Queue" FontSize="18" FontWeight="SemiBold" />
                                    <ItemsControl ItemsSource="{Binding InstallResults}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border BorderBrush="{DynamicResource CardBorderBrush}"
                                                        BorderThickness="1"
                                                        CornerRadius="10"
                                                        Padding="10"
                                                        Margin="0,0,0,6">
                                                    <Grid ColumnDefinitions="2*,Auto,3*">
                                                        <TextBlock Text="{Binding AppName}" FontWeight="SemiBold" />
                                                        <TextBlock Grid.Column="1"
                                                                   Text="{Binding Skipped, StringFormat='Skipped: {0}'}"
                                                                   Foreground="{DynamicResource TextMutedBrush}" />
                                                        <TextBlock Grid.Column="2"
                                                                   Text="{Binding Message}"
                                                                   Foreground="{DynamicResource TextMutedBrush}"
                                                                   TextWrapping="Wrap" />
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>

                            <Grid ColumnDefinitions="Auto,Auto,*" ColumnSpacing="10">
                                <Button Grid.Column="0"
                                        Content="Open Log File"
                                        Command="{Binding OpenLogFileCommand}" />
                                <Button Grid.Column="1"
                                        Classes="ghost"
                                        Content="Finish and Summary (auto)"
                                        IsEnabled="False" />
                            </Grid>
                        </StackPanel>
                    </ScrollViewer>
                    <ScrollViewer IsVisible="{Binding IsSummaryScreenVisible}"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <StackPanel Spacing="12" Margin="0,0,6,0">
                            <Border Classes="card" Padding="18">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="Setup complete"
                                               FontSize="38"
                                               FontWeight="Bold" />
                                    <TextBlock Text="{Binding InstallSummaryText}"
                                               FontSize="16"
                                               Foreground="{DynamicResource TextMutedBrush}" />
                                </StackPanel>
                            </Border>

                            <Grid ColumnDefinitions="1.6*,1*" ColumnSpacing="10">
                                <Border Grid.Column="0" Classes="card">
                                    <StackPanel Spacing="10">
                                        <TextBlock Text="Installed summary" FontSize="18" FontWeight="SemiBold" />
                                        <Grid ColumnDefinitions="1*,1*,1*,1*" ColumnSpacing="8">
                                            <Border Background="{DynamicResource SuccessSurfaceBrush}" CornerRadius="10" Padding="10">
                                                <TextBlock Text="{Binding InstalledResults.Count, StringFormat='Installed {0}'}"
                                                           Foreground="{DynamicResource SuccessBrush}" />
                                            </Border>
                                            <Border Grid.Column="1" Background="{DynamicResource DangerSurfaceBrush}" CornerRadius="10" Padding="10">
                                                <TextBlock Text="{Binding FailedResults.Count, StringFormat='Failed {0}'}"
                                                           Foreground="{DynamicResource DangerBrush}" />
                                            </Border>
                                            <Border Grid.Column="2" Background="{DynamicResource WarningSurfaceBrush}" CornerRadius="10" Padding="10">
                                                <TextBlock Text="{Binding SkippedResults.Count, StringFormat='Skipped {0}'}"
                                                           Foreground="{DynamicResource WarningBrush}" />
                                            </Border>
                                            <Border Grid.Column="3" Background="{DynamicResource InfoSurfaceBrush}" CornerRadius="10" Padding="10">
                                                <TextBlock Text="{Binding RestartRequiredResults.Count, StringFormat='Restart {0}'}"
                                                           Foreground="{DynamicResource AccentBrush}" />
                                            </Border>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="1" Classes="card">
                                    <StackPanel Spacing="8">
                                        <TextBlock Text="Next steps" FontSize="18" FontWeight="SemiBold" />
                                        <TextBlock Text="- Launch installed apps and sign in if needed."
                                                   Foreground="{DynamicResource TextMutedBrush}" />
                                        <TextBlock Text="- Check drivers if hardware tools were installed."
                                                   Foreground="{DynamicResource TextMutedBrush}" />
                                        <TextBlock Text="- Keep this profile as your default setup list."
                                                   Foreground="{DynamicResource TextMutedBrush}" />
                                        <TextBlock Text="{Binding Settings.SelfDeleteAfterInstall, StringFormat='Self-delete setting: {0}'}"
                                                   Foreground="{DynamicResource TextMutedBrush}" />
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <Border Classes="card"
                                    IsVisible="{Binding IsRestartSectionVisible}"
                                    Background="{DynamicResource WarningSurfaceBrush}"
                                    BorderBrush="{DynamicResource WarningBrush}">
                                <StackPanel Spacing="8">
                                    <TextBlock Text="Restart Recommended"
                                               FontSize="18"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource WarningBrush}" />
                                    <TextBlock Text="{Binding RestartStatusText}"
                                               Foreground="{DynamicResource WarningMessageBrush}"
                                               TextWrapping="Wrap" />

                                    <StackPanel Orientation="Horizontal"
                                                Spacing="8"
                                                IsVisible="{Binding ShowPrimaryRestartActions}">
                                        <Button Classes="primary"
                                                Content="Restart Now"
                                                Command="{Binding RequestRestartNowCommand}" />
                                        <Button Content="Skip / Restart Later"
                                                Command="{Binding RestartLaterCommand}" />
                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal"
                                                Spacing="8"
                                                IsVisible="{Binding IsRestartConfirmationVisible}">
                                        <Button Classes="primary"
                                                Content="Confirm Restart"
                                                Command="{Binding ConfirmRestartNowCommand}" />
                                        <Button Content="Cancel"
                                                Command="{Binding CancelRestartCommand}" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <Grid ColumnDefinitions="Auto,Auto,Auto,*" ColumnSpacing="10">
                                <Button Grid.Column="0"
                                        Content="Save Default List"
                                        Command="{Binding SaveListCommand}" />
                                <Button Grid.Column="1"
                                        Content="Export Report (PDF)"
                                        Command="{Binding ExportReportCommand}" />
                                <Button Grid.Column="2"
                                        Content="Open Log File"
                                        Command="{Binding OpenLogFileCommand}" />
                            </Grid>

                            <Border Classes="card" IsVisible="{Binding HasInstalledResults}">
                                <StackPanel Spacing="6">
                                    <TextBlock Text="{Binding InstalledResults.Count, StringFormat='Installed Apps ({0})'}"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource SuccessBrush}" />
                                    <ItemsControl ItemsSource="{Binding InstalledResults}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding AppName}" />
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>

                            <Border Classes="card" IsVisible="{Binding HasFailedResults}">
                                <StackPanel Spacing="6">
                                    <TextBlock Text="{Binding FailedResults.Count, StringFormat='Failed Apps ({0})'}"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource DangerBrush}" />
                                    <ItemsControl ItemsSource="{Binding FailedResults}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding AppName, StringFormat='- {0}'}" />
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>

                            <Border Classes="card" IsVisible="{Binding HasSkippedResults}">
                                <StackPanel Spacing="6">
                                    <TextBlock Text="{Binding SkippedResults.Count, StringFormat='Skipped Apps ({0})'}"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource WarningBrush}" />
                                    <ItemsControl ItemsSource="{Binding SkippedResults}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding AppName, StringFormat='- {0}'}" />
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>

                            <Border Classes="card" IsVisible="{Binding HasRestartRequiredResults}">
                                <StackPanel Spacing="6">
                                    <TextBlock Text="{Binding RestartRequiredResults.Count, StringFormat='Apps Requiring Restart ({0})'}"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource AccentBrush}" />
                                    <ItemsControl ItemsSource="{Binding RestartRequiredResults}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding AppName, StringFormat='- {0}'}" />
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>

                    <Border IsVisible="{Binding IsHistoryEmptyScreenVisible}"
                            Classes="card"
                            Padding="20">
                        <StackPanel Spacing="10">
                            <TextBlock Text="History"
                                       FontSize="34"
                                       FontWeight="Bold" />
                            <TextBlock Text="No install history yet. Run an install and the summary will appear here."
                                       Foreground="{DynamicResource TextMutedBrush}"
                                       TextWrapping="Wrap" />
                            <Button Content="Back to Apps"
                                    Command="{Binding NavigateAppsCommand}"
                                    HorizontalAlignment="Left" />
                        </StackPanel>
                    </Border>

                    <ScrollViewer IsVisible="{Binding IsLogsScreenVisible}"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <StackPanel Spacing="12" Margin="0,0,6,0">
                            <Border Classes="card" Padding="18">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="Logs"
                                               FontSize="34"
                                               FontWeight="Bold" />
                                    <TextBlock Text="Open the current runtime log file or inspect the latest status message below."
                                               FontSize="15"
                                               Foreground="{DynamicResource TextMutedBrush}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>

                            <Border Classes="card">
                                <StackPanel Spacing="8">
                                    <TextBlock Text="Current log file"
                                               FontSize="18"
                                               FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding LogFilePath}"
                                               Foreground="{DynamicResource TextMutedBrush}"
                                               TextWrapping="Wrap" />
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <Button Content="Open Log File"
                                                Command="{Binding OpenLogFileCommand}" />
                                        <Button Classes="ghost"
                                                Content="Back to Apps"
                                                Command="{Binding NavigateAppsCommand}" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <Border Classes="card"
                                    IsVisible="{Binding IsDeveloperModeEnabled}">
                                <StackPanel Spacing="6">
                                    <TextBlock Text="Latest status"
                                               FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding StatusText}"
                                               Foreground="{DynamicResource TextMutedBrush}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>

                    <views:AboutView IsVisible="{Binding IsAboutScreenVisible}"
                                     VersionText="{Binding AboutVersionText}"
                                     CurrentVersionText="{Binding AboutCurrentVersionText}"
                                     RemoteVersionText="{Binding AboutRemoteVersionText}"
                                     GitHubUrl="{Binding AboutGitHubUrl}"
                                     OpenGitHubCommand="{Binding OpenAboutGitHubCommand}"
                                     CheckForUpdatesCommand="{Binding ManualCheckForUpdatesCommand}"
                                     UpdateStatusText="{Binding AboutUpdateStatusText}"
                                     IsUpdateStatusVisible="{Binding IsAboutUpdateStatusVisible}" />

                    <GridSplitter Grid.Row="1"
                                  x:Name="DeveloperConsoleSplitter"
                                  Height="6"
                                  Margin="0,8,0,0"
                                  HorizontalAlignment="Stretch"
                                  ResizeDirection="Rows"
                                  ResizeBehavior="PreviousAndNext"
                                  Background="{DynamicResource CardBorderBrush}" />

                    <Border Grid.Row="2"
                            x:Name="DeveloperConsolePanel"
                            IsVisible="{Binding IsDeveloperModeEnabled}"
                            Classes="card"
                            Padding="0"
                            Margin="0,8,0,0"
                            Height="180"
                            MinHeight="40">
                        <Grid RowDefinitions="Auto,*">
                            <Border Background="{DynamicResource InputBrush}"
                                    BorderBrush="{DynamicResource CardBorderBrush}"
                                    BorderThickness="0,0,0,1"
                                    Padding="12,8">
                                <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto,Auto,Auto,Auto"
                                      ColumnSpacing="8">
                                    <Button Grid.Column="0"
                                            x:Name="DeveloperConsoleToggleButton"
                                            Classes="compact ghost"
                                            Content="Collapse"
                                            Click="OnDeveloperConsoleToggleClick" />

                                    <TextBlock Grid.Column="1"
                                               Text="Developer Console"
                                               VerticalAlignment="Center"
                                               FontWeight="SemiBold" />

                                    <TextBlock Grid.Column="2"
                                               Text="{Binding LiveLogs.Count, StringFormat='Entries: {0}'}"
                                               VerticalAlignment="Center"
                                               Foreground="{DynamicResource TextMutedBrush}" />

                                    <ComboBox Grid.Column="3"
                                              Width="128"
                                              ItemsSource="{Binding LogLevelFilterOptions}"
                                              SelectedItem="{Binding SelectedLogLevelFilterOption}">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Label}" />
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>

                                    <Button Grid.Column="4"
                                            Classes="compact ghost"
                                            Content="Copy Selected"
                                            Command="{Binding CopySelectedLogCommand}" />

                                    <Button Grid.Column="5"
                                            Classes="compact ghost"
                                            Content="Clear"
                                            Command="{Binding ClearLogsCommand}" />

                                    <Button Grid.Column="6"
                                            Classes="compact ghost"
                                            Content="Export"
                                            Command="{Binding ExportLogsCommand}" />

                                    <Button Grid.Column="7"
                                            Classes="compact ghost"
                                            Content="Copy All"
                                            Command="{Binding CopyLogsCommand}" />
                                </Grid>
                            </Border>

                            <Grid Grid.Row="1"
                                  x:Name="DeveloperConsoleContent"
                                  Margin="10">
                                <Border Background="{DynamicResource InputBrush}"
                                        BorderBrush="{DynamicResource InputBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="12"
                                        Padding="4">
                                    <ListBox x:Name="DeveloperLogListBox"
                                             ItemsSource="{Binding FilteredLiveLogs}"
                                             SelectedItem="{Binding SelectedLiveLogEntry, Mode=TwoWay}"
                                             SelectionMode="Single"
                                             Background="Transparent"
                                             BorderThickness="0">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Border Padding="8,4"
                                                        Background="Transparent">
                                                    <TextBlock Text="{Binding DisplayText}"
                                                               TextWrapping="Wrap"
                                                               FontFamily="Cascadia Code, Consolas, Segoe UI Mono"
                                                               Foreground="{Binding Level, Converter={StaticResource LogLevelToBrushConverter}}" />
                                                </Border>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </Border>
                            </Grid>
                        </Grid>
                    </Border>

                    <Border IsVisible="{Binding IsSettingsPanelOpen}"
                            Classes="card"
                            Width="370"
                            MaxHeight="700"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top"
                            Margin="10,10,0,0"
                            Padding="14"
                            Background="{DynamicResource ElevatedCardBrush}"
                            BorderBrush="{DynamicResource CardBorderBrush}">
                        <Grid RowDefinitions="Auto,*" RowSpacing="12">
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                                <StackPanel Spacing="2">
                                    <TextBlock Text="Preferences"
                                               FontSize="20"
                                               FontWeight="SemiBold" />
                                    <TextBlock Text="Persistent app behavior, downloads, and advanced options."
                                               Foreground="{DynamicResource TextMutedBrush}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                                <Button Grid.Column="1"
                                        Classes="closeIcon"
                                        Command="{Binding ToggleSettingsPanelCommand}">
                                    <Viewbox Width="14"
                                             Height="14">
                                        <Path Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                              Data="M19,6.41L17.59,5L12,10.59L6.41,5L5,6.41L10.59,12L5,17.59L6.41,19L12,13.41L17.59,19L19,17.59L13.41,12L19,6.41Z" />
                                    </Viewbox>
                                </Button>
                            </Grid>

                            <ScrollViewer Grid.Row="1"
                                          VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled">
                                <StackPanel Spacing="14">
                                    <StackPanel Spacing="8">
                                        <TextBlock Text="Installation"
                                                   FontSize="16"
                                                   FontWeight="SemiBold" />

                                        <StackPanel Spacing="2">
                                            <CheckBox IsChecked="{Binding Settings.SilentInstall}"
                                                      Content="Silent installation" />
                                            <TextBlock Text="Install apps without showing installer windows when possible."
                                                       FontSize="12"
                                                       Foreground="{DynamicResource TextMutedBrush}"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>

                                        <StackPanel Spacing="2">
                                            <CheckBox IsChecked="{Binding Settings.ParallelInstall}"
                                                      Content="Install apps simultaneously" />
                                            <TextBlock Text="Install multiple apps at the same time to speed up setup."
                                                       FontSize="12"
                                                       Foreground="{DynamicResource TextMutedBrush}"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>

                                        <StackPanel Spacing="2">
                                            <CheckBox IsChecked="{Binding Settings.SelfDeleteAfterInstall}"
                                                      Content="Self-delete after install" />
                                            <TextBlock Text="Remove NovaSetup after installation finishes."
                                                       FontSize="12"
                                                       Foreground="{DynamicResource TextMutedBrush}"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>

                                        <StackPanel Spacing="4">
                                            <TextBlock Text="Restart computer if required" />
                                            <ComboBox ItemsSource="{Binding RestartBehaviorOptions}"
                                                      SelectedItem="{Binding SelectedRestartBehaviorOption}">
                                                <ComboBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding Label}" />
                                                    </DataTemplate>
                                                </ComboBox.ItemTemplate>
                                            </ComboBox>
                                            <TextBlock Text="Choose what NovaSetup should do if installed apps require a restart."
                                                       FontSize="12"
                                                       Foreground="{DynamicResource TextMutedBrush}"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                    </StackPanel>

                                    <StackPanel Spacing="8">
                                        <TextBlock Text="App List"
                                                   FontSize="16"
                                                   FontWeight="SemiBold" />

                                        <StackPanel Spacing="2">
                                            <CheckBox IsChecked="{Binding Settings.OsSupportedApps}"
                                                      Content="OS supported apps" />
                                            <TextBlock Text="When enabled, only apps supported on this operating system will be shown."
                                                       FontSize="12"
                                                       Foreground="{DynamicResource TextMutedBrush}"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>

                                        <StackPanel Spacing="2">
                                            <CheckBox IsChecked="{Binding Settings.ShowAlreadyInstalledApps}"
                                                      Content="Show already installed apps" />
                                            <TextBlock Text="Show apps already installed on this computer."
                                                       FontSize="12"
                                                       Foreground="{DynamicResource TextMutedBrush}"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>

                                        <StackPanel Spacing="2">
                                            <CheckBox IsChecked="{Binding Settings.AutoDetectInstalledAppsOnStartup}"
                                                      Content="Scan PC for installed apps on startup" />
                                            <TextBlock Text="Automatically detect installed apps when NovaSetup starts."
                                                       FontSize="12"
                                                       Foreground="{DynamicResource TextMutedBrush}"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                    </StackPanel>

                                    <StackPanel Spacing="8">
                                        <TextBlock Text="Downloads"
                                                   FontSize="16"
                                                   FontWeight="SemiBold" />

                                        <StackPanel Spacing="4">
                                            <TextBlock Text="Download location" />
                                            <ComboBox ItemsSource="{Binding DownloadLocationOptions}"
                                                      SelectedItem="{Binding SelectedDownloadLocationOption}">
                                                <ComboBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding Label}" />
                                                    </DataTemplate>
                                                </ComboBox.ItemTemplate>
                                            </ComboBox>
                                            <TextBlock Text="Choose where installers are downloaded before installation."
                                                       FontSize="12"
                                                       Foreground="{DynamicResource TextMutedBrush}"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>

                                        <StackPanel Spacing="4"
                                                    IsVisible="{Binding IsCustomDownloadFolderVisible}">
                                            <TextBlock Text="Custom download folder" />
                                            <TextBox Watermark="Used only for Custom folder mode"
                                                     Text="{Binding Settings.CustomDownloadFolder}" />
                                            <TextBlock Text="Used only when Download location is set to Custom folder."
                                                       FontSize="12"
                                                       Foreground="{DynamicResource TextMutedBrush}"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>

                                        <StackPanel Spacing="2">
                                            <CheckBox IsChecked="{Binding Settings.KeepInstallersAfterInstall}"
                                                      Content="Keep installers after install" />
                                            <TextBlock Text="Keep downloaded installers after installation finishes."
                                                       FontSize="12"
                                                       Foreground="{DynamicResource TextMutedBrush}"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                    </StackPanel>

                                    <StackPanel Spacing="8">
                                        <TextBlock Text="System"
                                                   FontSize="16"
                                                   FontWeight="SemiBold" />

                                        <StackPanel Spacing="2">
                                            <CheckBox IsChecked="{Binding Settings.LaunchNovaAtStartup}"
                                                      Content="Launch Nova at startup" />
                                            <TextBlock Text="Open NovaSetup automatically when the system starts."
                                                       FontSize="12"
                                                       Foreground="{DynamicResource TextMutedBrush}"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>

                                        <StackPanel Spacing="2">
                                            <CheckBox IsChecked="{Binding Settings.CheckForUpdatesAutomatically}"
                                                      Content="Automatically check for updates" />
                                            <TextBlock Text="Check for a newer Nova release on startup and show a banner when one is available."
                                                       FontSize="12"
                                                       Foreground="{DynamicResource TextMutedBrush}"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>

                                        <StackPanel Spacing="4">
                                            <TextBlock Text="Theme" />
                                            <ComboBox ItemsSource="{Binding ThemeOptions}"
                                                      SelectedItem="{Binding SelectedThemeOption}">
                                                <ComboBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding Label}" />
                                                    </DataTemplate>
                                                </ComboBox.ItemTemplate>
                                            </ComboBox>
                                            <TextBlock Text="Choose the appearance theme for NovaSetup."
                                                       FontSize="12"
                                                       Foreground="{DynamicResource TextMutedBrush}"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>

                                        <StackPanel Spacing="4">
                                            <TextBlock Text="Language" />
                                            <ComboBox ItemsSource="{Binding LanguageOptions}"
                                                      SelectedItem="{Binding SelectedLanguageOption}">
                                                <ComboBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding Label}" />
                                                    </DataTemplate>
                                                </ComboBox.ItemTemplate>
                                            </ComboBox>
                                            <TextBlock Text="Choose the display language for NovaSetup."
                                                       FontSize="12"
                                                       Foreground="{DynamicResource TextMutedBrush}"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                    </StackPanel>

                                    <StackPanel Spacing="8">
                                        <TextBlock Text="Data"
                                                   FontSize="16"
                                                   FontWeight="SemiBold" />

                                        <StackPanel Spacing="2">
                                            <CheckBox IsChecked="{Binding Settings.SaveProfilesAutomatically}"
                                                      Content="Save profiles automatically" />
                                            <TextBlock Text="Automatically save changes to your NovaSetup lists and profiles."
                                                       FontSize="12"
                                                       Foreground="{DynamicResource TextMutedBrush}"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                    </StackPanel>

                                    <StackPanel Spacing="8">
                                        <TextBlock Text="Advanced"
                                                   FontSize="16"
                                                   FontWeight="SemiBold" />

                                        <StackPanel Spacing="2">
                                            <CheckBox IsChecked="{Binding Settings.DeveloperMode}"
                                                      Content="Developer mode" />
                                            <TextBlock Text="Show install logs and extra debug information."
                                                       FontSize="12"
                                                       Foreground="{DynamicResource TextMutedBrush}"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>

                                        <StackPanel Spacing="4">
                                            <Button Content="Reset Nova settings"
                                                    Command="{Binding ResetSettingsCommand}"
                                                    HorizontalAlignment="Left" />
                                            <TextBlock Text="Restore all NovaSetup settings to their default values."
                                                       FontSize="12"
                                                       Foreground="{DynamicResource TextMutedBrush}"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                    </StackPanel>
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>
                    </Border>

                    <Border IsVisible="{Binding IsAppDetailsOpen}"
                            Classes="card"
                            Width="360"
                            MaxHeight="720"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Margin="0,10,10,0"
                            Padding="14"
                            Background="{DynamicResource ElevatedCardBrush}"
                            BorderBrush="{DynamicResource CardBorderBrush}">
                        <Grid RowDefinitions="Auto,*"
                              RowSpacing="12">
                            <Grid ColumnDefinitions="*,Auto"
                                  ColumnSpacing="10">
                                <StackPanel Spacing="2">
                                    <TextBlock Text="App details"
                                               FontSize="20"
                                               FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding SelectedDetailApp.Name}"
                                               FontSize="13"
                                               Foreground="{DynamicResource TextMutedBrush}"
                                               TextWrapping="Wrap" />
                                </StackPanel>

                                <Button Grid.Column="1"
                                        Classes="closeIcon"
                                        Command="{Binding CloseAppDetailsCommand}">
                                    <Viewbox Width="14"
                                             Height="14">
                                        <Path Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                              Data="M19,6.41L17.59,5L12,10.59L6.41,5L5,6.41L10.59,12L5,17.59L6.41,19L12,13.41L17.59,19L19,17.59L13.41,12L19,6.41Z" />
                                    </Viewbox>
                                </Button>
                            </Grid>

                            <ScrollViewer Grid.Row="1"
                                          VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled">
                                <StackPanel Spacing="14">
                                    <Grid ColumnDefinitions="Auto,*"
                                          ColumnSpacing="12">
                                        <Border Width="46"
                                                Height="46"
                                                CornerRadius="23"
                                                Background="{DynamicResource AppIconBackgroundBrush}"
                                                VerticalAlignment="Top">
                                            <TextBlock Text="{Binding SelectedDetailApp.IconGlyph}"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       FontSize="18"
                                                       FontWeight="Bold" />
                                        </Border>

                                        <StackPanel Grid.Column="1"
                                                    Spacing="4">
                                            <TextBlock Text="{Binding SelectedDetailApp.Name}"
                                                       FontSize="22"
                                                       FontWeight="SemiBold"
                                                       TextWrapping="Wrap" />
                                            <Button Classes="link"
                                                    Content="{Binding SelectedDetailApp.PublisherName}"
                                                    Command="{Binding OpenPublisherCommand}"
                                                    CommandParameter="{Binding SelectedDetailApp}" />
                                            <TextBlock Text="{Binding SelectedDetailApp.Category, StringFormat='Category: {0}'}"
                                                       Foreground="{DynamicResource TextMutedBrush}"
                                                       FontSize="12" />
                                        </StackPanel>
                                    </Grid>

                                    <StackPanel Spacing="8">
                                        <Border Classes="metaChip">
                                            <TextBlock Text="{Binding SelectedDetailSupportStatusText}"
                                                       Foreground="{DynamicResource TextMutedBrush}"
                                                       TextWrapping="Wrap" />
                                        </Border>
                                        <Border Classes="metaChip">
                                            <TextBlock Text="{Binding SelectedDetailPlatformsText, StringFormat='Platforms: {0}'}"
                                                       Foreground="{DynamicResource TextMutedBrush}"
                                                       TextWrapping="Wrap" />
                                        </Border>
                                        <Border Classes="metaChip">
                                            <TextBlock Text="{Binding SelectedDetailInstallSupportText}"
                                                       Foreground="{DynamicResource TextMutedBrush}"
                                                       TextWrapping="Wrap" />
                                        </Border>
                                        <Border Classes="metaChip">
                                            <TextBlock Text="{Binding SelectedDetailApp.StatusBadge, StringFormat='Status: {0}'}"
                                                       Foreground="{DynamicResource TextMutedBrush}"
                                                       TextWrapping="Wrap" />
                                        </Border>
                                        <Border Classes="metaChip">
                                            <TextBlock Text="{Binding SelectedDetailCatalogVersionText}"
                                                       Foreground="{DynamicResource TextMutedBrush}"
                                                       TextWrapping="Wrap" />
                                        </Border>
                                        <Border Classes="metaChip">
                                            <TextBlock Text="{Binding SelectedDetailInstalledVersionText}"
                                                       Foreground="{DynamicResource TextMutedBrush}"
                                                       TextWrapping="Wrap" />
                                        </Border>
                                        <Border Classes="metaChip">
                                            <TextBlock Text="{Binding SelectedDetailUpdateStatusText}"
                                                       Foreground="{DynamicResource TextMutedBrush}"
                                                       TextWrapping="Wrap" />
                                        </Border>
                                    </StackPanel>

                                    <StackPanel Spacing="6">
                                        <TextBlock Text="Description"
                                                   FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding SelectedDetailDescription}"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>

                                    <StackPanel Spacing="6"
                                                IsVisible="{Binding HasSelectedDetailRecommendation}">
                                        <TextBlock Text="Recommendation"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource AccentBrush}" />
                                        <Border Background="{DynamicResource AccentSoftBrush}"
                                                BorderBrush="{DynamicResource AccentBrush}"
                                                BorderThickness="1"
                                                CornerRadius="12"
                                                Padding="10">
                                            <TextBlock Text="{Binding SelectedDetailApp.RecommendationReason}"
                                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                                       TextWrapping="Wrap" />
                                        </Border>
                                    </StackPanel>

                                    <StackPanel Spacing="6">
                                        <TextBlock Text="Selection"
                                                   FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding SelectedDetailApp.IsSelected, StringFormat='Selected: {0}'}"
                                                   Foreground="{DynamicResource TextMutedBrush}" />
                                        <TextBlock Text="{Binding SelectedDetailApp.IsInstalled, StringFormat='Installed: {0}'}"
                                                   Foreground="{DynamicResource TextMutedBrush}" />
                                        <TextBlock Text="{Binding SelectedDetailApp.RequiresRestartHint, StringFormat='Restart may be required: {0}'}"
                                                   Foreground="{DynamicResource TextMutedBrush}" />
                                    </StackPanel>
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>
        </Border>
    </Grid>
</Window>

