<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:controls="clr-namespace:NovaSetup.Views.Controls"
        xmlns:converters="clr-namespace:NovaSetup.Views.Converters"
        xmlns:views="clr-namespace:NovaSetup.Views"
        xmlns:design="clr-namespace:NovaSetup.Design"
        mc:Ignorable="d"
        d:DesignWidth="1500"
        d:DesignHeight="980"
        x:Class="NovaSetup.Views.MainWindow"
        x:Name="RootWindow"
        x:CompileBindings="False"
        Title="NovaSetup"
        Icon="avares://NovaSetup/Assets/nova_logo.ico"
        TransparencyLevelHint="Mica, AcrylicBlur"
        Background="{DynamicResource ShellBackgroundBrush}"
        Foreground="{DynamicResource TextPrimaryBrush}"
        MinWidth="600"
        MinHeight="450">
    <Design.DataContext>
        <design:MainWindowSampleData />
    </Design.DataContext>

    <Window.Resources>
        <converters:LogLevelToBrushConverter x:Key="LogLevelToBrushConverter" />
        <converters:InstallQueueStatusToBrushConverter x:Key="InstallQueueStatusToBrushConverter" />
        <converters:InstallQueueStatusToProgressVisibilityConverter x:Key="InstallQueueStatusToProgressVisibilityConverter" />
        <converters:StringHasValueConverter x:Key="StringHasValueConverter" />
    </Window.Resources>

    <Window.Styles>
        <Style Selector="Border.installQueueRow">
            <Setter Property="Background" Value="{DynamicResource CardBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style Selector="Border.installQueueRow.active">
            <Setter Property="Background" Value="{DynamicResource AccentSoftBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
            <Setter Property="BorderThickness" Value="3,1,1,1" />
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="Auto,Auto,*"
          RowSpacing="8">
        <Border Grid.Row="0"
                IsVisible="{Binding IsUpdateAvailable}"
                Background="{DynamicResource AccentSoftBrush}"
                BorderBrush="{DynamicResource AccentBrush}"
                BorderThickness="1"
                CornerRadius="16"
                Padding="14,8"
                Margin="10,10,10,0">
            <Grid ColumnDefinitions="*,Auto"
                  ColumnSpacing="12">
                <TextBlock Text="{Binding UpdateVersionText}"
                           VerticalAlignment="Center"
                           FontWeight="SemiBold" />

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            Spacing="8">
                    <Button Classes="ghost compact"
                            Content="Download"
                            Command="{Binding DownloadUpdateCommand}" />
                    <Button Classes="compact"
                            Content="Dismiss"
                            Command="{Binding DismissUpdateCommand}" />
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                IsVisible="{Binding IsDependencyInfoVisible}"
                Background="{DynamicResource AccentSoftBrush}"
                BorderBrush="{DynamicResource AccentBrush}"
                BorderThickness="1"
                CornerRadius="16"
                Padding="14,8"
                Margin="10,0,10,0">
            <TextBlock Text="{Binding DependencyInfoText}"
                       VerticalAlignment="Center"
                       TextWrapping="Wrap" />
        </Border>

        <Border Grid.Row="2"
                Margin="10"
                Classes="shellPanel"
                Padding="8"
                Background="{DynamicResource ShellBackgroundBrush}">
        <Grid ColumnDefinitions="1*,5*" ColumnSpacing="10">
            <controls:SidebarControl Grid.Column="0"
                                     CurrentProfileName="{Binding CurrentProfileName}"
                                     IsDashboardSelected="{Binding IsDashboardSelected}"
                                     IsDashboardUnselected="{Binding IsDashboardUnselected}"
                                     IsAppsSelected="{Binding IsAppsSelected}"
                                     IsAppsUnselected="{Binding IsAppsUnselected}"

                                     IsUpdatesSelected="{Binding IsUpdatesSelected}"
                                     IsUpdatesUnselected="{Binding IsUpdatesUnselected}"
                                     HasUpdatesAvailable="{Binding HasUpdatesAvailable}"
                                     UpdateAvailableCount="{Binding UpdateAvailableCount}"
                                     HelpCommand="{Binding HelpCommand}"
                                     NavigateDashboardCommand="{Binding NavigateDashboardCommand}"
                                     NavigateAppsCommand="{Binding NavigateAppsCommand}"

                                     NavigateUpdatesCommand="{Binding NavigateUpdatesCommand}"

                                     NavigateAboutCommand="{Binding NavigateAboutCommand}"
                                     NavigateHistoryCommand="{Binding NavigateHistoryCommand}"
                                     ToggleAccountMenuCommand="{Binding ToggleAccountMenuCommand}"
                                     OpenAccountProfileCommand="{Binding OpenAccountProfileCommand}"
                                     OpenAccountSettingsCommand="{Binding OpenAccountSettingsCommand}"
                                     IsAccountMenuOpen="{Binding IsAccountMenuOpen, Mode=TwoWay}" />

            <Border Grid.Column="1"
                    Classes="shellPanel"
                    Background="{DynamicResource PanelBrush}"
                    Padding="14">
                <Grid RowDefinitions="*,Auto,Auto">
                    <Grid IsVisible="{Binding IsHomeScreenVisible}"
                          RowDefinitions="Auto,Auto,*"
                          RowSpacing="0">
                        <controls:HeaderControl Grid.Row="0"
                                                Title="{Binding HomeTitle}"
                                                Subtitle="{Binding HomeSubtitle}"
                                                UpdateAvailableCount="{Binding UpdateAvailableCount}"
                                                HasUpdatesAvailable="{Binding HasUpdatesAvailable}"
                                                OpenUpdatesCommand="{Binding NavigateUpdatesCommand}"
                                                RefreshCatalogCommand="{Binding RefreshCatalogCommand}"
                                                HelpCommand="{Binding ShowHelpCommand}" />


                        <Border Grid.Row="1"
                                Classes="card"
                                IsVisible="{Binding IsMyListsSelected}"
                                Padding="12">
                            <StackPanel Spacing="10">
                                <Grid ColumnDefinitions="*,Auto,Auto"
                                      ColumnSpacing="8">
                                    <StackPanel Spacing="2">
                                        <TextBlock Text="Saved profiles"
                                                   FontSize="18"
                                                   FontWeight="SemiBold" />
                                        <TextBlock Text="Profiles saved on this machine. Load one to reapply its app selection instantly."
                                                   Foreground="{DynamicResource TextMutedBrush}"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>

                                    <Button Grid.Column="1"
                                            Classes="ghost compact"
                                            Content="Load Selected"
                                            Command="{Binding LoadSavedProfileCommand}"
                                            VerticalAlignment="Center" />

                                    <Button Grid.Column="2"
                                            Classes="ghost compact"
                                            Content="Delete"
                                            Command="{Binding DeleteSavedProfileCommand}"
                                            VerticalAlignment="Center" />
                                </Grid>

                                <TextBlock Text="No saved local profiles yet."
                                           IsVisible="{Binding HasNoSavedProfiles}"
                                           Foreground="{DynamicResource TextMutedBrush}"
                                           TextWrapping="Wrap" />

                                <ListBox ItemsSource="{Binding SavedProfiles}"
                                         SelectedItem="{Binding SelectedSavedProfile, Mode=TwoWay}"
                                         IsVisible="{Binding HasSavedProfiles}"
                                         MaxHeight="220"
                                         Background="{DynamicResource InputBrush}"
                                         BorderBrush="{DynamicResource InputBorderBrush}"
                                         BorderThickness="1">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border Padding="10,8">
                                                <Grid ColumnDefinitions="*,Auto"
                                                      ColumnSpacing="12">
                                                    <StackPanel Spacing="3">
                                                        <TextBlock Text="{Binding ProfileName}"
                                                                   FontWeight="SemiBold"
                                                                   TextWrapping="Wrap" />
                                                        <TextBlock Text="{Binding Description}"
                                                                   IsVisible="{Binding HasDescription}"
                                                                   Foreground="{DynamicResource TextMutedBrush}"
                                                                   TextWrapping="Wrap" />
                                                        <TextBlock Text="{Binding DisplayCreatedOn, StringFormat='Saved: {0}'}"
                                                                   Foreground="{DynamicResource TextMutedBrush}"
                                                                   FontSize="12" />
                                                    </StackPanel>

                                                    <StackPanel Grid.Column="1"
                                                                Spacing="3"
                                                                HorizontalAlignment="Right">
                                                        <Border Classes="metaChip">
                                                            <TextBlock Text="{Binding DisplaySelectedAppsText}"
                                                                       Foreground="{DynamicResource TextMutedBrush}" />
                                                        </Border>
                                                        <TextBlock Text="{Binding Platform}"
                                                                   Foreground="{DynamicResource TextMutedBrush}"
                                                                   FontSize="12"
                                                                   HorizontalAlignment="Right" />
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </StackPanel>
                        </Border>

                        <ScrollViewer Grid.Row="2"
                                      IsVisible="{Binding IsDashboardSelected}"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <StackPanel Spacing="12" Margin="0,0,6,0">
                                <Grid ColumnDefinitions="1.35*,1*" ColumnSpacing="12">
                                    <Border Grid.Column="0" Classes="card">
                                        <StackPanel Spacing="10">
                                            <StackPanel Spacing="3">
                                                <TextBlock Text="Setup overview"
                                                           FontSize="18"
                                                           FontWeight="SemiBold" />
                                                <TextBlock Text="Everything important about the current install list in one place."
                                                           Foreground="{DynamicResource TextMutedBrush}"
                                                           TextWrapping="Wrap" />
                                            </StackPanel>

                                            <Border Classes="metaChip">
                                                <TextBlock Text="{Binding SelectedFooterText}"
                                                           Foreground="{DynamicResource TextMutedBrush}"
                                                           TextWrapping="Wrap" />
                                            </Border>

                                            <TextBlock Text="{Binding UnsupportedSelectedCount, StringFormat='Unsupported selected apps to review: {0}'}"
                                                       IsVisible="{Binding HasUnsupportedSelectedApps}"
                                                       Foreground="{DynamicResource WarningBrush}"
                                                       TextWrapping="Wrap" />

                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <Button Classes="ghost"
                                                        Content="Save List"
                                                        Command="{Binding SaveListCommand}" />
                                                <Button Classes="primary"
                                                        Content="Install Selected"
                                                        Command="{Binding InstallCommand}" />
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Column="1" Classes="card">
                                        <StackPanel Spacing="10">
                                            <StackPanel Spacing="3">
                                                <TextBlock Text="Recommendations"
                                                           FontSize="18"
                                                           FontWeight="SemiBold" />
                                                <TextBlock Text="Suggested apps already found in your catalog based on detected hardware and accessories."
                                                           Foreground="{DynamicResource TextMutedBrush}"
                                                           TextWrapping="Wrap" />
                                            </StackPanel>

                                            <Border Classes="metaChip">
                                                <TextBlock Text="{Binding RecommendedAppsSummary}"
                                                           Foreground="{DynamicResource TextMutedBrush}"
                                                           TextWrapping="Wrap" />
                                            </Border>

                                            <Button Classes="ghost compact"
                                                    Content="Review Drivers &amp; Accessories"
                                                    Command="{Binding NavigateDriversCommand}"
                                                    HorizontalAlignment="Left" />
                                        </StackPanel>
                                    </Border>
                                </Grid>

                                <Grid ColumnDefinitions="1*,1*" ColumnSpacing="12">
                                    <Border Grid.Column="0" Classes="card">
                                        <StackPanel Spacing="10">
                                            <TextBlock Text="Recent installs" FontSize="18" FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding InstallSummaryText}" IsVisible="{Binding HasInstallResults}" Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap" />
                                            <TextBlock Text="No install history yet. Run an install and the summary screen will appear here." IsVisible="{Binding IsHistoryEmptyScreenVisible}" Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap" />
                                            <Button Classes="ghost compact" Content="Open Downloads" Command="{Binding NavigateHistoryCommand}" HorizontalAlignment="Left" />
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Column="1" Classes="card">
                                        <StackPanel Spacing="10">
                                            <TextBlock Text="Quick actions"
                                                       FontSize="18"
                                                       FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding StatusText}"
                                                       Foreground="{DynamicResource TextMutedBrush}"
                                                       TextWrapping="Wrap" />
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <Button Classes="ghost compact"
                                                        Content="Open Apps"
                                                        Command="{Binding NavigateAppsCommand}" />
                                                <Button Classes="ghost compact"
                                                        Content="Open Logs"
                                                        Command="{Binding NavigateLogsCommand}" />
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </StackPanel>
                        </ScrollViewer>

                        <Border Grid.Row="2"
                                Classes="card"
                                IsVisible="{Binding IsDashboardUnselected}"
                                Padding="8,8,12,12"
                                ClipToBounds="True">
                            <Grid RowDefinitions="Auto,Auto,*,Auto" RowSpacing="8">
                                <StackPanel Grid.Row="0"
                                            Spacing="6"
                                            IsVisible="{Binding IsAppsSelected}">
                                    <Border IsVisible="{Binding PresetAppliedText, Converter={StaticResource StringHasValueConverter}}"
                                            Background="{DynamicResource AccentSoftBrush}"
                                            BorderBrush="{DynamicResource AccentBrush}"
                                            BorderThickness="1"
                                            CornerRadius="14"
                                            Padding="12,8">
                                        <Grid ColumnDefinitions="*,Auto"
                                              ColumnSpacing="10">
                                            <TextBlock Text="{Binding PresetAppliedText}"
                                                       VerticalAlignment="Center"
                                                       FontWeight="SemiBold"
                                                       TextWrapping="Wrap" />

                                            <Button Grid.Column="1"
                                                    Classes="ghost compact"
                                                    Content="Dismiss"
                                                    Command="{Binding DismissPresetAppliedCommand}" />
                                        </Grid>
                                    </Border>

                                    <StackPanel Spacing="6"
                                                MaxHeight="180"
                                                ClipToBounds="True">
                                        <TextBlock Text="Quick Setup"
                                                   FontSize="18"
                                                   FontWeight="SemiBold" />

                                        <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                                      VerticalScrollBarVisibility="Disabled"
                                                      MaxHeight="150">
                                            <ItemsControl ItemsSource="{Binding AvailablePresets}"
                                                          HorizontalAlignment="Stretch">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <WrapPanel Orientation="Horizontal" />
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Classes="card"
                                                                MinWidth="180"
                                                                HorizontalAlignment="Stretch"
                                                                Padding="8"
                                                                Margin="0,0,12,8">
                                                            <StackPanel Spacing="5">
                                                                <Border Width="32"
                                                                        Height="32"
                                                                        CornerRadius="16"
                                                                        Background="{DynamicResource AccentSoftBrush}">
                                                                    <TextBlock Text="{Binding Icon}"
                                                                               HorizontalAlignment="Center"
                                                                               VerticalAlignment="Center"
                                                                               FontWeight="Bold"
                                                                               Foreground="{DynamicResource AccentBrush}" />
                                                                </Border>

                                                                <StackPanel Spacing="3">
                                                                    <TextBlock Text="{Binding Name}"
                                                                               FontWeight="SemiBold"
                                                                               TextWrapping="NoWrap"
                                                                               TextTrimming="CharacterEllipsis" />
                                                                    <TextBlock Text="{Binding AppCountText}"
                                                                               Foreground="{DynamicResource TextMutedBrush}"
                                                                               FontSize="12" />
                                                                    <TextBlock Text="{Binding Description}"
                                                                               Foreground="{DynamicResource TextDescriptionBrush}"
                                                                               FontSize="12"
                                                                               TextWrapping="Wrap"
                                                                               MaxLines="2"
                                                                               TextTrimming="CharacterEllipsis" />
                                                                </StackPanel>

                                                                <Button Content="Apply"
                                                                        HorizontalAlignment="Left"
                                                                        Command="{Binding #RootWindow.DataContext.ApplyPresetCommand}"
                                                                        CommandParameter="{Binding .}" />
                                                            </StackPanel>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </ScrollViewer>
                                    </StackPanel>
                                </StackPanel>

                                <controls:FilterBarControl Grid.Row="1"
                                                   SearchText="{Binding SearchText, Mode=TwoWay}"
                                                   AvailableCategories="{Binding AvailableCategories}"
                                                   SelectedCategory="{Binding SelectedCategory, Mode=TwoWay}"
                                                   IsAllFilter="{Binding IsAllFilter, Mode=TwoWay}"
                                                   IsGamesFilter="{Binding IsGamesFilter, Mode=TwoWay}"
                                                   IsDriversFilter="{Binding IsDriversFilter, Mode=TwoWay}"
                                                   IsRecommendedFilter="{Binding IsRecommendedFilter, Mode=TwoWay}"
                                                   IsDevToolsFilter="{Binding IsDevToolsFilter, Mode=TwoWay}"
                                                   IsUtilitiesFilter="{Binding IsUtilitiesFilter, Mode=TwoWay}"
                                                   IsArm64Filter="{Binding IsArm64Filter, Mode=TwoWay}"
                                                   IsUpdatesFilter="{Binding IsUpdatesFilter, Mode=TwoWay}"
                                                   IsArm64Machine="{Binding IsArm64Machine}"
                                                   IsGridViewActive="{Binding IsGridViewActive, Mode=TwoWay}"
                                                   RefreshCatalogCommand="{Binding RefreshCatalogCommand}"
                                                   ToggleViewModeCommand="{Binding ToggleViewModeCommand}" />

                                <controls:AppListControl Grid.Row="2"
                                                         IsVisible="{Binding IsListViewActive}"
                                                         MinHeight="0"
                                                         Items="{Binding VisibleApps}"
                                                         OpenPublisherCommand="{Binding OpenPublisherCommand}"
                                                         ShowAppDetailsCommand="{Binding ShowAppDetailsCommand}"
                                                         InstallAppCommand="{Binding InstallAppCommand}"
                                                         UpdateAppCommand="{Binding UpdateAppCommand}"
                                                         UninstallCommand="{Binding UninstallCommand}"
                                                         OpenInstallLocationCommand="{Binding OpenInstallLocationCommand}"
                                                         CopyToClipboardCommand="{Binding CopyToClipboardCommand}"
                                                         ToggleSilentInstallPreferenceCommand="{Binding ToggleSilentInstallPreferenceCommand}"
                                                         ToggleScanningPreferenceCommand="{Binding ToggleScanningPreferenceCommand}" />

                                <controls:AppGridControl Grid.Row="2"
                                                         IsVisible="{Binding IsGridViewActive}"
                                                         MinHeight="0"
                                                         Items="{Binding VisibleApps}"
                                                         OpenPublisherCommand="{Binding OpenPublisherCommand}"
                                                         ShowAppDetailsCommand="{Binding ShowAppDetailsCommand}" />

                                <controls:BottomBarControl Grid.Row="3"
                                                           SelectedAppsCount="{Binding SelectedAppsCount}"
                                                           SelectedAppsSizeMB="{Binding SelectedAppsSizeMB}"
                                                           SelectedAppsTimeMins="{Binding SelectedAppsTimeMins}"
                                                           SaveListCommand="{Binding SaveListCommand}"
                                                           InstallSelectedCommand="{Binding InstallCommand}" />
                            </Grid>
                        </Border>
                    </Grid>
                    <ScrollViewer IsVisible="{Binding IsInstallScreenVisible}"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <StackPanel Spacing="12" Margin="0,0,6,0">
                            <Border Classes="card" Padding="18">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="Installing"
                                               FontSize="38"
                                               FontWeight="Bold" />
                                    <TextBlock Text="Using official sources, silent installers when available, and logging every step."
                                               FontSize="15"
                                               Foreground="{DynamicResource TextMutedBrush}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>

                            <Border Classes="card">
                                <StackPanel Spacing="10">
                                    <TextBlock Text="{Binding ProgressValue, StringFormat='Overall progress: {0:0}%'}"
                                               Foreground="{DynamicResource TextMutedBrush}" />
                                    <ProgressBar Minimum="0"
                                                 Maximum="100"
                                                 Value="{Binding ProgressValue}"
                                                 Height="16"
                                                 Background="{DynamicResource InputBrush}"
                                                 Foreground="{DynamicResource AccentBrush}" />
                                </StackPanel>
                            </Border>

                            <Grid ColumnDefinitions="1.45*,0.95*" ColumnSpacing="12">
                                <StackPanel Grid.Column="0"
                                            Spacing="12">
                                    <Grid ColumnDefinitions="2*,1*" ColumnSpacing="10">
                                        <Border Grid.Column="0" Classes="card">
                                            <StackPanel Spacing="8">
                                                <TextBlock Text="Now installing" FontSize="18" FontWeight="SemiBold" />
                                                <TextBlock Text="{Binding InstallStatusText}"
                                                           TextWrapping="Wrap"
                                                           Foreground="{DynamicResource TextMutedBrush}" />
                                            </StackPanel>
                                        </Border>

                                        <Border Grid.Column="1" Classes="card">
                                            <StackPanel Spacing="8">
                                                <TextBlock Text="Actions" FontSize="18" FontWeight="SemiBold" />
                                                <Button Content="Cancel All"
                                                        Command="{Binding PauseInstallCommand}" />
                                                <Button Content="Open Logs"
                                                        Command="{Binding OpenLogFileCommand}" />
                                            </StackPanel>
                                        </Border>
                                    </Grid>

                                    <Border Classes="card">
                                        <StackPanel Spacing="8">
                                            <TextBlock Text="Activity" FontSize="18" FontWeight="SemiBold" />
                                            <ItemsControl ItemsSource="{Binding InstallResults}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border BorderBrush="{DynamicResource CardBorderBrush}"
                                                                BorderThickness="1"
                                                                CornerRadius="10"
                                                                Padding="10"
                                                                Margin="0,0,0,6">
                                                            <Grid ColumnDefinitions="2*,Auto,3*">
                                                                <TextBlock Text="{Binding AppName}" FontWeight="SemiBold" />
                                                                <TextBlock Grid.Column="1"
                                                                           Text="{Binding StatusText}"
                                                                           Foreground="{DynamicResource TextMutedBrush}" />
                                                                <TextBlock Grid.Column="2"
                                                                           Text="{Binding Message}"
                                                                           Foreground="{DynamicResource TextMutedBrush}"
                                                                           TextWrapping="Wrap" />
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>

                                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                                        <Button Grid.Column="0"
                                                Content="Open Log File"
                                                Command="{Binding OpenLogFileCommand}" />
                                    </Grid>
                                </StackPanel>

                                <Border Grid.Column="1"
                                        Classes="card"
                                        IsVisible="{Binding IsQueueVisible}"
                                        Background="{DynamicResource ElevatedCardBrush}">
                                    <Grid RowDefinitions="Auto,*"
                                          RowSpacing="10">
                                        <Grid ColumnDefinitions="*,Auto"
                                              ColumnSpacing="10">
                                            <StackPanel Spacing="2">
                                                <TextBlock Text="Install queue"
                                                           FontSize="18"
                                                           FontWeight="SemiBold" />
                                                <TextBlock Text="{Binding InstallQueueHeaderText}"
                                                           Foreground="{DynamicResource TextMutedBrush}"
                                                           TextWrapping="Wrap" />
                                            </StackPanel>

                                            <Button Grid.Column="1"
                                                    Classes="ghost compact"
                                                    Content="Clear"
                                                    Command="{Binding ClearQueueCommand}" />
                                        </Grid>

                                        <ScrollViewer Grid.Row="1"
                                                      VerticalScrollBarVisibility="Auto"
                                                      HorizontalScrollBarVisibility="Disabled">
                                            <ItemsControl ItemsSource="{Binding InstallQueue}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Classes="installQueueRow"
                                                                Classes.active="{Binding IsActive}"
                                                                CornerRadius="12"
                                                                Padding="10"
                                                                Margin="0,0,0,8">
                                                            <Grid RowDefinitions="Auto,Auto,Auto"
                                                                  RowSpacing="6">
                                                                <Grid ColumnDefinitions="Auto,*,Auto"
                                                                      ColumnSpacing="10">
                                                                    <Ellipse Width="10"
                                                                             Height="10"
                                                                             Fill="{Binding Status, Converter={StaticResource InstallQueueStatusToBrushConverter}}"
                                                                             VerticalAlignment="Center" />

                                                                    <StackPanel Grid.Column="1"
                                                                                Spacing="2">
                                                                        <TextBlock Text="{Binding AppName}"
                                                                                   FontWeight="SemiBold"
                                                                                   TextWrapping="Wrap" />
                                                                        <TextBlock Text="{Binding StatusText}"
                                                                                   FontSize="12"
                                                                                   Foreground="{DynamicResource TextMutedBrush}"
                                                                                   TextWrapping="Wrap" />
                                                                    </StackPanel>

                                                                    <Border Grid.Column="2"
                                                                            Width="28"
                                                                            Height="28"
                                                                            CornerRadius="14"
                                                                            Background="{DynamicResource AppIconBackgroundBrush}"
                                                                            VerticalAlignment="Top">
                                                                        <TextBlock Text="{Binding IconGlyph}"
                                                                                   HorizontalAlignment="Center"
                                                                                   VerticalAlignment="Center"
                                                                                   FontWeight="SemiBold" />
                                                                    </Border>
                                                                </Grid>

                                                                <ProgressBar Grid.Row="2"
                                                                             Minimum="0"
                                                                             Maximum="1"
                                                                             Height="3"
                                                                             Value="{Binding Progress}"
                                                                             Background="{DynamicResource InputBrush}"
                                                                             Foreground="{DynamicResource AccentBrush}"
                                                                             IsVisible="{Binding Status, Converter={StaticResource InstallQueueStatusToProgressVisibilityConverter}}" />
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </ScrollViewer>
                                    </Grid>
                                </Border>
                            </Grid>
                        </StackPanel>
                    </ScrollViewer>
                    <StackPanel IsVisible="{Binding IsHistoryScreenVisible}"
                                Spacing="12">
                        <Border Classes="card"
                                IsVisible="{Binding HasInstallResults}"
                                Padding="18">
                            <StackPanel Spacing="8">
                                <TextBlock Text="Latest install summary"
                                           FontSize="24"
                                           FontWeight="Bold" />
                                <TextBlock Text="{Binding InstallSummaryText}"
                                           Foreground="{DynamicResource TextMutedBrush}"
                                           TextWrapping="Wrap" />

                                <Border IsVisible="{Binding IsRestartSectionVisible}"
                                        Background="{DynamicResource WarningSurfaceBrush}"
                                        BorderBrush="{DynamicResource WarningBrush}"
                                        BorderThickness="1"
                                        CornerRadius="12"
                                        Padding="12">
                                    <StackPanel Spacing="8">
                                        <TextBlock Text="Restart Recommended"
                                                   FontSize="18"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource WarningBrush}" />
                                        <TextBlock Text="{Binding RestartStatusText}"
                                                   Foreground="{DynamicResource WarningMessageBrush}"
                                                   TextWrapping="Wrap" />

                                        <StackPanel Orientation="Horizontal"
                                                    Spacing="8"
                                                    IsVisible="{Binding ShowPrimaryRestartActions}">
                                            <Button Classes="primary"
                                                    Content="Restart Now"
                                                    Command="{Binding RequestRestartNowCommand}" />
                                            <Button Content="Skip / Restart Later"
                                                    Command="{Binding RestartLaterCommand}" />
                                        </StackPanel>

                                        <StackPanel Orientation="Horizontal"
                                                    Spacing="8"
                                                    IsVisible="{Binding IsRestartConfirmationVisible}">
                                            <Button Classes="primary"
                                                    Content="Confirm Restart"
                                                    Command="{Binding ConfirmRestartNowCommand}" />
                                            <Button Content="Cancel"
                                                    Command="{Binding CancelRestartCommand}" />
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>

                        <Grid IsVisible="{Binding HasInstallResults}"
                              ColumnDefinitions="1*,1*"
                              ColumnSpacing="10">
                            <Border Grid.Column="0"
                                    Classes="card">
                                <StackPanel Spacing="8">
                                    <TextBlock Text="Latest install queue"
                                               FontSize="18"
                                               FontWeight="SemiBold" />
                                    <TextBlock Text="Apps from the most recent install run are shown here."
                                               Foreground="{DynamicResource TextMutedBrush}"
                                               TextWrapping="Wrap" />
                                    <ItemsControl ItemsSource="{Binding InstallQueue}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Classes="installQueueRow"
                                                        Classes.active="{Binding IsActive}"
                                                        CornerRadius="12"
                                                        Padding="10"
                                                        Margin="0,0,0,8">
                                                    <Grid RowDefinitions="Auto,Auto"
                                                          RowSpacing="6">
                                                        <Grid ColumnDefinitions="Auto,*,Auto"
                                                              ColumnSpacing="10">
                                                            <Ellipse Width="10"
                                                                     Height="10"
                                                                     Fill="{Binding Status, Converter={StaticResource InstallQueueStatusToBrushConverter}}"
                                                                     VerticalAlignment="Center" />

                                                            <StackPanel Grid.Column="1"
                                                                        Spacing="2">
                                                                <TextBlock Text="{Binding AppName}"
                                                                           FontWeight="SemiBold"
                                                                           TextWrapping="Wrap" />
                                                                <TextBlock Text="{Binding StatusText}"
                                                                           FontSize="12"
                                                                           Foreground="{DynamicResource TextMutedBrush}"
                                                                           TextWrapping="Wrap" />
                                                            </StackPanel>

                                                            <Border Grid.Column="2"
                                                                    Width="28"
                                                                    Height="28"
                                                                    CornerRadius="14"
                                                                    Background="{DynamicResource AppIconBackgroundBrush}"
                                                                    VerticalAlignment="Top">
                                                                <TextBlock Text="{Binding IconGlyph}"
                                                                           HorizontalAlignment="Center"
                                                                           VerticalAlignment="Center"
                                                                           FontWeight="SemiBold" />
                                                            </Border>
                                                        </Grid>

                                                        <ProgressBar Grid.Row="1"
                                                                     Minimum="0"
                                                                     Maximum="1"
                                                                     Height="3"
                                                                     Value="{Binding Progress}"
                                                                     Background="{DynamicResource InputBrush}"
                                                                     Foreground="{DynamicResource AccentBrush}"
                                                                     IsVisible="{Binding Status, Converter={StaticResource InstallQueueStatusToProgressVisibilityConverter}}" />
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="1"
                                    Classes="card">
                                <StackPanel Spacing="8">
                                    <TextBlock Text="Latest install activity"
                                               FontSize="18"
                                               FontWeight="SemiBold" />
                                    <TextBlock Text="Each result from the most recent install run is listed below."
                                               Foreground="{DynamicResource TextMutedBrush}"
                                               TextWrapping="Wrap" />
                                    <ItemsControl ItemsSource="{Binding InstallResults}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border BorderBrush="{DynamicResource CardBorderBrush}"
                                                        BorderThickness="1"
                                                        CornerRadius="10"
                                                        Padding="10"
                                                        Margin="0,0,0,6">
                                                    <Grid ColumnDefinitions="2*,Auto,3*"
                                                          ColumnSpacing="10">
                                                        <TextBlock Text="{Binding AppName}"
                                                                   FontWeight="SemiBold" />
                                                        <TextBlock Grid.Column="1"
                                                                   Text="{Binding StatusText}"
                                                                   Foreground="{DynamicResource TextMutedBrush}" />
                                                        <TextBlock Grid.Column="2"
                                                                   Text="{Binding Message}"
                                                                   Foreground="{DynamicResource TextMutedBrush}"
                                                                   TextWrapping="Wrap" />
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <views:HistoryView DataContext="{Binding HistoryViewModel}" />
                    </StackPanel>

                    <Border IsVisible="{Binding IsUpdatesScreenVisible}"
                            Background="Transparent">
                        <views:UpdatesView DataContext="{Binding UpdatesViewModel}" />
                    </Border>

                    <ScrollViewer IsVisible="{Binding IsLogsScreenVisible}"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <StackPanel Spacing="12" Margin="0,0,6,0">
                            <Border Classes="card" Padding="18">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="Logs"
                                               FontSize="34"
                                               FontWeight="Bold" />
                                    <TextBlock Text="Open the current runtime log file or inspect the latest status message below."
                                               FontSize="15"
                                               Foreground="{DynamicResource TextMutedBrush}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>

                            <Border Classes="card">
                                <StackPanel Spacing="8">
                                    <TextBlock Text="Current log file"
                                               FontSize="18"
                                               FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding LogFilePath}"
                                               Foreground="{DynamicResource TextMutedBrush}"
                                               TextWrapping="Wrap" />
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <Button Content="Open Log File"
                                                Command="{Binding OpenLogFileCommand}" />
                                        <Button Classes="ghost"
                                                Content="Back to Apps"
                                                Command="{Binding NavigateAppsCommand}" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <Border Classes="card"
                                    IsVisible="{Binding IsDeveloperModeEnabled}">
                                <StackPanel Spacing="6">
                                    <TextBlock Text="Latest status"
                                               FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding StatusText}"
                                               Foreground="{DynamicResource TextMutedBrush}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>

                    <views:AboutView IsVisible="{Binding IsAboutScreenVisible}"
                                     VersionText="{Binding AboutVersionText}"
                                     CurrentVersionText="{Binding AboutCurrentVersionText}"
                                     RemoteVersionText="{Binding AboutRemoteVersionText}"
                                     GitHubUrl="{Binding AboutGitHubUrl}"
                                     OpenGitHubCommand="{Binding OpenAboutGitHubCommand}"
                                     CheckForUpdatesCommand="{Binding ManualCheckForUpdatesCommand}"
                                     HelpCommand="{Binding HelpCommand}"
                                     UpdateStatusText="{Binding AboutUpdateStatusText}"
                                     IsUpdateStatusVisible="{Binding IsAboutUpdateStatusVisible}" />

                    <GridSplitter Grid.Row="1"
                                  x:Name="DeveloperConsoleSplitter"
                                  Height="6"
                                  Margin="0,8,0,0"
                                  HorizontalAlignment="Stretch"
                                  ResizeDirection="Rows"
                                  ResizeBehavior="PreviousAndNext"
                                  IsVisible="{Binding IsDeveloperModeEnabled}"
                                  Background="{DynamicResource CardBorderBrush}" />

                    <Border Grid.Row="2"
                            x:Name="DeveloperConsolePanel"
                            IsVisible="{Binding IsDeveloperModeEnabled}"
                            Classes="card"
                            Padding="0"
                            Margin="0,8,0,0"
                            Height="180"
                            MinHeight="40">
                        <Grid RowDefinitions="Auto,*">
                            <Border Background="{DynamicResource InputBrush}"
                                    BorderBrush="{DynamicResource CardBorderBrush}"
                                    BorderThickness="0,0,0,1"
                                    Padding="12,8">
                                <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto,Auto,Auto,Auto"
                                      ColumnSpacing="8">
                                    <Button Grid.Column="0"
                                            x:Name="DeveloperConsoleToggleButton"
                                            Classes="compact ghost"
                                            Content="Collapse"
                                            Click="OnDeveloperConsoleToggleClick" />

                                    <TextBlock Grid.Column="1"
                                               Text="Developer Console"
                                               VerticalAlignment="Center"
                                               FontWeight="SemiBold" />

                                    <TextBlock Grid.Column="2"
                                               Text="{Binding FilteredLiveLogs.Count, StringFormat='Entries: {0}'}"
                                               VerticalAlignment="Center"
                                               Foreground="{DynamicResource TextMutedBrush}" />

                                    <ComboBox Grid.Column="3"
                                              Width="128"
                                              ItemsSource="{Binding LogLevelFilterOptions}"
                                              SelectedItem="{Binding SelectedLogLevelFilterOption}">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Label}" />
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>

                                    <Button Grid.Column="4"
                                            Classes="compact ghost"
                                            Content="Copy Selected"
                                            Command="{Binding CopySelectedLogCommand}" />

                                    <Button Grid.Column="5"
                                            Classes="compact ghost"
                                            Content="Clear"
                                            Command="{Binding ClearLogsCommand}" />

                                    <Button Grid.Column="6"
                                            Classes="compact ghost"
                                            Content="Export"
                                            Command="{Binding ExportLogsCommand}" />

                                    <Button Grid.Column="7"
                                            Classes="compact ghost"
                                            Content="Copy All"
                                            Command="{Binding CopyLogsCommand}" />
                                </Grid>
                            </Border>

                            <Grid Grid.Row="1"
                                  x:Name="DeveloperConsoleContent"
                                  Margin="10">
                                <Border Background="{DynamicResource InputBrush}"
                                        BorderBrush="{DynamicResource InputBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="12"
                                        Padding="4">
                                    <ListBox x:Name="DeveloperLogListBox"
                                             ItemsSource="{Binding FilteredLiveLogs}"
                                             SelectedItem="{Binding SelectedLiveLogEntry, Mode=TwoWay}"
                                             SelectionMode="Single"
                                             Background="Transparent"
                                             BorderThickness="0">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Border Padding="8,4"
                                                        Background="Transparent">
                                                    <TextBlock Text="{Binding DisplayText}"
                                                               TextWrapping="Wrap"
                                                               FontFamily="Cascadia Code, Consolas, Segoe UI Mono"
                                                               Foreground="{Binding Level, Converter={StaticResource LogLevelToBrushConverter}}" />
                                                </Border>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </Border>
                            </Grid>
                        </Grid>
                    </Border>

                    <Border IsVisible="{Binding IsAppDetailsOpen}"
                            Classes="card"
                            Width="360"
                            MaxHeight="720"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Margin="0,10,10,0"
                            Padding="14"
                            Background="{DynamicResource ElevatedCardBrush}"
                            BorderBrush="{DynamicResource CardBorderBrush}">
                        <Grid RowDefinitions="*,Auto"
                              RowSpacing="12">
                            <ScrollViewer Grid.Row="0"
                                          VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled">
                                <StackPanel Spacing="14">
                                    <Grid ColumnDefinitions="*,Auto"
                                          ColumnSpacing="10">
                                        <StackPanel Spacing="2">
                                            <TextBlock Text="App details"
                                                       FontSize="20"
                                                       FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding SelectedDetailApp.Name}"
                                                       FontSize="13"
                                                       Foreground="{DynamicResource TextMutedBrush}"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>

                                        <Button Grid.Column="1"
                                                Classes="closeIcon"
                                                Command="{Binding CloseAppDetailsCommand}">
                                            <Viewbox Width="14"
                                                     Height="14">
                                                <Path Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                                      Data="M19,6.41L17.59,5L12,10.59L6.41,5L5,6.41L10.59,12L5,17.59L6.41,19L12,13.41L17.59,19L19,17.59L13.41,12L19,6.41Z" />
                                            </Viewbox>
                                        </Button>
                                    </Grid>

                                    <Grid ColumnDefinitions="Auto,*"
                                          ColumnSpacing="12">
                                        <Border Width="46"
                                                Height="46"
                                                CornerRadius="23"
                                                Background="{DynamicResource AppIconBackgroundBrush}"
                                                VerticalAlignment="Top">
                                            <TextBlock Text="{Binding SelectedDetailApp.IconGlyph}"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       FontSize="18"
                                                       FontWeight="Bold" />
                                        </Border>

                                        <StackPanel Grid.Column="1"
                                                    Spacing="4">
                                            <TextBlock Text="{Binding SelectedDetailApp.Name}"
                                                       FontSize="22"
                                                       FontWeight="SemiBold"
                                                       TextWrapping="Wrap" />
                                            <Button Classes="link"
                                                    Content="{Binding SelectedDetailApp.PublisherName}"
                                                    Command="{Binding OpenPublisherCommand}"
                                                    CommandParameter="{Binding SelectedDetailApp}" />
                                            <TextBlock Text="{Binding SelectedDetailApp.Category, StringFormat='Category: {0}'}"
                                                       Foreground="{DynamicResource TextMutedBrush}"
                                                       FontSize="12" />
                                        </StackPanel>
                                    </Grid>

                                    <StackPanel Spacing="8">
                                        <Border Classes="metaChip">
                                            <TextBlock Text="{Binding SelectedDetailSupportStatusText}"
                                                       Foreground="{DynamicResource TextMutedBrush}"
                                                       TextWrapping="Wrap" />
                                        </Border>
                                        <Border Classes="metaChip">
                                            <TextBlock Text="{Binding SelectedDetailPlatformsText, StringFormat='Platforms: {0}'}"
                                                       Foreground="{DynamicResource TextMutedBrush}"
                                                       TextWrapping="Wrap" />
                                        </Border>
                                        <Border Classes="metaChip">
                                            <TextBlock Text="{Binding SelectedDetailInstallSupportText}"
                                                       Foreground="{DynamicResource TextMutedBrush}"
                                                       TextWrapping="Wrap" />
                                        </Border>
                                        <Border Classes="metaChip">
                                            <TextBlock Text="{Binding SelectedDetailApp.StatusBadge, StringFormat='Status: {0}'}"
                                                       Foreground="{DynamicResource TextMutedBrush}"
                                                       TextWrapping="Wrap" />
                                        </Border>
                                    </StackPanel>

                                    <StackPanel Spacing="6">
                                        <TextBlock Text="Version info"
                                                   FontWeight="SemiBold" />
                                        <Border Classes="metaChip">
                                            <TextBlock Text="{Binding SelectedDetailCatalogVersionText}"
                                                       Foreground="{DynamicResource TextMutedBrush}"
                                                       TextWrapping="Wrap" />
                                        </Border>
                                        <Border Classes="metaChip">
                                            <TextBlock Text="{Binding SelectedDetailInstalledVersionText}"
                                                       Foreground="{DynamicResource TextMutedBrush}"
                                                       TextWrapping="Wrap" />
                                        </Border>
                                        <Border Classes="metaChip">
                                            <TextBlock Text="{Binding SelectedDetailUpdateStatusText}"
                                                       Foreground="{DynamicResource TextMutedBrush}"
                                                       TextWrapping="Wrap" />
                                        </Border>
                                    </StackPanel>

                                    <StackPanel Spacing="6">
                                        <TextBlock Text="Details"
                                                   FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding SelectedDetailDescription}"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   TextWrapping="Wrap" />
                                        <TextBlock Text="{Binding SelectedDetailLicenseText}"
                                                   IsVisible="{Binding SelectedDetailLicenseText, Converter={StaticResource StringHasValueConverter}}"
                                                   Foreground="{DynamicResource TextMutedBrush}"
                                                   TextWrapping="Wrap" />
                                        <ItemsControl ItemsSource="{Binding SelectedDetailTags}"
                                                      IsVisible="{Binding HasSelectedDetailTags}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel Orientation="Horizontal" />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Classes="metaChip"
                                                            Margin="0,0,8,8">
                                                        <TextBlock Text="{Binding .}"
                                                                   Foreground="{DynamicResource TextMutedBrush}"
                                                                   FontSize="12" />
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        <Button Classes="link compact"
                                                Content="{Binding SelectedDetailReleaseNotesText}"
                                                IsVisible="{Binding HasSelectedDetailReleaseNotes}"
                                                Command="{Binding OpenSelectedDetailReleaseNotesCommand}"
                                                HorizontalAlignment="Left"
                                                Padding="0" />
                                    </StackPanel>

                                    <StackPanel Spacing="6"
                                                IsVisible="{Binding HasSelectedDetailRecommendation}">
                                        <TextBlock Text="Recommendation"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource AccentBrush}" />
                                        <Border Background="{DynamicResource AccentSoftBrush}"
                                                BorderBrush="{DynamicResource AccentBrush}"
                                                BorderThickness="1"
                                                CornerRadius="12"
                                                Padding="10">
                                            <TextBlock Text="{Binding SelectedDetailApp.RecommendationReason}"
                                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                                       TextWrapping="Wrap" />
                                        </Border>
                                    </StackPanel>

                                    <StackPanel Spacing="6">
                                        <TextBlock Text="Security"
                                                   FontWeight="SemiBold"
                                                   IsVisible="{Binding HasSelectedDetailVirusTotal}" />
                                        <Button Classes="link compact"
                                                Content="{Binding SelectedDetailApp.VirusTotalDisplayText}"
                                                IsVisible="{Binding HasSelectedDetailVirusTotal}"
                                                Command="{Binding OpenSelectedDetailVirusTotalCommand}"
                                                HorizontalAlignment="Left"
                                                Padding="0" />
                                    </StackPanel>

                                    <StackPanel Spacing="6">
                                        <TextBlock Text="Install method"
                                                   FontWeight="SemiBold" />
                                        <Border Classes="metaChip">
                                            <TextBlock Text="{Binding SelectedDetailInstallMethodText}"
                                                       Foreground="{DynamicResource TextMutedBrush}"
                                                       TextWrapping="Wrap" />
                                        </Border>
                                    </StackPanel>

                                    <StackPanel Spacing="6">
                                        <TextBlock Text="Selection"
                                                   FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding SelectedDetailApp.IsSelected, StringFormat='Selected: {0}'}"
                                                   Foreground="{DynamicResource TextMutedBrush}" />
                                        <TextBlock Text="{Binding SelectedDetailApp.IsInstalled, StringFormat='Installed: {0}'}"
                                                   Foreground="{DynamicResource TextMutedBrush}" />
                                        <TextBlock Text="{Binding SelectedDetailApp.RequiresRestartHint, StringFormat='Restart may be required: {0}'}"
                                                   Foreground="{DynamicResource TextMutedBrush}" />
                                    </StackPanel>
                                </StackPanel>
                            </ScrollViewer>

                            <Border Grid.Row="1"
                                    BorderBrush="{DynamicResource CardBorderBrush}"
                                    BorderThickness="0,1,0,0"
                                    Padding="0,12,0,0">
                                <Button Classes="primary"
                                        Content="{Binding SelectedDetailPrimaryActionText}"
                                        Command="{Binding SelectedDetailPrimaryActionCommand}"
                                        CommandParameter="{Binding SelectedDetailApp}"
                                        IsEnabled="{Binding IsSelectedDetailPrimaryActionEnabled}"
                                        HorizontalAlignment="Stretch" />
                            </Border>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>
        </Border>
                    <Grid Classes="settingsOverlay" Classes.isOpen="{Binding IsSettingsPanelOpen}" Grid.RowSpan="3" ZIndex="100">
                        <Grid.Styles>
                            <!-- The semi-transparent backdrop and overall HitTest rules -->
                            <Style Selector="Grid.settingsOverlay">
                                <Setter Property="IsHitTestVisible" Value="False" />
                                <Setter Property="Opacity" Value="0" />
                                <Setter Property="Transitions">
                                    <Transitions>
                                        <DoubleTransition Property="Opacity" Duration="0:0:0.2" Easing="SineEaseInOut" />
                                    </Transitions>
                                </Setter>
                            </Style>
                            <Style Selector="Grid.settingsOverlay.isOpen">
                                <Setter Property="IsHitTestVisible" Value="True" />
                                <Setter Property="Opacity" Value="1" />
                            </Style>

                            <!-- The inner Card slide & scale animation -->
                            <Style Selector="Grid.settingsOverlay > Border.card">
                                <Setter Property="RenderTransform" Value="scale(0.96) translateY(12px)" />
                                <Setter Property="Transitions">
                                    <Transitions>
                                        <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.35" Easing="CubicEaseOut" />
                                    </Transitions>
                                </Setter>
                            </Style>
                            <Style Selector="Grid.settingsOverlay.isOpen > Border.card">
                                <Setter Property="RenderTransform" Value="scale(1) translateY(0px)" />
                            </Style>
                        </Grid.Styles>

                        <Border Background="#A0000000" CornerRadius="12" />
                        <Border Classes="card"
                                Width="680"
                                Height="580"
                                CornerRadius="16"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Padding="18"
                                Background="{DynamicResource CardBrush}"
                                BorderBrush="{DynamicResource CardBorderBrush}"
                                BoxShadow="0 16 64 0 #80000000">
                            <Grid RowDefinitions="Auto,*" RowSpacing="0">
                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10" Margin="0,0,0,16">
                                    <StackPanel Spacing="2">
                                        <TextBlock Text="Preferences"
                                                   FontSize="20"
                                                   FontWeight="SemiBold" />
                                        <TextBlock Text="Persistent app behavior, downloads, and advanced options."
                                                   Foreground="{DynamicResource TextMutedBrush}"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                    <Button Grid.Column="1"
                                            Classes="closeIcon"
                                            Command="{Binding ToggleSettingsPanelCommand}"
                                            VerticalAlignment="Top">
                                        <Viewbox Width="14"
                                                 Height="14">
                                            <Path Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                                  Data="M19,6.41L17.59,5L12,10.59L6.41,5L5,6.41L10.59,12L5,17.59L6.41,19L12,13.41L17.59,19L19,17.59L13.41,12L19,6.41Z" />
                                        </Viewbox>
                                    </Button>
                                </Grid>
                                
                                <Border Grid.Row="0" Height="1" Background="{DynamicResource CardBorderBrush}" Margin="-18,0,-18,0" VerticalAlignment="Bottom" />

                                <ScrollViewer Grid.Row="1"
                                          VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled">
                                <Grid ColumnDefinitions="*,*" ColumnSpacing="32" Margin="0,16,0,0">
                                    
                                    <!-- Left Column -->
                                    <StackPanel Spacing="24">
                                        
                                        <!-- Installation Group -->
                                        <StackPanel Spacing="10">
                                            <TextBlock Text="Installation" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}" Margin="4,0,0,0" />
                                            <Border Background="{DynamicResource ShellBackgroundBrush}" CornerRadius="12" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1" Padding="16">
                                                <StackPanel Spacing="16">
                                                    <StackPanel Spacing="0">
                                                        <CheckBox IsChecked="{Binding Settings.SilentInstall}" Content="Silent installation" />
                                                        <TextBlock Text="Install apps silently when possible." FontSize="12" Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap" Margin="24,2,0,0" />
                                                    </StackPanel>
                                                    <Border Height="1" Background="{DynamicResource CardBorderBrush}" Margin="-16,0" />
                                                    <StackPanel Spacing="0">
                                                        <CheckBox IsChecked="{Binding Settings.ParallelInstall}" Content="Install apps simultaneously" />
                                                        <TextBlock Text="Speeds up setup by running installers together." FontSize="12" Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap" Margin="24,2,0,0" />
                                                    </StackPanel>
                                                    <Border Height="1" Background="{DynamicResource CardBorderBrush}" Margin="-16,0" />
                                                    <StackPanel Spacing="0">
                                                        <CheckBox IsChecked="{Binding Settings.SelfDeleteAfterInstall}" Content="Self-delete after install" />
                                                        <TextBlock Text="Remove NovaSetup after finishing." FontSize="12" Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap" Margin="24,2,0,0" />
                                                    </StackPanel>
                                                    <Border Height="1" Background="{DynamicResource CardBorderBrush}" Margin="-16,0" />
                                                    <StackPanel Spacing="6" Margin="0,4,0,0">
                                                        <TextBlock Text="Restart behavior" FontWeight="Medium" />
                                                        <ComboBox ItemsSource="{Binding RestartBehaviorOptions}" SelectedItem="{Binding SelectedRestartBehaviorOption}" HorizontalAlignment="Stretch">
                                                            <ComboBox.ItemTemplate>
                                                                <DataTemplate><TextBlock Text="{Binding Label}" /></DataTemplate>
                                                            </ComboBox.ItemTemplate>
                                                        </ComboBox>
                                                    </StackPanel>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>

                                        <!-- App List Group -->
                                        <StackPanel Spacing="10">
                                            <TextBlock Text="App List" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}" Margin="4,0,0,0" />
                                            <Border Background="{DynamicResource ShellBackgroundBrush}" CornerRadius="12" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1" Padding="16">
                                                <StackPanel Spacing="16">
                                                    <StackPanel Spacing="0">
                                                        <CheckBox IsChecked="{Binding Settings.OsSupportedApps}" Content="OS supported apps" />
                                                        <TextBlock Text="Only show apps compatible with Windows." FontSize="12" Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap" Margin="24,2,0,0" />
                                                    </StackPanel>
                                                    <Border Height="1" Background="{DynamicResource CardBorderBrush}" Margin="-16,0" />
                                                    <StackPanel Spacing="0">
                                                        <CheckBox IsChecked="{Binding Settings.ShowAlreadyInstalledApps}" Content="Show already installed apps" />
                                                        <TextBlock Text="Include software you already have." FontSize="12" Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap" Margin="24,2,0,0" />
                                                    </StackPanel>
                                                    <Border Height="1" Background="{DynamicResource CardBorderBrush}" Margin="-16,0" />
                                                    <StackPanel Spacing="0">
                                                        <CheckBox IsChecked="{Binding Settings.AutoDetectInstalledAppsOnStartup}" Content="Scan PC on startup" />
                                                        <TextBlock Text="Auto-detect existing apps." FontSize="12" Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap" Margin="24,2,0,0" />
                                                    </StackPanel>
                                                    <Border Height="1" Background="{DynamicResource CardBorderBrush}" Margin="-16,0" />
                                                    <StackPanel Spacing="0">
                                                        <CheckBox IsChecked="{Binding Settings.AutoSelectDrivers}" Content="Automatically select drivers" />
                                                        <TextBlock Text="Allow hardware detection to select driver recommendations." FontSize="12" Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap" Margin="24,2,0,0" />
                                                    </StackPanel>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>

                                        <!-- Downloads Group -->
                                        <StackPanel Spacing="10">
                                            <TextBlock Text="Downloads" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}" Margin="4,0,0,0" />
                                            <Border Background="{DynamicResource ShellBackgroundBrush}" CornerRadius="12" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1" Padding="16">
                                                <StackPanel Spacing="16">
                                                    <StackPanel Spacing="6">
                                                        <TextBlock Text="Download location" FontWeight="Medium" />
                                                        <ComboBox ItemsSource="{Binding DownloadLocationOptions}" SelectedItem="{Binding SelectedDownloadLocationOption}" HorizontalAlignment="Stretch">
                                                            <ComboBox.ItemTemplate>
                                                                <DataTemplate><TextBlock Text="{Binding Label}" /></DataTemplate>
                                                            </ComboBox.ItemTemplate>
                                                        </ComboBox>
                                                    </StackPanel>
                                                    <StackPanel Spacing="6" IsVisible="{Binding IsCustomDownloadFolderVisible}">
                                                        <TextBlock Text="Custom folder path" FontWeight="Medium" />
                                                        <TextBox Watermark="e.g. C:\Downloads" Text="{Binding Settings.CustomDownloadFolder}" />
                                                    </StackPanel>
                                                    <Border Height="1" Background="{DynamicResource CardBorderBrush}" Margin="-16,0" />
                                                    <StackPanel Spacing="6">
                                                        <TextBlock Text="Portable apps folder" FontWeight="Medium" />
                                                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                                            <TextBox Text="{Binding Settings.DefaultPortableFolder}"
                                                                     IsReadOnly="True" />
                                                            <Button Grid.Column="1"
                                                                    Content="Browse"
                                                                    Command="{Binding BrowsePortableFolderCommand}" />
                                                        </Grid>
                                                    </StackPanel>
                                                    <Border Height="1" Background="{DynamicResource CardBorderBrush}" Margin="-16,0" />
                                                    <StackPanel Spacing="0">
                                                        <CheckBox IsChecked="{Binding Settings.AllowScriptExecution}" Content="Allow pre/post install scripts" />
                                                        <TextBlock Text="Only enable this if you trust the apps.json source. Scripts run with your user permissions."
                                                                   FontSize="12"
                                                                   Foreground="{DynamicResource TextMutedBrush}"
                                                                   TextWrapping="Wrap"
                                                                   Margin="24,2,0,0" />
                                                    </StackPanel>
                                                    <Border Height="1" Background="{DynamicResource CardBorderBrush}" Margin="-16,0" />
                                                    <StackPanel Spacing="0">
                                                        <CheckBox IsChecked="{Binding Settings.KeepInstallersAfterInstall}" Content="Keep installer files" />
                                                        <TextBlock Text="Don't delete installers from disk." FontSize="12" Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap" Margin="24,2,0,0" />
                                                    </StackPanel>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- Right Column -->
                                    <StackPanel Grid.Column="1" Spacing="24">
                                        
                                        <!-- System Group -->
                                        <StackPanel Spacing="10">
                                            <TextBlock Text="System" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}" Margin="4,0,0,0" />
                                            <Border Background="{DynamicResource ShellBackgroundBrush}" CornerRadius="12" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1" Padding="16">
                                                <StackPanel Spacing="16">
                                                    <StackPanel Spacing="0">
                                                        <CheckBox IsChecked="{Binding Settings.LaunchNovaAtStartup}" Content="Launch at startup" />
                                                        <TextBlock Text="Open NovaSetup automatically." FontSize="12" Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap" Margin="24,2,0,0" />
                                                    </StackPanel>
                                                    <Border Height="1" Background="{DynamicResource CardBorderBrush}" Margin="-16,0" />
                                                    <StackPanel Spacing="0">
                                                        <CheckBox IsChecked="{Binding Settings.CheckForUpdatesAutomatically}" Content="Check for updates" />
                                                        <TextBlock Text="Show a banner when updates exist." FontSize="12" Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap" Margin="24,2,0,0" />
                                                    </StackPanel>
                                                    <Border Height="1" Background="{DynamicResource CardBorderBrush}" Margin="-16,0" />
                                                    <StackPanel Spacing="10">
                                                        <TextBlock Text="Scheduled Updates" FontWeight="Medium" />
                                                        <StackPanel Spacing="0">
                                                            <CheckBox IsChecked="{Binding Settings.ScheduledUpdatesEnabled}" Content="Enable scheduled updates" />
                                                            <TextBlock Text="Register a Windows Task Scheduler task to update apps on a schedule." FontSize="12" Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap" Margin="24,2,0,0" />
                                                        </StackPanel>
                                                        <StackPanel Spacing="12" Margin="24,4,0,0" IsEnabled="{Binding AreScheduledUpdateControlsEnabled}">
                                                            <StackPanel Spacing="6">
                                                                <TextBlock Text="Frequency" FontWeight="Medium" />
                                                                <ComboBox ItemsSource="{Binding ScheduledUpdateFrequencyOptions}" SelectedItem="{Binding SelectedScheduledUpdateFrequencyOption}" HorizontalAlignment="Stretch">
                                                                    <ComboBox.ItemTemplate>
                                                                        <DataTemplate><TextBlock Text="{Binding Label}" /></DataTemplate>
                                                                    </ComboBox.ItemTemplate>
                                                                </ComboBox>
                                                            </StackPanel>
                                                            <StackPanel Spacing="6">
                                                                <TextBlock Text="Run at hour" FontWeight="Medium" />
                                                                <ComboBox ItemsSource="{Binding ScheduledUpdateHourOptions}" SelectedItem="{Binding SelectedScheduledUpdateHourOption}" HorizontalAlignment="Stretch">
                                                                    <ComboBox.ItemTemplate>
                                                                        <DataTemplate><TextBlock Text="{Binding Label}" /></DataTemplate>
                                                                    </ComboBox.ItemTemplate>
                                                                </ComboBox>
                                                            </StackPanel>
                                                            <StackPanel Spacing="6" IsVisible="{Binding IsScheduledUpdateWeeklyVisible}">
                                                                <TextBlock Text="Run on" FontWeight="Medium" />
                                                                <ComboBox ItemsSource="{Binding ScheduledUpdateDayOptions}" SelectedItem="{Binding SelectedScheduledUpdateDayOption}" HorizontalAlignment="Stretch">
                                                                    <ComboBox.ItemTemplate>
                                                                        <DataTemplate><TextBlock Text="{Binding Label}" /></DataTemplate>
                                                                    </ComboBox.ItemTemplate>
                                                                </ComboBox>
                                                            </StackPanel>
                                                            <StackPanel Spacing="0">
                                                                <CheckBox IsChecked="{Binding Settings.RunMissedUpdatesASAP}" Content="Run missed updates as soon as possible" />
                                                                <TextBlock Text="If the PC was off at the scheduled time, run the task on the next opportunity." FontSize="12" Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap" Margin="24,2,0,0" />
                                                            </StackPanel>
                                                            <TextBlock Text="{Binding ScheduledUpdatesLastRunText, StringFormat=Last run: {0}}" FontSize="12" Foreground="{DynamicResource TextMutedBrush}" />
                                                            <TextBlock Text="{Binding ScheduledUpdatesNextRunText, StringFormat=Next scheduled run: {0}}" FontSize="12" Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap" />
                                                            <TextBlock Text="{Binding ScheduledUpdateTaskSchedulerStatusText, StringFormat=Task Scheduler status: {0}}" FontSize="12" Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap" />
                                                            <Button Content="Run Now" Command="{Binding RunScheduledUpdatesNowCommand}" HorizontalAlignment="Left" />
                                                        </StackPanel>
                                                    </StackPanel>
                                                    <Border Height="1" Background="{DynamicResource CardBorderBrush}" Margin="-16,0" />
                                                    <StackPanel Spacing="6">
                                                        <TextBlock Text="Appearance" FontWeight="Medium" />
                                                        <ComboBox ItemsSource="{Binding ThemeOptions}" SelectedItem="{Binding SelectedThemeOption}" HorizontalAlignment="Stretch">
                                                            <ComboBox.ItemTemplate>
                                                                <DataTemplate><TextBlock Text="{Binding Label}" /></DataTemplate>
                                                            </ComboBox.ItemTemplate>
                                                        </ComboBox>
                                                    </StackPanel>
                                                    <StackPanel Spacing="6">
                                                        <TextBlock Text="Language" FontWeight="Medium" />
                                                        <ComboBox ItemsSource="{Binding LanguageOptions}" SelectedItem="{Binding SelectedLanguageOption}" HorizontalAlignment="Stretch">
                                                            <ComboBox.ItemTemplate>
                                                                <DataTemplate><TextBlock Text="{Binding Label}" /></DataTemplate>
                                                            </ComboBox.ItemTemplate>
                                                        </ComboBox>
                                                    </StackPanel>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>

                                        <!-- Data Group -->
                                        <StackPanel Spacing="10">
                                            <TextBlock Text="Data" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}" Margin="4,0,0,0" />
                                            <Border Background="{DynamicResource ShellBackgroundBrush}" CornerRadius="12" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1" Padding="16">
                                                <StackPanel Spacing="0">
                                                    <CheckBox IsChecked="{Binding Settings.SaveProfilesAutomatically}" Content="Auto-save profiles" />
                                                    <TextBlock Text="Keep your NovaSetup lists saved." FontSize="12" Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap" Margin="24,2,0,0" />
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>

                                        <!-- Advanced Group -->
                                        <StackPanel Spacing="10">
                                            <TextBlock Text="Advanced" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}" Margin="4,0,0,0" />
                                            <Border Background="{DynamicResource ShellBackgroundBrush}" CornerRadius="12" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1" Padding="16">
                                                <StackPanel Spacing="16">
                                                    <StackPanel Spacing="0">
                                                        <CheckBox IsChecked="{Binding Settings.DeveloperMode}" Content="Developer mode" />
                                                        <TextBlock Text="Show logs and extra debug info." FontSize="12" Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap" Margin="24,2,0,0" />
                                                    </StackPanel>
                                                    <Border Height="1" Background="{DynamicResource CardBorderBrush}" Margin="-16,0" />
                                                    <StackPanel Spacing="8">
                                                        <TextBlock Text="View the application's runtime log file for debugging." FontSize="12" Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap" />
                                                        <Button Content="Open Logs" Command="{Binding OpenLogsFromSettingsCommand}" HorizontalAlignment="Left" />
                                                    </StackPanel>
                                                    <Border Height="1" Background="{DynamicResource CardBorderBrush}" Margin="-16,0" />
                                                    <StackPanel Spacing="8">
                                                        <TextBlock Text="Reset NovaSetup settings to default values." FontSize="12" Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap" />
                                                        <Button Content="Reset Settings" Classes="danger" Command="{Binding ResetSettingsCommand}" HorizontalAlignment="Left" />
                                                    </StackPanel>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                        
                                    </StackPanel>
                                </Grid>
                            </ScrollViewer>
                            </Grid>
                        </Border>
                    </Grid>

    </Grid>
</Window>



