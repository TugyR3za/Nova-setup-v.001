<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="NovaSetup.Views.Controls.HeaderControl"
             x:CompileBindings="False"
             x:Name="Root">
  <Border Background="{DynamicResource PanelBrush}"
          BorderBrush="#0DFFFFFF"
          BorderThickness="0,0,0,1"
          BoxShadow="0 4 12 0 #4D000000"
          Padding="24,14,24,6"
          Margin="-14,-14,-14,0">
    <StackPanel Spacing="2">
      <TextBlock Text="{Binding #Root.Title}"
                 FontSize="23"
                 FontWeight="Bold"
                 TextWrapping="Wrap" />
      <TextBlock Text="{Binding #Root.Subtitle}"
                 FontSize="14"
                 Foreground="{DynamicResource TextMutedBrush}"
                 TextWrapping="Wrap" />
    </StackPanel>
  </Border>
</UserControl>
