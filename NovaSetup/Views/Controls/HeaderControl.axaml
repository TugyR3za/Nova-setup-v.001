<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="NovaSetup.Views.Controls.HeaderControl"
             x:CompileBindings="False"
             x:Name="Root">
  <Grid ColumnDefinitions="*,Auto"
        ColumnSpacing="12">
    <StackPanel Spacing="2">
      <TextBlock Text="{Binding #Root.Title}"
                 FontSize="23"
                 FontWeight="Bold"
                 TextWrapping="Wrap" />
      <TextBlock Text="{Binding #Root.Subtitle}"
                 FontSize="14"
                 Foreground="{DynamicResource TextMutedBrush}"
                 TextWrapping="Wrap" />
    </StackPanel>

    <Grid Grid.Column="1"
          ColumnDefinitions="*,Auto"
          ColumnSpacing="8"
          VerticalAlignment="Top">
      <ScrollViewer HorizontalScrollBarVisibility="Auto"
                    VerticalScrollBarVisibility="Disabled"
                    MaxWidth="620">
        <StackPanel Orientation="Horizontal" Spacing="8">
          <Border Classes="metaChip">
            <TextBlock Text="{Binding #Root.ProfileName, StringFormat='Profile: {0}'}"
                       FontSize="12"
                       Foreground="{DynamicResource TextMutedBrush}" />
          </Border>
          <Border Classes="metaChip">
            <TextBlock Text="{Binding #Root.SelectedCount, StringFormat='Selected: {0}'}"
                       FontSize="12"
                       Foreground="{DynamicResource TextMutedBrush}" />
          </Border>
          <Border Classes="metaChip"
                  IsVisible="{Binding #Root.HasRecommendedApps}">
            <TextBlock Text="{Binding #Root.RecommendedCount, StringFormat='Recommended: {0}'}"
                       FontSize="12"
                       Foreground="{DynamicResource TextMutedBrush}" />
          </Border>
          <Border Classes="metaChip">
            <TextBlock Text="{Binding #Root.CurrentPlatform, StringFormat='OS: {0}'}"
                       FontSize="12"
                       Foreground="{DynamicResource TextMutedBrush}" />
          </Border>
        </StackPanel>
      </ScrollViewer>

      <StackPanel Grid.Column="1"
                  Orientation="Horizontal"
                  Spacing="8">
        <Button Classes="icon ghost"
                Command="{Binding #Root.RefreshCatalogCommand}"
                ToolTip.Tip="Refresh catalog and app state">
          <Viewbox Width="18" Height="18">
            <Path Data="{DynamicResource IconRefreshGeometry}"
                  Fill="{DynamicResource TextSecondaryBrush}" />
          </Viewbox>
        </Button>

        <Button Classes="icon ghost"
                Command="{Binding #Root.HelpCommand}">
          <Viewbox Width="18" Height="18">
            <Path Data="{DynamicResource IconHelpGeometry}"
                  Fill="{DynamicResource TextSecondaryBrush}" />
          </Viewbox>
        </Button>
      </StackPanel>
    </Grid>
  </Grid>
</UserControl>
