<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:NovaSetup.Views.Controls"
             xmlns:converters="clr-namespace:NovaSetup.Views.Converters"
             x:Class="NovaSetup.Views.Controls.AppRowControl"
             x:CompileBindings="False"
             x:Name="Root">
  <UserControl.Resources>
    <converters:StatusTextToToneConverter x:Key="StatusTextToToneConverter" />
    <converters:StringHasValueConverter x:Key="StringHasValueConverter" />
    <converters:VirusTotalRatioToBrushConverter x:Key="VirusTotalRatioToBrushConverter" />
    <converters:AppInstallActionTextConverter x:Key="AppInstallActionTextConverter" />
  </UserControl.Resources>

  <Border Classes="rowCard"
          Classes.selected="{Binding #Root.Item.IsSelected}"
          Opacity="{Binding #Root.Item.RowOpacity}"
          HorizontalAlignment="Stretch"
          ClipToBounds="True">
    <Border.ContextMenu>
      <ContextMenu DataContext="{Binding #Root}">
        <MenuItem Header="Install"
                  IsVisible="{Binding Item.CanInstallFromContextMenu}"
                  Command="{Binding InstallAppCommand}"
                  CommandParameter="{Binding Item}" />
        <MenuItem Header="Update"
                  IsVisible="{Binding Item.HasUpdateAvailable}"
                  Command="{Binding UpdateAppCommand}"
                  CommandParameter="{Binding Item}" />
        <MenuItem Header="Uninstall"
                  IsVisible="{Binding Item.IsInstalled}"
                  Command="{Binding UninstallCommand}"
                  CommandParameter="{Binding Item}" />
        <Separator />
        <MenuItem Header="Open install location"
                  IsVisible="{Binding Item.IsInstalled}"
                  Command="{Binding OpenInstallLocationCommand}"
                  CommandParameter="{Binding Item}" />
        <MenuItem Header="Open homepage"
                  IsVisible="{Binding Item.HasHomepageLink}"
                  Command="{Binding OpenPublisherCommand}"
                  CommandParameter="{Binding Item}" />
        <MenuItem Header="Copy app name"
                  Command="{Binding CopyToClipboardCommand}"
                  CommandParameter="{Binding Item.Name}" />
        <Separator />
        <MenuItem Header="{Binding Item.SilentInstallPreferenceMenuText}"
                  Command="{Binding ToggleSilentInstallPreferenceCommand}"
                  CommandParameter="{Binding Item}" />
        <MenuItem Header="{Binding Item.UpdateScanningPreferenceMenuText}"
                  Command="{Binding ToggleScanningPreferenceCommand}"
                  CommandParameter="{Binding Item}" />
        <MenuItem Header="{Binding Item.InstallScriptsPreferenceMenuText}"
                  IsVisible="{Binding Item.HasInstallScripts}"
                  Command="{Binding ToggleInstallScriptsPreferenceCommand}"
                  CommandParameter="{Binding Item}" />
      </ContextMenu>
    </Border.ContextMenu>
    <Grid ColumnDefinitions="36,*,60,90,90,44"
          ColumnSpacing="8"
          ClipToBounds="True">
      <CheckBox Classes="appCheck"
                IsChecked="{Binding #Root.Item.IsSelected}"
                IsEnabled="{Binding #Root.Item.IsSupportedOnCurrentPlatform}"
                IsVisible="{Binding #Root.SelectionEnabled}"
                VerticalAlignment="Center"
                HorizontalAlignment="Center" />

      <Grid Grid.Column="1"
            ColumnDefinitions="36,*"
            ColumnSpacing="8"
            MinWidth="0"
            ClipToBounds="True">
        <controls:AppLogoControl LogoUrl="{Binding #Root.Item.LogoUrl}"
                                 FallbackGlyph="{Binding #Root.Item.IconGlyph}"
                                 LogoSize="32"
                                 VerticalAlignment="Center" />

        <StackPanel Grid.Column="1"
                    Spacing="1"
                    MinWidth="0"
                    ClipToBounds="True">
          <Grid ColumnDefinitions="*,Auto,Auto"
                ColumnSpacing="6"
                ClipToBounds="True">
            <TextBlock Text="{Binding #Root.Item.Name}"
                       FontSize="15"
                       FontWeight="SemiBold"
                       TextWrapping="NoWrap"
                       TextTrimming="CharacterEllipsis" />
            <Border Grid.Column="1"
                    IsVisible="{Binding #Root.Item.IsRecommended}"
                    Background="{DynamicResource RecommendedBadgeBrush}"
                    CornerRadius="7"
                    Padding="6,2">
              <TextBlock Text="Recommended"
                         FontSize="10" />
            </Border>
            <Border Grid.Column="2"
                    IsVisible="{Binding #Root.Item.ShowArmIndicator}"
                    Background="{DynamicResource AccentSoftBrush}"
                    BorderBrush="{DynamicResource AccentBrush}"
                    BorderThickness="1"
                    CornerRadius="7"
                    Padding="6,2">
              <TextBlock Text="{Binding #Root.Item.ArmIndicatorText}"
                         Foreground="{DynamicResource AccentBrush}"
                         FontSize="10" />
            </Border>
          </Grid>

          <Grid ColumnDefinitions="Auto,*,Auto"
                ColumnSpacing="8"
                ClipToBounds="True">
            <TextBlock Text="{Binding #Root.Item.Category}"
                       Foreground="{DynamicResource TextMutedBrush}"
                       Opacity="0.5"
                       FontSize="12"
                       TextWrapping="NoWrap"
                       TextTrimming="CharacterEllipsis"
                       VerticalAlignment="Center" />
            <Button Grid.Column="1"
                    Classes="link"
                    Command="{Binding #Root.OpenPublisherCommand}"
                    CommandParameter="{Binding #Root.Item}"
                    Opacity="0.75"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Left">
              <TextBlock Text="{Binding #Root.Item.PublisherName}"
                         Foreground="{DynamicResource LinkBrush}"
                         TextWrapping="NoWrap"
                         TextTrimming="CharacterEllipsis" />
            </Button>
            <Button x:Name="PreferencesButton"
                    Grid.Column="2"
                    Classes="link compact detailsBtn"
                    IsVisible="{Binding #Root.Item.CanShowPreferencesButton}"
                    Content="Prefs"
                    HorizontalAlignment="Right"
                    Click="PreferencesButton_OnClick" />
          </Grid>
        </StackPanel>
      </Grid>

      <TextBlock Grid.Column="2"
                 Text="~ 20 MB"
                 VerticalAlignment="Center"
                 Foreground="{DynamicResource TextMutedBrush}"
                 Opacity="0.5"
                 TextWrapping="NoWrap"
                 TextTrimming="CharacterEllipsis" />

      <StackPanel Grid.Column="3"
                  Spacing="4"
                  VerticalAlignment="Center"
                  ClipToBounds="True">
        <controls:StatusPillControl Text="{Binding #Root.Item.StatusBadge}"
                                    MaxWidth="90"
                                    Tone="{Binding #Root.Item.StatusBadge, Converter={StaticResource StatusTextToToneConverter}}" />
        <Button Classes="link compact"
                Command="{Binding #Root.OpenPublisherCommand}"
                CommandParameter="{Binding #Root.Item.CurrentVirusTotalUrl}"
                HorizontalAlignment="Left"
                Padding="0"
                IsVisible="{Binding #Root.Item.VirusTotalDisplayText, Converter={StaticResource StringHasValueConverter}}"
                ToolTip.Tip="VirusTotal scan result. The ratio shows detections vs. engines scanned (e.g. 0/17 means 0 detections out of 17 antivirus engines). Click to view the full report.">
          <TextBlock Text="{Binding #Root.Item.VirusTotalDisplayText}"
                     FontSize="11"
                     Foreground="{Binding #Root.Item.CurrentVirusTotalRatio, Converter={StaticResource VirusTotalRatioToBrushConverter}}"
                     TextWrapping="NoWrap"
                     TextTrimming="CharacterEllipsis" />
        </Button>
        <ProgressBar Minimum="0"
                     Maximum="1"
                     Height="4"
                     Value="{Binding #Root.Item.DownloadProgress}"
                     Background="{DynamicResource InputBrush}"
                     Foreground="{DynamicResource AccentBrush}"
                     IsVisible="{Binding #Root.Item.IsDownloading}" />
        <TextBlock Text="{Binding #Root.Item.DownloadProgressText}"
                   FontSize="11"
                   Foreground="{DynamicResource TextMutedBrush}"
                   TextWrapping="NoWrap"
                   TextTrimming="CharacterEllipsis"
                   IsVisible="{Binding #Root.Item.DownloadProgressText, Converter={StaticResource StringHasValueConverter}}" />
      </StackPanel>

      <Grid Grid.Column="4"
            ClipToBounds="True">
        <Button Classes="ghost compact"
                IsVisible="{Binding #Root.Item.CanShowInstallActionButton}"
                Content="{Binding #Root.Item, Converter={StaticResource AppInstallActionTextConverter}}"
                Command="{Binding #Root.InstallAppCommand}"
                CommandParameter="{Binding #Root.Item}"
                HorizontalAlignment="Left"
                MinWidth="64"
                MaxWidth="90" />
        <Button Classes="ghost compact"
                IsVisible="{Binding #Root.Item.IsCancellable}"
                Content="Cancel"
                Command="{Binding #Root.Item.CancelCommand}"
                HorizontalAlignment="Left"
                MinWidth="64"
                MaxWidth="90" />
      </Grid>

      <Grid Grid.Column="5"
            ClipToBounds="True">
        <Button Classes="ghost compact detailsBtn"
                Width="44"
                HorizontalAlignment="Left"
                Command="{Binding #Root.ShowAppDetailsCommand}"
                CommandParameter="{Binding #Root.Item}">
          <Viewbox Width="16" Height="16">
            <Path Data="{DynamicResource IconOverflowGeometry}"
                  Fill="{DynamicResource TextSecondaryBrush}" />
          </Viewbox>
        </Button>

        <Popup IsOpen="{Binding #Root.IsPreferencesMenuOpen, Mode=TwoWay}"
               PlacementTarget="{Binding #PreferencesButton}"
               Placement="Bottom"
               HorizontalOffset="-4"
               VerticalOffset="8"
               IsLightDismissEnabled="True"
               Closed="PreferencesPopup_OnClosed">
          <Border Classes="accountMenuPopup"
                  MinWidth="190">
            <StackPanel Spacing="8">
              <TextBlock Text="App preferences"
                         FontWeight="SemiBold" />
              <CheckBox IsChecked="{Binding #Root.Item.SilentInstallEnabled}"
                        Content="Silent install" />
              <CheckBox IsChecked="{Binding #Root.Item.ScanningEnabled}"
                        Content="Scan for updates" />
              <CheckBox IsChecked="{Binding #Root.Item.AutoUpdateEnabled}"
                        Content="Auto-update" />
              <CheckBox IsChecked="{Binding #Root.Item.InstallScriptsEnabled}"
                        IsVisible="{Binding #Root.Item.HasInstallScripts}"
                        Content="Allow install scripts" />
            </StackPanel>
          </Border>
        </Popup>
      </Grid>
    </Grid>
  </Border>
</UserControl>
