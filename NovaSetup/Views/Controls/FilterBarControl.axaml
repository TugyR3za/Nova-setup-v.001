<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="NovaSetup.Views.Controls.FilterBarControl"
             x:CompileBindings="False"
             x:Name="Root">
  <Grid ColumnDefinitions="Auto,Auto,*,Auto,Auto"
        ColumnSpacing="0"
        VerticalAlignment="Center">
    <ScrollViewer HorizontalScrollBarVisibility="Auto"
                  VerticalScrollBarVisibility="Disabled"
                  VerticalAlignment="Center"
                  Margin="4,0">
      <Border Background="{DynamicResource InputBrush}"
              BorderBrush="Transparent"
              BorderThickness="0"
              CornerRadius="10"
              Padding="4"
              HorizontalAlignment="Left">
        <StackPanel Orientation="Horizontal" Spacing="2">
          <RadioButton GroupName="filter" Classes="segmented" IsChecked="{Binding #Root.IsAllFilter, Mode=TwoWay}" Content="All" />
          <RadioButton GroupName="filter" Classes="segmented" IsChecked="{Binding #Root.IsGamesFilter, Mode=TwoWay}" Content="Games" />
          <RadioButton GroupName="filter" Classes="segmented" IsChecked="{Binding #Root.IsDriversFilter, Mode=TwoWay}" Content="Drivers" />
          <RadioButton GroupName="filter" Classes="segmented" IsChecked="{Binding #Root.IsRecommendedFilter, Mode=TwoWay}" Content="Recommended" />
          <RadioButton GroupName="filter" Classes="segmented" IsChecked="{Binding #Root.IsDevToolsFilter, Mode=TwoWay}" Content="Dev Tools" />
          <RadioButton GroupName="filter" Classes="segmented" IsChecked="{Binding #Root.IsUtilitiesFilter, Mode=TwoWay}" Content="Utilities" />
          <RadioButton GroupName="filter"
                       Classes="segmented"
                       IsVisible="{Binding #Root.IsArm64Machine}"
                       IsChecked="{Binding #Root.IsArm64Filter, Mode=TwoWay}"
                       Content="ARM64" />
          <RadioButton GroupName="filter" Classes="segmented" IsChecked="{Binding #Root.IsUpdatesFilter, Mode=TwoWay}" Content="Updates" />
        </StackPanel>
      </Border>
    </ScrollViewer>

    <ComboBox Grid.Column="1"
              MinWidth="120"
              HorizontalAlignment="Left"
              VerticalAlignment="Center"
              Margin="4,0"
              PlaceholderText="All categories"
              ItemsSource="{Binding #Root.AvailableCategories}"
              SelectedItem="{Binding #Root.SelectedCategory, Mode=TwoWay}">
      <ComboBox.ItemTemplate>
        <DataTemplate>
          <TextBlock Text="{Binding .}" />
        </DataTemplate>
      </ComboBox.ItemTemplate>
    </ComboBox>

    <TextBox Grid.Column="2"
             Watermark="Search apps..."
             Text="{Binding #Root.SearchText, Mode=TwoWay}"
             HorizontalAlignment="Stretch"
             VerticalAlignment="Center"
             MinWidth="120"
             Margin="4,0" />

    <Button Grid.Column="3"
            Classes="icon outline"
            Command="{Binding #Root.RefreshCatalogCommand}"
            VerticalAlignment="Center"
            Margin="4,0"
            ToolTip.Tip="Refresh catalog">
      <Viewbox Width="16" Height="16">
        <Path Data="{DynamicResource IconRefreshGeometry}" Fill="{DynamicResource TextSecondaryBrush}" />
      </Viewbox>
    </Button>

    <Button Grid.Column="4"
            Classes="outline icon"
            Command="{Binding #Root.ToggleViewModeCommand}"
            VerticalAlignment="Center"
            Margin="4,0">
      <Panel>
        <TextBlock Text="Grid" IsVisible="{Binding !#Root.IsGridViewActive}" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="11" />
        <TextBlock Text="List" IsVisible="{Binding #Root.IsGridViewActive}" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="11" />
      </Panel>
    </Button>
  </Grid>
</UserControl>
