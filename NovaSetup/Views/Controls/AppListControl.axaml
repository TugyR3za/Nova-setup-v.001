<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:NovaSetup.Views.Controls"
             x:Class="NovaSetup.Views.Controls.AppListControl"
             x:CompileBindings="False"
             x:Name="Root">
  <Grid RowDefinitions="Auto,*"
        HorizontalAlignment="Stretch"
        ClipToBounds="True">
    <Grid ColumnDefinitions="36,*,60,90,90,44"
          Margin="8,0,8,0"
          ColumnSpacing="8">
      <TextBlock Text="Sel"
                 FontWeight="SemiBold"
                 Foreground="{DynamicResource TextMutedBrush}"
                 VerticalAlignment="Center" />
      <TextBlock Grid.Column="1"
                 Text="App"
                 FontWeight="SemiBold"
                 Foreground="{DynamicResource TextMutedBrush}"
                 VerticalAlignment="Center" />
      <TextBlock Grid.Column="2"
                 Text="Size"
                 FontWeight="SemiBold"
                 Foreground="{DynamicResource TextMutedBrush}"
                 VerticalAlignment="Center" />
      <TextBlock Grid.Column="3"
                 Text="Status"
                 FontWeight="SemiBold"
                 Foreground="{DynamicResource TextMutedBrush}"
                 VerticalAlignment="Center" />
      <TextBlock Grid.Column="4"
                 Text="Action"
                 FontWeight="SemiBold"
                 Foreground="{DynamicResource TextMutedBrush}"
                 VerticalAlignment="Center" />
      <TextBlock Grid.Column="5"
                 Text="More"
                 FontWeight="SemiBold"
                 Foreground="{DynamicResource TextMutedBrush}"
                 VerticalAlignment="Center" />
    </Grid>

    <ScrollViewer Grid.Row="1"
                  VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  Margin="0,8,0,0">
      <ItemsControl ItemsSource="{Binding #Root.Items}"
                    HorizontalAlignment="Stretch">
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <controls:AppRowControl Item="{Binding .}"
                                    HorizontalAlignment="Stretch"
                                    OpenPublisherCommand="{Binding #Root.OpenPublisherCommand}"
                                    ShowAppDetailsCommand="{Binding #Root.ShowAppDetailsCommand}"
                                    InstallAppCommand="{Binding #Root.InstallAppCommand}"
                                    UpdateAppCommand="{Binding #Root.UpdateAppCommand}"
                                    UninstallCommand="{Binding #Root.UninstallCommand}"
                                    OpenInstallLocationCommand="{Binding #Root.OpenInstallLocationCommand}"
                                    CopyToClipboardCommand="{Binding #Root.CopyToClipboardCommand}"
                                    ToggleSilentInstallPreferenceCommand="{Binding #Root.ToggleSilentInstallPreferenceCommand}"
                                    ToggleScanningPreferenceCommand="{Binding #Root.ToggleScanningPreferenceCommand}" />
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </ScrollViewer>
  </Grid>
</UserControl>
