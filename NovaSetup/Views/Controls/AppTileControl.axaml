<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:NovaSetup.Views.Controls"
             xmlns:converters="clr-namespace:NovaSetup.Views.Converters"
             x:Class="NovaSetup.Views.Controls.AppTileControl"
             x:CompileBindings="False"
             x:Name="Root">
  <UserControl.Resources>
    <converters:StatusTextToToneConverter x:Key="StatusTextToToneConverter" />
  </UserControl.Resources>

  <Border Classes="rowCard"
          Classes.selected="{Binding #Root.Item.IsSelected}"
          Opacity="{Binding #Root.Item.RowOpacity}"
          Width="160" Height="200"
          Margin="0,0,10,10">
    <Grid RowDefinitions="Auto,*,Auto,Auto,Auto,Auto">
      <!-- Top Row: Checkbox & Status -->
      <Grid ColumnDefinitions="Auto,*">
        <CheckBox Classes="appCheck"
                  IsChecked="{Binding #Root.Item.IsSelected}"
                  IsEnabled="{Binding #Root.Item.IsSupportedOnCurrentPlatform}"
                  VerticalAlignment="Top" HorizontalAlignment="Left" />
        <controls:StatusPillControl Grid.Column="1"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Top"
                                    Text="{Binding #Root.Item.StatusBadge}"
                                    Tone="{Binding #Root.Item.StatusBadge, Converter={StaticResource StatusTextToToneConverter}}" />
      </Grid>
      
      <!-- Icon -->
      <controls:AppLogoControl Grid.Row="1"
                               LogoUrl="{Binding #Root.Item.LogoUrl}"
                               FallbackGlyph="{Binding #Root.Item.IconGlyph}"
                               LogoSize="48"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Margin="0,8,0,0" />
      
      <!-- Name -->
      <TextBlock Grid.Row="2"
                 Text="{Binding #Root.Item.Name}"
                 FontSize="14" FontWeight="SemiBold"
                 TextAlignment="Center" TextWrapping="Wrap"
                 MaxLines="2" TextTrimming="CharacterEllipsis"
                 Margin="0,12,0,0" />

      <!-- Category -->
      <TextBlock Grid.Row="3"
                 Text="{Binding #Root.Item.Category}"
                 Foreground="{DynamicResource TextMutedBrush}"
                 FontSize="11" Opacity="0.5"
                 TextAlignment="Center"
                 Margin="0,4,0,0" />

      <!-- Bottom meta row -->
      <Grid Grid.Row="4" ColumnDefinitions="*,Auto" Margin="0,8,0,0">
        <TextBlock Text="~ 20 MB"
                   VerticalAlignment="Center"
                   Foreground="{DynamicResource TextMutedBrush}"
                   FontSize="11" Opacity="0.5" />
        <Button Grid.Column="1"
                Classes="ghost compact detailsBtn"
                Width="32" Height="24" Padding="0"
                Command="{Binding #Root.ShowAppDetailsCommand}"
                CommandParameter="{Binding #Root.Item}">
          <Viewbox Width="14" Height="14">
            <Path Data="{DynamicResource IconOverflowGeometry}" Fill="{DynamicResource TextSecondaryBrush}" />
          </Viewbox>
        </Button>
      </Grid>

      <ProgressBar Grid.Row="5"
                   Minimum="0"
                   Maximum="1"
                   Height="4"
                   Value="{Binding #Root.Item.DownloadProgress}"
                   Background="{DynamicResource InputBrush}"
                   Foreground="{DynamicResource AccentBrush}"
                   IsVisible="{Binding #Root.Item.IsDownloading}"
                   Margin="0,8,0,0" />
    </Grid>
  </Border>
</UserControl>
