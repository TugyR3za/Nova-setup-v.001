<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="NovaSetup.Views.Controls.SidebarControl"
             x:CompileBindings="False"
             x:Name="Root">
  <Border Classes="shellPanel"
          Background="{DynamicResource SidebarBrush}"
          Padding="12">
    <Grid RowDefinitions="Auto,*,Auto"
          RowSpacing="14">
      <Grid ColumnDefinitions="44,*"
            ColumnSpacing="10">
        <Border Width="44"
                Height="44"
                CornerRadius="12"
                Background="{DynamicResource BrandTileBrush}"
                ClipToBounds="True">
          <Image Source="avares://NovaSetup/Assets/nova_logo_512.png"
                 Stretch="UniformToFill" />
        </Border>
        <StackPanel Grid.Column="1"
                    Spacing="0"
                    VerticalAlignment="Center">
          <TextBlock Text="Nova"
                     FontSize="22"
                     FontWeight="Bold" />
          <TextBlock Text="Setup everything fast"
                     FontSize="13"
                     Foreground="{DynamicResource TextMutedBrush}" />
        </StackPanel>
      </Grid>

      <Grid Grid.Row="1">
        <Grid.RowDefinitions>
          <RowDefinition Height="*" />
          <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
          <StackPanel Spacing="6">
            <Button Classes="nav navActive" IsVisible="{Binding #Root.IsDashboardSelected}" Command="{Binding #Root.NavigateDashboardCommand}">
              <Grid ColumnDefinitions="18,*" ColumnSpacing="10">
                <Path Data="{DynamicResource IconDashboardGeometry}" Fill="{DynamicResource TextPrimaryBrush}" Width="16" Height="16" VerticalAlignment="Center" />
                <TextBlock Grid.Column="1" Text="Dashboard" VerticalAlignment="Center" />
              </Grid>
            </Button>
            <Button Classes="nav" IsVisible="{Binding #Root.IsDashboardUnselected}" Command="{Binding #Root.NavigateDashboardCommand}">
              <Grid ColumnDefinitions="18,*" ColumnSpacing="10">
                <Path Data="{DynamicResource IconDashboardGeometry}" Fill="{DynamicResource TextMutedBrush}" Width="16" Height="16" VerticalAlignment="Center" />
                <TextBlock Grid.Column="1" Text="Dashboard" VerticalAlignment="Center" />
              </Grid>
            </Button>

            <Button Classes="nav navActive" IsVisible="{Binding #Root.IsAppsSelected}" Command="{Binding #Root.NavigateAppsCommand}">
              <Grid ColumnDefinitions="18,*" ColumnSpacing="10">
                <Path Data="{DynamicResource IconAppsGeometry}" Fill="{DynamicResource TextPrimaryBrush}" Width="16" Height="16" VerticalAlignment="Center" />
                <TextBlock Grid.Column="1" Text="Apps" VerticalAlignment="Center" />
              </Grid>
            </Button>
            <Button Classes="nav" IsVisible="{Binding #Root.IsAppsUnselected}" Command="{Binding #Root.NavigateAppsCommand}">
              <Grid ColumnDefinitions="18,*" ColumnSpacing="10">
                <Path Data="{DynamicResource IconAppsGeometry}" Fill="{DynamicResource TextMutedBrush}" Width="16" Height="16" VerticalAlignment="Center" />
                <TextBlock Grid.Column="1" Text="Apps" VerticalAlignment="Center" />
              </Grid>
            </Button>

            <Button Classes="nav navActive" IsVisible="{Binding #Root.IsUpdatesSelected}" Command="{Binding #Root.NavigateUpdatesCommand}">
              <Grid ColumnDefinitions="18,*,Auto" ColumnSpacing="10">
                <Path Data="{DynamicResource IconRefreshGeometry}" Fill="{DynamicResource TextPrimaryBrush}" Width="16" Height="16" VerticalAlignment="Center" />
                <TextBlock Grid.Column="1" Text="Updates" VerticalAlignment="Center" />
                <Border Grid.Column="2" Background="{DynamicResource AccentBrush}" CornerRadius="12" Padding="6,2" IsVisible="{Binding #Root.HasUpdatesAvailable}">
                  <TextBlock Text="{Binding #Root.UpdateAvailableCount}" FontSize="11" FontWeight="Bold" Foreground="#FFFFFF" />
                </Border>
              </Grid>
            </Button>
            <Button Classes="nav" IsVisible="{Binding #Root.IsUpdatesUnselected}" Command="{Binding #Root.NavigateUpdatesCommand}">
              <Grid ColumnDefinitions="18,*,Auto" ColumnSpacing="10">
                <Path Data="{DynamicResource IconRefreshGeometry}" Fill="{DynamicResource TextMutedBrush}" Width="16" Height="16" VerticalAlignment="Center" />
                <TextBlock Grid.Column="1" Text="Updates" VerticalAlignment="Center" />
                <Border Grid.Column="2" Background="{DynamicResource CardBorderBrush}" CornerRadius="12" Padding="6,2" IsVisible="{Binding #Root.HasUpdatesAvailable}">
                  <TextBlock Text="{Binding #Root.UpdateAvailableCount}" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" />
                </Border>
              </Grid>
            </Button>
          </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="4" HorizontalAlignment="Center" Margin="0,0,0,8">
          <Button Classes="ghost compact" Command="{Binding #Root.NavigateAboutCommand}" Padding="8,6">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <Path Data="{DynamicResource IconInfoGeometry}" Fill="{DynamicResource TextMutedBrush}" Width="12" Height="12" VerticalAlignment="Center" />
              <TextBlock Text="About" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center" />
            </StackPanel>
          </Button>
          <Button Classes="ghost compact" Command="{Binding #Root.NavigateHistoryCommand}" Padding="8,6">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <Path Data="{DynamicResource IconHistoryGeometry}" Fill="{DynamicResource TextMutedBrush}" Width="12" Height="12" VerticalAlignment="Center" />
              <TextBlock Text="Downloads" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center" />
            </StackPanel>
          </Button>
        </StackPanel>
      </Grid>

      <Grid Grid.Row="2">
        <Border Classes="accountPrimary">
          <Grid ColumnDefinitions="Auto,*,Auto"
                ColumnSpacing="8">
            <Border Width="34"
                    Height="34"
                    CornerRadius="10"
                    Background="{DynamicResource SuccessBrush}"
                    VerticalAlignment="Center">
              <Viewbox Width="16" Height="16">
                <Path Fill="#FFFFFF"
                      Data="{DynamicResource IconProfileGeometry}" />
              </Viewbox>
            </Border>

            <StackPanel Grid.Column="1"
                        Spacing="0"
                        VerticalAlignment="Center">
              <TextBlock Text="My Account"
                         FontSize="14"
                         FontWeight="SemiBold"
                         TextWrapping="NoWrap" />
              <TextBlock Text="{Binding #Root.CurrentProfileName}"
                         Foreground="{DynamicResource TextMutedBrush}"
                         FontSize="11"
                         TextWrapping="NoWrap"
                         TextTrimming="CharacterEllipsis" />
            </StackPanel>

            <Button x:Name="AccountMenuAnchor"
                    Grid.Column="2"
                    Classes="accountArrow"
                    Command="{Binding #Root.ToggleAccountMenuCommand}"
                    VerticalAlignment="Center">
              <Viewbox Width="12"
                       Height="12">
                <Path Fill="{DynamicResource TextMutedBrush}"
                      Data="{DynamicResource IconChevronRightGeometry}" />
              </Viewbox>
            </Button>
          </Grid>
        </Border>

        <Popup IsOpen="{Binding #Root.IsAccountMenuOpen, Mode=TwoWay}"
               PlacementTarget="{Binding #AccountMenuAnchor}"
               Placement="RightEdgeAlignedBottom"
               HorizontalOffset="10"
               VerticalOffset="-8"
               IsLightDismissEnabled="True"
               Closed="AccountMenuPopup_OnClosed">
          <Border Classes="accountMenuPopup"
                  MinWidth="188">
            <StackPanel Spacing="2">
              <Button Classes="accountMenuItem"
                      Command="{Binding #Root.OpenAccountProfileCommand}">
                <StackPanel Orientation="Horizontal"
                            Spacing="10">
                  <Viewbox Width="14" Height="14">
                    <Path Fill="{DynamicResource TextMutedBrush}"
                          Data="{DynamicResource IconMyListsGeometry}" />
                  </Viewbox>
                  <TextBlock Text="Profile" />
                </StackPanel>
              </Button>

              <Button Classes="accountMenuItem"
                      Command="{Binding #Root.OpenAccountSettingsCommand}">
                <StackPanel Orientation="Horizontal"
                            Spacing="10">
                  <Viewbox Width="14" Height="14">
                    <Path Fill="{DynamicResource TextMutedBrush}"
                          Data="{DynamicResource IconSettingsGeometry}" />
                  </Viewbox>
                  <TextBlock Text="Settings" />
                </StackPanel>
              </Button>

              <Button Classes="accountMenuItem"
                      IsEnabled="False">
                <StackPanel Orientation="Horizontal"
                            Spacing="10">
                  <Viewbox Width="14" Height="14">
                    <Path Fill="{DynamicResource TextMutedBrush}"
                          Data="{DynamicResource IconSignOutGeometry}" />
                  </Viewbox>
                  <TextBlock Text="Sign Out"
                             Foreground="{DynamicResource TextMutedBrush}" />
                </StackPanel>
              </Button>
            </StackPanel>
          </Border>
        </Popup>
      </Grid>
    </Grid>
  </Border>
</UserControl>
