<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="NovaSetup.Views.SplashScreen"
        x:CompileBindings="False"
        Width="440"
        Height="300"
        CanResize="False"
        WindowStartupLocation="CenterScreen"
        SystemDecorations="None"
        Topmost="True"
        Background="Transparent"
        TransparencyLevelHint="Transparent"
        Foreground="{DynamicResource TextPrimaryBrush}"
        ShowInTaskbar="False">
  
  <Border Margin="24"
          Background="{DynamicResource ElevatedCardBrush}"
          BorderBrush="{DynamicResource CardBorderBrush}"
          BorderThickness="1"
          CornerRadius="20"
          Padding="30"
          BoxShadow="0 12 36 0 #40000000">
    <Grid RowDefinitions="*,Auto,Auto"
          RowSpacing="16">
      
      <StackPanel Spacing="14"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Center">
        <Image Source="avares://NovaSetup/Assets/nova_logo_512.png"
               Width="80"
               Height="80"
               Stretch="Uniform"
               HorizontalAlignment="Center" />
               
        <TextBlock Text="Nova"
                   FontSize="28"
                   FontWeight="Bold"
                   HorizontalAlignment="Center" />
      </StackPanel>
      
      <StackPanel Grid.Row="1" Spacing="10" Margin="0,10,0,0">
          <TextBlock x:Name="StatusTextBlock"
                     Text="Preparing your setup..."
                     FontSize="13"
                     Foreground="{DynamicResource TextSecondaryBrush}"
                     HorizontalAlignment="Center" />
          <ProgressBar Height="6"
                       CornerRadius="3"
                       IsIndeterminate="True"
                       Background="{DynamicResource InputBrush}"
                       Foreground="{DynamicResource AccentBrush}" />
      </StackPanel>

      <TextBlock x:Name="VersionTextBlock"
                 Grid.Row="2"
                 Text="Nova vUnknown"
                 FontSize="11"
                 Foreground="{DynamicResource TextMutedBrush}"
                 HorizontalAlignment="Right" />
    </Grid>
  </Border>
</Window>
