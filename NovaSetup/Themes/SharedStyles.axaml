<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Style Selector="TextBlock">
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    <Setter Property="FontFamily" Value="Segoe UI Variable Text, Segoe UI, Inter, Arial" />
  </Style>

  <Style Selector="Border.shellPanel">
    <Setter Property="BorderBrush" Value="{DynamicResource ShellBorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="24" />
    <Setter Property="BoxShadow" Value="0 4 16 0 rgba(0, 0, 0, 0.08)" />
  </Style>

  <Style Selector="Border.card">
    <Setter Property="Background" Value="{DynamicResource CardBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="18" />
    <Setter Property="Padding" Value="12" />
    <Setter Property="BoxShadow" Value="0 2 8 0 rgba(0, 0, 0, 0.08)" />
  </Style>

  <Style Selector="Border.rowCard">
    <Setter Property="Background" Value="{DynamicResource ElevatedCardBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="14" />
    <Setter Property="Padding" Value="8" />
    <Setter Property="Margin" Value="0,0,0,6" />
    <Setter Property="BoxShadow" Value="0 1 4 0 rgba(0, 0, 0, 0.05)" />
  </Style>

  <Style Selector="Border.metaChip">
    <Setter Property="Background" Value="{DynamicResource InputBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource InputBorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="999" />
    <Setter Property="Padding" Value="10,5" />
  </Style>

  <Style Selector="TextBox">
    <Setter Property="Background" Value="{DynamicResource InputBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource InputBorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    <Setter Property="CornerRadius" Value="12" />
    <Setter Property="Padding" Value="11,7" />
  </Style>

  <Style Selector="TextBox:pointerover">
    <Setter Property="Background" Value="{DynamicResource HoverSurfaceBrush}" />
  </Style>

  <Style Selector="TextBox:focus">
    <Setter Property="BorderBrush" Value="{DynamicResource FocusBrush}" />
    <Setter Property="BorderThickness" Value="1.5" />
  </Style>

  <Style Selector="ComboBox">
    <Setter Property="Background" Value="{DynamicResource InputBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource InputBorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    <Setter Property="Padding" Value="9,6" />
  </Style>

  <Style Selector="ComboBox:pointerover">
    <Setter Property="Background" Value="{DynamicResource HoverSurfaceBrush}" />
  </Style>

  <Style Selector="ComboBox:focus">
    <Setter Property="BorderBrush" Value="{DynamicResource FocusBrush}" />
    <Setter Property="BorderThickness" Value="1.5" />
  </Style>

  <Style Selector="ComboBoxItem">
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    <Setter Property="Background" Value="{DynamicResource InputBrush}" />
  </Style>

  <Style Selector="Button">
    <Setter Property="Background" Value="{DynamicResource CardBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    <Setter Property="CornerRadius" Value="12" />
    <Setter Property="Padding" Value="12,8" />
  </Style>

  <Style Selector="Button:pointerover">
    <Setter Property="Background" Value="{DynamicResource HoverSurfaceBrush}" />
  </Style>

  <Style Selector="Button:pressed">
    <Setter Property="Background" Value="{DynamicResource PressedSurfaceBrush}" />
  </Style>

  <Style Selector="Button:disabled">
    <Setter Property="Foreground" Value="{DynamicResource TextDisabledBrush}" />
  </Style>

  <Style Selector="Button.primary">
    <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
    <Setter Property="Foreground" Value="#FFFFFF" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Padding" Value="18,9" />
    <Setter Property="FontSize" Value="15" />
    <Setter Property="CornerRadius" Value="12" />
  </Style>

  <Style Selector="Button.primary:pointerover">
    <Setter Property="Background" Value="{DynamicResource AccentHoverBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource AccentHoverBrush}" />
  </Style>

  <Style Selector="Button.primary:pressed">
    <Setter Property="Background" Value="{DynamicResource AccentPressedBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource AccentPressedBrush}" />
  </Style>

  <Style Selector="Button.ghost">
    <Setter Property="Background" Value="{DynamicResource InputBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource InputBorderBrush}" />
  </Style>

  <Style Selector="Button.icon">
    <Setter Property="Width" Value="38" />
    <Setter Property="Height" Value="38" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="CornerRadius" Value="10" />
  </Style>

  <Style Selector="Button.compact">
    <Setter Property="Padding" Value="12,6" />
    <Setter Property="FontSize" Value="13" />
    <Setter Property="CornerRadius" Value="10" />
  </Style>

  <Style Selector="Button.closeIcon">
    <Setter Property="Width" Value="32" />
    <Setter Property="Height" Value="32" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="10" />
    <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
  </Style>

  <Style Selector="Button.closeIcon:pointerover">
    <Setter Property="Background" Value="{DynamicResource HoverSurfaceBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource InputBorderBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
  </Style>

  <Style Selector="Button.closeIcon:pressed">
    <Setter Property="Background" Value="{DynamicResource PressedSurfaceBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}" />
  </Style>

  <Style Selector="Border.accountPrimary">
    <Setter Property="Background" Value="{DynamicResource PanelBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource InputBorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="14" />
    <Setter Property="Padding" Value="10,9" />
  </Style>

  <Style Selector="Border.accountPrimary:pointerover">
    <Setter Property="Background" Value="{DynamicResource HoverSurfaceBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}" />
  </Style>

  <Style Selector="Button.accountArrow">
    <Setter Property="Width" Value="22" />
    <Setter Property="Height" Value="22" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="CornerRadius" Value="7" />
  </Style>

  <Style Selector="Button.accountArrow:pointerover">
    <Setter Property="Background" Value="{DynamicResource HoverSurfaceBrush}" />
  </Style>

  <Style Selector="Button.accountArrow:pressed">
    <Setter Property="Background" Value="{DynamicResource PressedSurfaceBrush}" />
  </Style>

  <Style Selector="Border.accountMenuPopup">
    <Setter Property="Background" Value="{DynamicResource CardBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="16" />
    <Setter Property="Padding" Value="8" />
    <Setter Property="BoxShadow" Value="0 12 32 0 rgba(0, 0, 0, 0.20)" />
  </Style>

  <Style Selector="Button.accountMenuItem">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="CornerRadius" Value="10" />
    <Setter Property="Padding" Value="12,10" />
    <Setter Property="HorizontalContentAlignment" Value="Left" />
  </Style>

  <Style Selector="Button.accountMenuItem:pointerover">
    <Setter Property="Background" Value="{DynamicResource HoverSurfaceBrush}" />
  </Style>

  <Style Selector="Button.link">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="Foreground" Value="{DynamicResource LinkBrush}" />
    <Setter Property="HorizontalAlignment" Value="Left" />
    <Setter Property="Cursor" Value="Hand" />
  </Style>

  <Style Selector="Button.link:pointerover">
    <Setter Property="Opacity" Value="0.8" />
  </Style>

  <Style Selector="Button.nav">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="12" />
    <Setter Property="Padding" Value="11,8" />
    <Setter Property="HorizontalContentAlignment" Value="Left" />
    <Setter Property="FontSize" Value="15" />
  </Style>

  <Style Selector="Button.nav:pointerover">
    <Setter Property="Background" Value="{DynamicResource HoverSurfaceBrush}" />
  </Style>

  <Style Selector="Button.navActive">
    <Setter Property="Background" Value="{DynamicResource AccentSoftBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
    <Setter Property="BorderThickness" Value="1.2" />
    <Setter Property="FontWeight" Value="SemiBold" />
  </Style>

  <Style Selector="RadioButton.pill">
    <Setter Property="Background" Value="{DynamicResource InputBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource InputBorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
    <Setter Property="CornerRadius" Value="999" />
    <Setter Property="Padding" Value="10,5" />
    <Setter Property="FontSize" Value="13" />
  </Style>

  <Style Selector="RadioButton.pill:pointerover">
    <Setter Property="Background" Value="{DynamicResource HoverSurfaceBrush}" />
  </Style>

  <Style Selector="RadioButton.pill:checked">
    <Setter Property="Background" Value="{DynamicResource AccentSoftBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    <Setter Property="BorderThickness" Value="1.5" />
  </Style>

  <Style Selector="CheckBox">
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    <Setter Property="FontSize" Value="14" />
  </Style>

  <Style Selector="CheckBox.appCheck">
    <Setter Property="Width" Value="22" />
    <Setter Property="Height" Value="22" />
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="Cursor" Value="Hand" />
  </Style>
</Styles>
